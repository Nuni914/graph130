ace: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n.attention {\n  font-weight: bold;\n}\n.hidden-scrollbar {\n  /* Chrome/Safari/Webkit */\n  scrollbar-width: none;\n  /* Firefox */\n}\n.hidden-scrollbar::-webkit-scrollbar {\n  display: none;\n}\n.meeting-admin-diagnostics input[type="text"] {\n  width: 75%;\n  max-width: 450px;\n}\n.meeting-admin-diagnostics .warning {\n  color: #a04242;\n  font-size: 0.8em;\n}\n.meeting-admin-diagnostics .navigation-tab {\n  font-weight: bold;\n}\n.meeting-admin-diagnostics .teams-search-type-dropdown {\n  margin-bottom: 10px;\n}\n.meeting-admin-diagnostics .teams-entity-toggle {\n  margin-left: 20px;\n}\n.meeting-admin-diagnostics .teams-entity-toggle-button {\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  margin-bottom: 10px;\n}\n.meeting-admin-diagnostics .teams-entity-toggle-expander {\n  margin-left: -4px;\n}\n.meeting-admin-diagnostics .teams-entity-toggle-area {\n  margin-left: 20px;\n}\n.meeting-admin-diagnostics .teams-entity-select {\n  margin-left: 20px;\n}\n.meeting-admin-diagnostics .teams-entity-info {\n  margin-top: -20px;\n}\n.meeting-admin-diagnostics .recording-list {\n  margin-left: 20px;\n}\n.recording-query-link {\n  color: #0F7395;\n  text-decoration: none;\n}\n.recording-query-link:hover,\n.recording-query-link:focus {\n  cursor: pointer;\n  text-decoration: underline;\n}\n.meeting-admin-diagnostics-user {\n  display: flex;\n  margin-left: 20px;\n}\n.recording-row {\n  margin-bottom: 20px;\n}\n.recording-row .new {\n  color: orange;\n}\n.recording-row .recording-logs {\n  margin: 5px 15px;\n}\n.recording-row .recording-logs .recording-log-sub-entry {\n  margin-left: 10px;\n}\n.recording-row .recording-logs .recording-log-entry,\n.recording-row .recording-logs .recording-log-sub-entry {\n  margin-top: 5px;\n  margin-bottom: 5px;\n}\n.recording-row .recording-logs .recording-log-entry a,\n.recording-row .recording-logs .recording-log-sub-entry a {\n  color: #0F7395;\n  text-decoration: none;\n}\n.recording-row .recording-logs .recording-log-entry a:hover,\n.recording-row .recording-logs .recording-log-sub-entry a:hover,\n.recording-row .recording-logs .recording-log-entry a:focus,\n.recording-row .recording-logs .recording-log-sub-entry a:focus {\n  cursor: pointer;\n  text-decoration: underline;\n}\n.recording-row .recording-logs .recording-log-entry .recording-log-timestamp,\n.recording-row .recording-logs .recording-log-sub-entry .recording-log-timestamp {\n  margin-left: 5px;\n}\n.recording-row .recording-logs .recording-log-entry .recording-log-error,\n.recording-row .recording-logs .recording-log-sub-entry .recording-log-error {\n  margin-left: 5px;\n}\n.recording-row .recording-logs .recording-log-entry .recording-log-details-button,\n.recording-row .recording-logs .recording-log-sub-entry .recording-log-details-button {\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n}\n.recording-row .recording-logs .recording-log-entry .recording-log-details-expander,\n.recording-row .recording-logs .recording-log-sub-entry .recording-log-details-expander {\n  font-size: 14px;\n}\n.recording-row .recording-logs .recording-log-entry .recording-log-details-data,\n.recording-row .recording-logs .recording-log-sub-entry .recording-log-details-data {\n  font-size: 12px;\n}\n.recording-row .recording-logs .recording-log-queue .property-page-property {\n  margin-left: 0;\n}\n',"",{version:3,sources:["webpack://./React/Admin/Components/Diagnostics/MeetingIntegrationDiagnostics.less","webpack://./../../WebCore/css/Assets/Assets.less","webpack://./../../WebCore/css/Assets/Mixins.less"],names:[],mappings:"AAAA,+CAA+C;AAC/C,UAAU;ACcV;EACI,sDAAA;EACA,kGAAA;EACA,iGAAA;ADZJ;AACA,UAAU;AACV,kBAAkB;AAClB,6EAA6E;AAC7E,gBAAgB;AAChB,gCAAgC;AAChC,oBAAoB;AACpB,wBAAwB;AACxB,WAAW;AACX,yBAAyB;AACzB,oBAAoB;AACpB,mCAAmC;AACnC,cAAc;AACd,YAAY;AACZ,mDAAmD;AACnD,wBAAwB;AACxB,WAAW;AACX,gBAAgB;AAChB,WAAW;AACX,UAAU;AACV,mBAAmB;AACnB,WAAW;ACqPX;EACI,WAAA;ADnPJ;ACsPA;EACI,aAAA;ADpPJ;AEwIA;EACI,cAAA;EACA,YAAA;AFtIJ;AEyIA;EACI,WAAA;EACA,WAAA;AFvIJ;AE2QA;EACI,yBAAA;AFzQJ;AE4QA;EACI,mBAAA;EACA,gBAAA;EACA,uBAAA;AF1QJ;AE2RA;EACI,iBAAA;AFzRJ;AEwUA;EFtUE,yBAAyB;EEwUvB,qBAAA;EFtUF,YAAY;AACd;AEoUI;EAAuB,aAAA;AFjU3B;AAtDA;EAGQ,UAAA;EACA,gBAAA;AAsDR;AA1DA;EAQQ,cAAA;EACA,gBAAA;AAqDR;AA9DA;EAaQ,iBAAA;AAoDR;AAjEA;EAiBQ,mBAAA;AAmDR;AApEA;EAqBQ,iBAAA;AAkDR;AAvEA;EAyBQ,eAAA;EACA,aAAA;EACA,mBAAA;EACA,mBAAA;AAiDR;AA7EA;EAgCQ,iBAAA;AAgDR;AAhFA;EAoCQ,iBAAA;AA+CR;AAnFA;EAwCQ,iBAAA;AA8CR;AAtFA;EA4CQ,iBAAA;AA6CR;AAzFA;EAgDQ,iBAAA;AA4CR;AAxCA;EEoSI,cAAA;EACA,qBAAA;AFzPJ;AE2PI;;EACI,eAAA;EACA,0BAAA;AFxPR;AA7CA;EACI,aAAA;EACA,iBAAA;AA+CJ;AA5CA;EACI,mBAAA;AA8CJ;AA/CA;EAIQ,aAAA;AA8CR;AAlDA;EAQQ,gBAAA;AA6CR;AArDA;EAWY,iBAAA;AA6CZ;AAxDA;;EAeY,eAAA;EACA,kBAAA;AA6CZ;AA7DA;;EE2RI,cAAA;EACA,qBAAA;AF1NJ;AE4NI;;;;EACI,eAAA;EACA,0BAAA;AFvNR;AAzEA;;EAuBgB,gBAAA;AAsDhB;AA7EA;;EA2BgB,gBAAA;AAsDhB;AAjFA;;EA+BgB,eAAA;EACA,aAAA;EACA,mBAAA;AAsDhB;AAvFA;;EAqCgB,eAAA;AAsDhB;AA3FA;;EAyCgB,eAAA;AAsDhB;AA/FA;EA8CY,cAAA;AAoDZ",sourcesContent:['@import "../../../../../../WebCore/css/Assets/Assets.less";\n@import "../../../../../../WebCore/css/Assets/Mixins.less";\n\n@recording-margin: 5px;\n@indent-margin: 20px;\n\n.meeting-admin-diagnostics {\n\n    input[type="text"] {\n        width: 75%;\n        max-width: 450px;\n    }\n\n    .warning {\n        color: @red-medium;\n        font-size: @font-size-small;\n    }\n\n    .navigation-tab {\n        font-weight: bold;\n    }\n\n    .teams-search-type-dropdown {\n        margin-bottom: 10px;\n    }\n\n    .teams-entity-toggle {\n        margin-left: @indent-margin;\n    }\n\n    .teams-entity-toggle-button {\n        cursor: pointer;\n        display: flex;\n        align-items: center;\n        margin-bottom: 10px\n    }\n\n    .teams-entity-toggle-expander {\n        margin-left: -4px;\n    }\n\n    .teams-entity-toggle-area {\n        margin-left: @indent-margin;\n    }\n\n    .teams-entity-select {\n        margin-left: @indent-margin;\n    }\n\n    .teams-entity-info {\n        margin-top: -@indent-margin;\n    }\n\n    .recording-list {\n        margin-left: @indent-margin;\n    }\n}\n\n.recording-query-link {\n    .link();\n}\n\n.meeting-admin-diagnostics-user {\n    display: flex;\n    margin-left: @indent-margin;\n}\n\n.recording-row {\n    margin-bottom: 20px;\n\n    .new {\n        color: orange;\n    }\n\n    .recording-logs {\n        margin: @recording-margin 15px;\n\n        .recording-log-sub-entry {\n            margin-left: 10px;\n        }\n\n        .recording-log-entry, .recording-log-sub-entry {\n            margin-top: @recording-margin;\n            margin-bottom: @recording-margin;\n\n            a {\n                .link();\n            }\n\n            .recording-log-timestamp {\n                margin-left: @recording-margin;\n            }\n\n            .recording-log-error {\n                margin-left: @recording-margin;\n            }\n\n            .recording-log-details-button {\n                cursor: pointer;\n                display: flex;\n                align-items: center;\n            }\n\n            .recording-log-details-expander {\n                font-size: 14px;\n            }\n\n            .recording-log-details-data {\n                font-size: 12px;\n            }\n        }\n\n        .recording-log-queue .property-page-property {\n            margin-left: 0;\n        }\n    }\n}\n','/* Constants / styles used across the product */\n\n/* Fonts */\n@font: Segoe UI, Helvetica, sans-serif;\n@font-semibold: Segoe UI Semibold, Helvetica Neue, Segoe UI, Helvetica, sans-serif;\n@font-light: Segoe UI Light, HelveticaNeue-Light, Segoe UI, Helvetica, sans-serif;\n.font-light() {\n    font-family: var(--panopto-font-family-light);\n    font-weight: 100; // FF doesn\'t include Segoe UI Light, font-weight lighter approximates it.\n}\n.font-semibold() {\n    font-family: var(--panopto-font-family-semibold);\n    font-weight: 600;\n}\n\n:root {\n    --panopto-font-family: @font;\n    --panopto-font-family-semibold: @font-semibold;\n    --panopto-font-family-light: @font-light;\n}\n\n@font-size-base: 16px;\n@font-size-medium: 1.45em;\n@font-size-large: 1.5em;\n@font-size-big-title: 1.7em;\n@font-size-small: .8em;\n@font-size-xsmall: .7em;\n@font-size-extra-large: 2.1em;\n@font-size-huge: 3.0em;\n// Our website uses this as its base\n@font-size-website-base: 13px;\n// These are basic font sizes used by the recorder. We should start making all of these consistent\n@font-size-title: 1.3em;\n@font-size-header: 1.2em;\n@font-size-command-button: 1.1em;\n@font-size-subtitle: .9em;\n@font-size-option: .8em;\n@font-size-button: .7em;\n\n@icon-size-without-text: 24px;\n@icon-size-with-text: 18px;\n\n/* Sizes */\n@site-min-width: 1004px;\n\n@small-logo-max-width: 265px;\n@small-logo-max-height: 23px;\n@large-logo-max-width: 340px;\n@large-logo-max-height: 50px;\n\n// Preferred hit target size for touch interfaces.\n@touch-target-size: 48px;\n// Smaller touch target size for tightly constrained contexts.\n@touch-target-size-small: 40px;\n\n@button-spacing: 10px;\n\n/* Page gradient */\n@page-gradient: linear-gradient(to bottom, #ffffff 0%, #f5f5f5 60%);\n\n/* Opacities of black (for consistent effect over gradient vs. fixed grays) */\n@darken-hovered: rgba(0, 0, 0, 0.03);\n@darken-selected: rgba(0, 0, 0, 0.06);\n@darken-selected-session: rgba(0, 0, 0, 0.05);\n\n/* Font Colors */\n@font-color-primary: #009900;\n@font-color-secondary: #466c2c;\n@font-color-link: #0F7395;\n\n@font-color-error: #990000;\n@font-color-dark: #000000;\n@font-color: #464646;\n@font-color-light: #777777;\n@font-color-lightest: #999999;\n@font-color-light-background: #b8b8b8;\n@font-light-gray: #aaaaaa;\n\n@font-color-black-80pct: rgba(0, 0, 0, 0.8);\n\n/* Font Colors (Accessibility) */\n@font-color-light-white-background: #767676;\n\n/* New font colors */\n@text-color-primary: rgba(0, 0, 0, .9);\n@text-color-secondary: rgba(0, 0, 0, .7);\n@text-color-on-accent: rgba(255, 255, 255);\n@text-color-additional: rgba(0, 0, 0, .6);\n\n@icon-color-primary: rgba(0, 0, 0, .8);\n@icon-color-secondary: rgba(0, 0, 0, .6);\n@icon-color-additional: rgba(0, 0, 0, .5);\n\n@border-color-primary: rgba(0, 0, 0, .1);\n\n@background-hover: rgba(0, 0, 0, .05);\n@background-active: rgba(0, 0, 0, .1);\n\n/* "Dark Theme" Colors */\n@overlay-background-color: rgba(0, 0, 0, 0.8);\n@icon-color-dark-theme: rgba(255, 255, 255, 0.8);\n@icon-color-active-dark-theme: white;\n@tab-highlight-color-dark-theme: rgba(255, 255, 255, 0.8);\n@border-color-dark-theme: rgba(255, 255, 255, 0.2);\n@font-color-dark-theme: rgba(255, 255, 255, 1);\n@font-color-secondary-dark-theme: rgba(255, 255, 255, 0.8);\n@hover-background-color-dark-theme: rgba(255, 255, 255, 0.1);\n@contrast-background-color-dark-theme: rgba(255, 255, 255, 0.2);\n\n/* Colors */\n@blue-selected: #aedcf1;\n\n@white-bright: #e6e6e6;\n@pure-white: #ffffff;\n\n@red: #bd4f4f;\n@red-medium: #a04242;\n@red-dark: #8c3939;\n@red-light: #ebcaca;\n@red-bright: #dd3217;\n\n@green: #54bf6d;\n@green-medium: #1d8f37;\n@green-dark: #185e0d;\n@green-light: #92c88a;\n@green-background: #eef5f0;\n@green-sunny: #719f46;\n@green-shady: #48761d;\n\n// Branded Panopto Green. Do _NOT_ use this for areas that should be affected by branding\n@panopto-green: #30733F;\n\n@icon-color: #626262;\n@header-color: #f5f5f5;\n@header-dropdown-background-color: White;\n@focused-background-color: #e8e8e8;\n@gray-border: #e0e0e0;\n@gray-light: #d6d6d6;\n@gray-hover: #f0f0f0;\n@gray-very-light: #f2f2f2;\n@gray-hint: #f5f5f5;\n@gray-press: #cccccc;\n@gray-dark: #999999;\n@gray-header: #666;\n@gray-shadow: #888;\n@gray-future: #f2f2f2;\n@dark-selected: #8b8b8b;\n@gray-divider: #989898;\n@light-selected: #dbdbdb;\n@gray-silver: #e7e7e7;\n@gray-disabled: #ebebe4;\n@gray-button-hover: #e5e5e5;\n@gray-transparent: rgba(0,0,0,0.2);\n@gray-transparent-subtle: rgba(0,0,0,0.1);\n@gray-transparent-light: rgba(0,0,0,0.3);\n@gray-transparent-medium: rgba(0,0,0,0.5);\n@gray-transparent-dark: rgba(0,0,0,0.6);\n@gray-dark-shadow: rgba(0,0,0,0.7);\n@gray-darker-shadow: rgba(0,0,0,0.8);\n@gray-watermark: gray;\n@letterbox-color: black;\n@rr-letterbox-color: #3f3f3f;\n@material-box-shadow: 0 6px 10px 0 rgba(0,0,0,.14),\n                      0 1px 18px 0 rgba(0,0,0,.12),\n                      0 3px 5px -1px rgba(0,0,0,.20);\n\n@background-warning: orange;\n\n@yellow: #feffc9;\n\n@stored-quota-foreground: #B56F90;\n@stored-quota-background: #B56F90;\n@delivered-quota-foreground: #4798D0;\n@delivered-quota-background: #4798D0;\n\n@drop-target-background: rgba(231, 239, 254, 0.5);\n@drop-target-background-invalid: fadeout(white, 20%);\n@drop-target-border: fadeout(#4384f4, 57%);\n\n/* For gradient buttons */\n\n/* Small Thumbnail */\n@small-thumbnail-cell-width: 120px;\n@small-thumbnail-height: 60px;\n@small-thumbnail-width: (16 / 9) * @small-thumbnail-height;\n\n/* Volume preview specific colors */\n@neutral-color: #0098cc;\n@loud-color: #9d0b0b;\n@quiet-color: #ffa900;\n@neutral-text-color: #019acd;\n@loud-text-color: #8a1d1d;\n@quiet-text-color: #d08e0b;\n@loud-warning-color: #cf8787;\n@quiet-warning-color: #ffd57f;\n@loud-border: #7fcce6;\n\n/* Opacities */\n@button-opacity: .6;\n@button-hover-opacity: .8;\n@button-active-opacity: 1.0;\n@button-disabled: .3;\n\n/* Borders */\n@input-border-edit: 1px solid #959595;\n@input-border-hover: 1px solid #cdcdcd;\n@input-border-white: 1px solid White;\n@header-dropdown-border: 1px solid #cccccc;\n@input-border-light: 1px solid #cccccc;\n@input-border-extra-light: 1px solid @gray-border;\n/* Input Border Color (WCAG 1.4.11 Accessibility) */\n@input-border-color: #8C8C8C;\n\n/* Common measurements */\n\n// The height of most of our modal inputs\n@input-height: 28px;\n\n/* Images */\n@spinner-path: "Spinner/";\n@spinner-large: "large-comet-animation-grey.gif";\n@spinner-small-white: "spinner_small_white.gif";\n@spinner-small-beige: "spinner_small_eee.gif";\n\n@spinner-large-themable: "spinner_large_themable.png";\n@spinner-small-white-themable: "spinner_small_themable_white.png";\n@spinner-small-beige-themable: "spinner_small_themable_eee.png";\n@spinner-small-gray-themable: "spinner_small_themable_e0e0e0.png";\n\n/* Transitions */\n@viewer-transition: all .125s ease-in-out;\n\n/* Mobile */\n\n// Google recommends a base of 16px\n// https://developers.google.com/speed/docs/insights/UseLegibleFontSizes?hl=en\n@mobile-base-size: 16px;\n\n// Maybe we want to change this to a hex code later\n// so for now use yellow and we can change it easier\n@mobile-font-warning: yellow;\n@mobile-background-disabled: rgb(187, 187, 187);\n\n// Mobile query constants\n\n// "almost" is one less then actual width,\n// "almost" queries should be used for max-width \n// actual queries should be used for min-width\n// By keeping those consistent we can be sure that the layout\n// doesn\'t do funky things on the pixel between the two\n// and we won\'t need to consider which media query comes first\n// NOTE: The parens around the following bits are necessary, LESS generates invalid CSS without them.\n@ipad4-portrait-width: 320px;\n@iphone5-landscape-width: 568px;\n@iphone6-portrait-width: 375px;\n\n@almost-iphone6-portrait-width: (@iphone6-portrait-width - 1);\n\n@ipad-mini-portrait-width: 768px;\n@almost-ipad-mini-portrait-width: (@ipad-mini-portrait-width - 1);\n\n@nexus7-landscape-width: 960px;\n@almost-nexus7-landscape-width: (@nexus7-landscape-width - 1);\n\n/* Embed */\n@defaultEmbedWidth: 720px;\n@defaultEmbedHeight: 405px;\n\n/* Material icons */\n@checkbox-glyph-inset: 3px;\n\n/* Resets */\nbody {\n    margin: 0px;\n}\n\n.clicked {\n    outline: none;\n}\n','@small-loading-indicator-length: 16px;\n\n.border-radius (@radius) {\n    -webkit-border-radius: @radius;\n    -moz-border-radius: @radius;\n    border-radius: @radius;\n}\n\n.box-sizing (@sizing) {\n    box-sizing: @sizing;\n    -moz-box-sizing: @sizing;\n}\n\n// Prevents anti aliasing\n// http://stackoverflow.com/questions/14068103/disable-antialising-when-scaling-images\n.prevent-anti-aliasing () {\n    // The browser will ignore the lines it can\'t understand\n    // and so it works to have the same property listed multiple times\n    image-rendering: optimizeSpeed;\n    image-rendering: -moz-crisp-edges;\n    image-rendering: -o-crisp-edges;\n    image-rendering: -webkit-optimize-contrast;\n    image-rendering: pixelated;\n    image-rendering: optimize-contrast;\n}\n\n.user-select(@select) {\n    -webkit-touch-callout: @select;\n    -webkit-user-select: @select;\n    -khtml-user-select: @select;\n    -moz-user-select: @select;\n    user-select: @select;\n}\n\n.background-image-gradient (@deg, @color-bottom, @color-top) {\n    background-image: -webkit-linear-gradient(@deg, @color-bottom 0%, @color-top 100%);\n    background-image: -moz-linear-gradient(@deg, @color-bottom 0%, @color-top 100%);\n}\n\n.background-complex-gradient (@deg, @color-first, @color-second, @color-third, @color-fourth) {\n    background-image: -webkit-linear-gradient(@deg, @color-first, @color-second, @color-third, @color-fourth);\n    background-image: -moz-linear-gradient(@deg, @color-first, @color-second, @color-third, @color-fourth);\n}\n\n// Block-level elements with known dimensions can be centered within positioned parents.\n.center-block(@width, @height, @h-offset: 0, @v-offset: 0) {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    // Block origin is centered by the above, shift by half height / width to align block center with container center.\n    margin-left: -(@width / 2) + @h-offset;\n    margin-top: -(@height / 2) + @v-offset;\n    width: @width;\n    height: @height;\n}\n\n.clickable () {\n    &:hover {\n        cursor: pointer;\n    }\n}\n\n.access-icons(@length) {\n    .access-item-icon(@image) {\n        .icon("Share/", @image, @length, @length);\n    }\n\n    &.invite {\n        .access-item-icon("icon_email.png");\n    }\n\n    &.group {\n        .access-item-icon("icon_group.png");\n    }\n\n    &.user {\n        .access-item-icon("icon_user.png");\n    }\n}\n\n.pressable (@background-highlight, @background-pressed, @cursor: default) {\n    &:hover {\n        background-color: @background-highlight;\n        cursor: @cursor;\n    }\n    &:focus {\n        background-color: @background-highlight;\n    }\n    &:active {\n        background-color: @background-pressed;\n    }\n}\n\n.hoverable (@background-highlight, @background-pressed, @cursor: default) {\n    .transition(background-color .15s);\n    &:hover {\n        background-color: @background-highlight;\n        cursor: @cursor;\n        .transition(background-color .15s);\n    }\n    &:active {\n        background-color: @background-pressed;\n        .transition(background-color .15s);\n    }\n}\n\n// @child-class-string needs to the the class selector without the \'.\', LESS allows us to pass strings but not complete selectors\n// http://stackoverflow.com/questions/19602812/less-mixin-a-variable-class-name\n.hoverable-child (@child-class-string, @background-parent-highlight, @background-child-highlight, @background-pressed, @cursor: default) {\n    &:hover .@{child-class-string} {\n        background-color: @background-parent-highlight;\n        .transition(background-color .15s);\n    }\n    .@{child-class-string} {\n        .hoverable(@background-child-highlight, @background-pressed, @cursor);\n    }\n}\n\n.hoverable-opacity() {\n    opacity: @button-opacity;\n\n    &:hover, &:focus {\n        opacity: @button-hover-opacity;\n    }\n\n    &:active {\n        opacity: @button-active-opacity;\n    }\n}\n\n.background-image(@root, @image, @repeat: no-repeat, @align: center) {\n    background-image: ~"url(\'@{image-path}@{root}@{image}\')";\n    background-repeat: @repeat;\n    background-position: @align;\n}\n\n.icon (@root, @image, @width: auto, @height: auto, @repeat: no-repeat, @align: center) {\n    .background-image(@root, @image, @repeat, @align);\n    width: @width;\n    height: @height;\n}\n\n.transition(@params) {\n    -webkit-transition: @params;\n    -moz-transition: @params;\n    -o-transition: @params;\n    transition: @params;\n}\n\n.transform(@params) {\n    transform: @params;\n    -webkit-transform: @params;\n}\n\n.pressable-icon(@root, @image, @image-hover, @image-press, @width: auto, @height: auto, @repeat: no-repeat, @align: center) {\n    .icon(@root, @image, @width, @height, @repeat, @align);\n\n    &:hover {\n        .icon(@root, @image-hover, @width, @height, @repeat, @align);\n        cursor: default;\n    }\n    &:focus {\n        .icon(@root, @image-hover, @width, @height, @repeat, @align);\n    }\n    &:active {\n        .icon(@root, @image-press, @width, @height, @repeat, @align);\n    }\n}\n\n.break {\n    display: block;\n    height:  15px;\n}\n\n.clear {\n    clear: both;\n    height: 0px;\n}\n\n.box-shadow(none) {\n    -webkit-box-shadow: none;\n    -moz-box-shadow: none;\n    box-shadow: none;\n}\n\n.box-shadow(@color, @h-shadow, @v-shadow, @blur, @spread) {\n    -webkit-box-shadow: @color @h-shadow @v-shadow @blur @spread;\n    -moz-box-shadow: @color @h-shadow @v-shadow @blur @spread;\n    box-shadow: @color @h-shadow @v-shadow @blur @spread;\n}\n\n.box-shadow-inset(@color, @h-shadow, @v-shadow, @blur, @spread) {\n    -webkit-box-shadow: @color @h-shadow @v-shadow @blur @spread inset;\n    -moz-box-shadow: @color @h-shadow @v-shadow @blur @spread inset;\n    box-shadow: @color @h-shadow @v-shadow @blur @spread inset;\n}\n\n.borders(@top-color, @right-color, @bottom-color, @left-color) {\n    border-top:1px solid @top-color;\n    border-right: 1px solid @right-color;\n    border-bottom:1px solid @bottom-color;\n    border-left:1px solid @left-color;\n}\n\n.rotating-animation() {\n    // IE and FF support the w3 standard keyframes\n    @keyframes rotate {\n        0% {\n            transform: rotate(0deg);\n        }\n        100% {\n            transform: rotate(360deg);\n        }\n    }\n\n    // Chrome and Safari need special webkit\n    @-webkit-keyframes rotate {\n        0% {\n            -webkit-transform: rotate(0deg);\n        }\n        100% {\n            -webkit-transform: rotate(360deg);\n        }\n    }\n\n    animation: rotate 2s linear infinite;\n    -webkit-animation: rotate 2s linear infinite;\n}\n\n.color-holder(@diameter) {\n    position: absolute;\n    .border-radius(50%); // Circle\n    width: @diameter;\n    height: @diameter;\n}\n\n.indicator-border(@border-size, @color){\n    left: -@border-size;\n    top: -@border-size;\n    border: @border-size solid @color;\n}\n\n.small-loading-indicator(@image-grey, @image-themed, @border-color) {\n    @small-length: @small-loading-indicator-length;\n    width: @small-length;\n    height: @small-length;\n    overflow: hidden;\n\n    .branding-color-holders {\n        display: block;\n       .color-holder(15px);\n    }\n\n    .loading-indicator {\n        position: relative;\n        .icon(@spinner-path, @image-grey, @small-length, @small-length);\n        .indicator-border(10px, @border-color);\n\n        &.branded-animation {\n            // The "- 1" fixes a samll issue in Chrome where the when zoomed to 90% you could see a second spinner\n            .icon(@spinner-path, @image-themed, @small-length - 1, @small-length - 1);\n            .rotating-animation();\n        }\n    }\n}\n\n.opacity(@opacity) {\n    opacity: @opacity;\n    @percent: @opacity * 100;\n    // IE8 and below\n    filter: alpha(opacity=@percent);\n}\n\n.horizontal-rule(@color) {\n    display: block;\n    border-bottom: 1px solid @color;\n}\n\n.popup(@z-index) {\n    z-index: @z-index;\n    .box-shadow(@gray-dark, 2px, 3px, 5px, 0);\n    border: @header-dropdown-border;\n    background-color: @header-dropdown-background-color;\n    position: absolute;\n    text-align: left;\n\n    .popup-title {\n        color: @font-color;\n        font-weight: bold;\n    }\n}\n\n.header-dropdown() {\n    .popup(100003);\n\n    > a, > div {\n        &:hover {\n            background-color: @gray-hover;\n            cursor: default;\n        }\n        &:active {\n            background-color: @gray-press;\n        }\n        text-decoration: none;\n        display: block;\n    }\n}\n\n.error {\n    color: @font-color-error !important;\n}\n\n.ellipsis {\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n}\n\n// @lines is honored on WebKit.\n// @max-height provides a fallback on other browsers (simple vertical truncation).\n.multiline-ellipsis (@lines, @max-height) {\n    // On WebKit, show ellipsis after two lines if text is longer.\n    display: -webkit-box;\n    -webkit-line-clamp: @lines;\n    -webkit-box-orient: vertical;\n    // For non-WebKit browsers, just crop lines beyond the second (no ellipsis).\n    max-height: @max-height;\n    overflow: hidden;\n    // Override "nowrap" behavior of .ellipsis (typically also present for tooltips) to enable wrapping to additional lines.\n    white-space: normal;\n}\n\n.attention {\n    font-weight: bold;\n}\n\n\n// Styles a div as a table row, with direct div children as cells\n.table-row (@width: 100%, @align: top) {\n    display: table;\n    width: @width;\n\n    > div, > a, > img, > i {\n        display: table-cell;\n        vertical-align: @align;\n    }\n}\n\n// Styles any element to look and behavior like a link\n.link (@cursor: pointer, @color: @font-color-link) {\n    color: @color;\n    text-decoration: none;\n\n    &:hover, &:focus {\n        cursor: @cursor;\n        text-decoration: underline;\n    }\n}\n\n// Creates a thin, two-tone scrollbar (plain thumb on plain track), where supported by the browser.\n// Width is 8px on Webkit, "thin" on FF (works out to similar), and full width on other browsers.\n// Webkit thumb will have a 5px border-radius (others will have square edges).\n.custom-scrollbar(@thumb-color, @track-color) {\n    @supports not selector(::-webkit-scrollbar) {\n        scrollbar-width: thin;\n        scrollbar-color: @thumb-color @track-color;\n    }\n\n    &::-webkit-scrollbar {\n        background-color: @track-color;\n        width: 8px;\n        height: 8px;\n    }\n\n    &::-webkit-scrollbar-thumb {\n        background-color: @thumb-color;\n        border-radius: 5px;\n    }\n}\n\n.hidden-scrollbar {\n    &::-webkit-scrollbar { display: none; } /* Chrome/Safari/Webkit */\n    scrollbar-width: none; /* Firefox */\n}\n\n.edit-control() {\n    padding: 2px;\n    bottom: 0px;\n    right: 0px;\n    z-index: 1;\n    background-color: white;\n\n    > div {\n        .link;\n        display: inline-block;\n        padding: 3px 8px 4px 8px;\n        border: 1px solid @gray-press;\n        background-color: white;\n    }\n}\n\n.viewer-message() {\n    margin: 20px auto 0px auto;\n    text-align: center;\n    // This is the size used in Viewer.less\n    // repeated here to make this consistent between pages\n    font-size: medium;\n\n    #messageText {\n        padding: 10px;\n    }\n\n    #messageLink {\n        padding: 0px 10px 10px 10px;\n    }\n}\n\n.role-select(@width, @margin-top) {\n    font-family: @font;\n    width: @width;\n    height: 38px;\n    margin-top: @margin-top;\n    padding: 6px;\n    font-size: @font-size-base;\n    .border-radius(4px);\n    color: @font-color-light;\n    display: block;\n    vertical-align: top;\n}\n\n// Shared thumbnail styles\n.thumbnail(@thumbnail-width-param: 196px, @thumbnail-height-param: 110px) {\n    // This is necessary to surface these params in the enclosing scope of the mixin.\n    @thumbnail-width: @thumbnail-width-param;\n    @thumbnail-height: @thumbnail-height-param;\n    @thumbnail-border: 1px;\n    @overlay-margin: 2px;\n\n    .thumbnail-container {\n        // Provide a positioning context for thumbnail overlays\n        position: relative;\n        width: @thumbnail-width;\n        height: @thumbnail-height;\n        border: @thumbnail-border solid @gray-border;\n        .border-radius(3px);\n        background: black;\n        // Prevent child image from bleeding out of the rounded corners\n        overflow: hidden;\n\n        // Give linked thumbnails a darkened border on hover\n        &.viewable:hover {\n            border: @thumbnail-border solid @gray-dark;\n        }\n\n        // Show link or span depending on "viewable" class on container\n        .thumbnail-span,\n        &.viewable .thumbnail-link {\n            display: block;\n        }\n        .thumbnail-link,\n        &.viewable .thumbnail-span {\n            display: none;\n        }\n\n        // Needed to enable "height/width: 100%" to work on ".thumbnail-img/-failed-load" below\n        .thumbnail-link,\n        .thumbnail-span {\n            width: 100%;\n            height: 100%;\n        }\n\n        .thumbnail-img,\n        .thumbnail-failed-load {\n            // Necessary for horizontal centering, correct focus outlines, etc.\n            display: block;\n            // Start by fitting height and allowing width to scale with thumbnail aspect ratio.\n            // Aspect ratios wider than 16:9 are handled in JS by Panopto.Util.fitThumbnailWidth().\n            // Once we drop IE8 we can use background-size: contain for a pure CSS solution.\n            width: auto;\n            height: 100%;\n            // Center the thumbnail horizontally within the container if it\'s narrower than 16:9\n            margin: auto;\n            // Prevent image link border in older IE\n            border: none;\n            // Prevent browser default behavior for dragging images to enable session drag from thumb.\n            pointer-events: none;\n        }\n\n        // Show duration in an overlay at the bottom right of the thumbnail\n        .duration {\n            .overlay();\n            .border-radius(1px);\n            bottom: @overlay-margin;\n            right: @overlay-margin;\n            font-size: @font-size-subtitle;\n        }\n\n        .playlist {\n            .overlay();\n            .border-radius(1px);\n            top: 0;\n            right: 0;\n            height: @thumbnail-height;\n            line-height: @thumbnail-height;\n            text-align: center;\n            padding: 0 5px;\n\n            // Give the playlist overlay a bit of default width so shorter languages don\'t look goofy\n            min-width: 40%;\n\n            // This works around issues with our "line-height"-based vertical centering hack when on a page with an\n            // XHTML 1.0 doctype (resulting in "Almost Standards Mode").\n            &::before,\n            &::after {\n                content: \'\';\n                display: inline-block;\n                vertical-align: middle;\n            }\n\n            // Handle vertical centering of text;\n            .playlist-text {\n                @height-adjustment: 10px;\n                display: inline-block;\n                vertical-align: middle;\n                // Adjust the height between the icon and text\n                line-height: @height-adjustment;\n                // Fix the vertical centering of the text\n                margin-top: -@height-adjustment;\n                font-size: @font-size-website-base;\n            }\n        }\n\n        .completion-overlay {\n            position: absolute;\n            bottom: 0;\n            height: 4px;\n            width: 100%;\n            background: @gray-press;\n\n            // Width is set in script in `itemRendered` callbacks in SessionList.ts and HomeUtils.ts.\n            // Color is set to brand color via .accent-background.\n            .progress {\n                height: 100%;\n            }\n        }\n\n        .archived-overlay {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            display: flex;\n            align-items: center;\n            justify-content: space-around;\n            align-content: space-around;\n            // Control opacity through the backgroun so the text is fully opaque.\n            background: rgba(255, 255, 255, 0.8);\n            color: @icon-color;\n            pointer-events: none;\n        }\n    }\n\n    // Mixin for info overlays on .thumbnail-container (white text on translucent black background)\n    .overlay() {\n        position: absolute;\n        // IE8 fallback (doesn\'t support rgba)\n        background: black;\n        background: rgba(0, 0, 0, 0.7);\n        padding: 1px 3px;\n        color: white;\n        cursor: default;\n        // Enable mouse events to pass through to the underlying thumbnail link / span (NOTE: not supported on IE10-)\n        pointer-events: none;\n    }\n}\n\n// Shared caption option styles\n.caption-options(@asset-path, @item-size, @item-padding, @item-border, @docked-icon-size) {\n    .user-select(none);\n\n    li {\n        // override box-sizing: border-box set on fullscreen options\n        box-sizing: content-box;\n        display: block;\n        float: left;\n        margin-left: 5px;\n        width: @item-size;\n        height: @item-size;\n        // Line height needs to consider padding to align with the width\n        line-height: @item-size - (2 * @item-padding);\n        text-align: center;\n        cursor: pointer;\n        padding: @item-padding;\n\n        // Use a transparent border when not selected to avoid reflow on selection\n        border-width: @item-border;\n        border-style: solid;\n        border-color: transparent;\n    }\n\n    // Color samples have a border color to display as well\n    li .color-sample {\n        border-width: 1px;\n        border-style: solid;\n    }\n\n    .transparent-background {\n        .icon(@asset-path, "checker.png");\n        background-position: left top;\n    }\n\n    .placement-option {\n        // Override the default explicit size to the image\n        width: auto;\n        height: auto;\n    }\n\n    // Docked image icon\n    .Docked div {\n        .icon(@asset-path, "icon_position_Docked.png", @docked-icon-size, @docked-icon-size);\n    }\n\n    // Overlay image icon\n    .Overlay div {\n        .icon(@asset-path, "icon_position_Overlay.png", @docked-icon-size, @docked-icon-size);\n    }\n}\n\n.dialog-triangle() {\n    // These are styles to position and scale unicode triangle character for a dialog\n    position: absolute;\n    display: block;\n    color: white;\n    z-index: 1000;\n    margin-left: -10px;\n    margin-top: -11px;\n    font-size: 1.5em;\n    .transform(scaleX(1.5));\n    cursor: default;\n}\n\n// Used to place an opaque overlay on the screen\n.screen-overlay() {\n    display: none;\n    position: fixed;\n    top: 0; left: 0; right: 0; bottom: 0;\n    background-color: black;\n    @opacity: 70;\n    opacity: (@opacity / 100);\n    filter: alpha(opacity=@opacity); // IE8 hack. "opacity" supported in IE9+\n    z-index: 999;\n}\n\n// Used to vertically align material icons nicely beside text\n.material-icon-beside-text() {\n    // Align the material icon with the text\n    vertical-align: middle;\n    // Underlining material design icons doesn\'t render nicely\n    text-decoration: none;\n    // Give the icon a little space from the title\n    padding-right: 3px;\n}\n\n.folder-header-icon(@width, @height, @icon) {\n    .icon(@asset-path, @icon, @width, @height);\n    float: left;\n    margin-right: 10px;\n}\n\n// Used for close buttons that use the "close"/x material icon\n.close-button (@size) {\n    display: block;\n    text-decoration: none;\n    color: @font-color-light;\n    font-size: @size;\n\n    .hoverable(@gray-transparent, @gray-transparent-dark);\n\n    &:active {\n        color: white;\n    }\n}\n\n.speech-bubble() {\n    @padding: 10px;\n    @border-width: 1px;\n    @background-color: white;\n    position: relative;\n    background-color: @background-color;\n    border: @border-width solid @gray-border;\n    border-radius: 3px;\n    border-bottom-left-radius: 0px;\n    padding: @padding;\n\n    &:before {\n        content: "";\n        position: absolute;\n        top: 100%;\n        left: 0px - @border-width;\n        width: 0px;\n        display: block;\n        border-width: 20px 20px 0 0;\n        border-style: solid;\n        border-color: @gray-border transparent;\n    }\n\n    &:after {\n        content: "";\n        position: absolute;\n        top: 100%;\n        left: 0px;\n        width: 0px;\n        display: block;\n        border-width: 17px 17px 0 0;\n        border-style: solid;\n        border-color: @background-color transparent;\n    }\n}\n\n.flat-button() {\n    display: inline-block;\n    padding: 6px 9px 8px 9px;\n    .border-radius(3px);\n    background-color: @header-color;\n    cursor: pointer;\n    text-decoration: none;\n    font-weight: 600;\n    color: @font-color;\n    text-align: center;\n    border: 1px solid @gray-light;\n\n    &.safety-background {\n        color: white;\n        border: 0px;\n        padding: 7px 10px 9px 10px;\n    }\n\n    &:hover, &:active {\n        text-decoration: none;\n    }\n}\n\n.copyright-warning() {\n    font-size: @font-size-small;\n    color: @font-color-light-white-background;\n    text-align: center;\n    padding: 20px;\n}\n\n.material-checkbox(\n    @color: @icon-color,\n    @background: rgba(255, 255, 255, 0.85)\n) {\n    -webkit-appearance: unset;\n    -moz-appearance: none;\n    position: relative;\n    color: @color;\n\n    // Remove border and background color as they still show up on Mobile Safari\n    // even with appearance unset\n    border: none;\n    background-color: transparent;\n\n    &::before {\n        content: "";\n        position: absolute;\n        top: @checkbox-glyph-inset;\n        right: @checkbox-glyph-inset;\n        bottom: @checkbox-glyph-inset;\n        left: @checkbox-glyph-inset;\n        border-radius: 3px;\n        background: @background;\n    }\n\n    &::after {\n        content: "check_box_outline_blank";\n        position: absolute;\n    }\n    &:checked::after {\n        content: "check_box";\n    }\n}\n\n.material-radio(\n    @color: @icon-color,\n    @background: rgba(255, 255, 255, 0.85)\n) {\n    -webkit-appearance: unset;\n    -moz-appearance: none;\n    position: relative;\n    color: @color;\n\n    // Remove border and background color as they still show up on Mobile Safari\n    // even with appearance unset\n    border: none;\n    background-color: transparent;\n\n    &::before {\n        content: "";\n        position: absolute;\n        top: @checkbox-glyph-inset;\n        right: @checkbox-glyph-inset;\n        bottom: @checkbox-glyph-inset;\n        left: @checkbox-glyph-inset;\n        border-radius: 3px;\n        background: @background;\n    }\n\n    &::after {\n        content: "radio_button_unchecked";\n        position: absolute;\n    }\n    &:checked::after {\n        content: "radio_button_checked";\n    }\n}\n\n.placeholder(@rules) {\n    &::placeholder {\n        @rules();\n    }\n}\n\n.material-select() {\n    background: url(data:image/svg+xml;base64,) no-repeat right 2px center;\n    -moz-appearance: none; \n    -webkit-appearance: none; \n    appearance: none;\n}\n\n.clear-search-icon() {\n    @icon-size: 18px;\n    .icon("Widgets/", "icon_cancel.svg", @icon-size, @icon-size, no-repeat);\n    background-size: @icon-size;\n}\n'],sourceRoot:""}]);const s=/^(4044|8193)$/.test(t.j)?a:null},13186(e,n,t){"use strict";t.d(n,{A:()=>s});var o=t(82001),r=t.n(o),i=t(40935),a=t.n(i)()(r());a.push([e.id,'/* Constants / styles used across the product */\n/* Fonts */\n:root {\n  --panopto-font-family: Segoe UI, Helvetica, sans-serif;\n  --panopto-font-family-semibold: Segoe UI Semibold, Helvetica Neue, Segoe UI, Helvetica, sans-serif;\n  --panopto-font-family-light: Segoe UI Light, HelveticaNeue-Light, Segoe UI, Helvetica, sans-serif;\n}\n/* Sizes */\n/* Page gradient */\n/* Opacities of black (for consistent effect over gradient vs. fixed grays) */\n/* Font Colors */\n/* Font Colors (Accessibility) */\n/* New font colors */\n/* "Dark Theme" Colors */\n/* Colors */\n/* For gradient buttons */\n/* Small Thumbnail */\n/* Volume preview specific colors */\n/* Opacities */\n/* Borders */\n/* Input Border Color (WCAG 1.4.11 Accessibility) */\n/* Common measurements */\n/* Images */\n/* Transitions */\n/* Mobile */\n/* Embed */\n/* Material icons */\n/* Resets */\nbody {\n  margin: 0px;\n}\n.clicked {\n  outline: none;\n}\n.break {\n  display: block;\n  height: 15px;\n}\n.clear {\n  clear: both;\n  height: 0px;\n}\n.error {\n  color: #990000 !important;\n}\n.ellipsis {\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n.attention {\n  font-weight: bold;\n}\n.hidden-scrollbar {\n  /* Chrome/Safari/Webkit */\n  scrollbar-width: none;\n  /* Firefox */\n}\n.hidden-scrollbar::-webkit-scrollbar {\n  display: none;\n}\n.div-text-with-link a:link,\n.div-text-with-link a:visited,\n.div-text-with-link a:active {\n  text-decoration: none;\n  color: #0F7395;\n}\n.div-text-with-link a:link:hover,\n.div-text-with-link a:visited:hover,\n.div-text-with-link a:active:hover,\n.div-text-with-link a:link:focus,\n.div-text-with-link a:visited:focus,\n.div-text-with-link a:active:focus {\n  cursor: pointer;\n  text-decoration: underline;\n}\n',"",{version:3,sources:["webpack://./React/Admin/Components/DivTextWithLink.less","webpack://./../../WebCore/css/Assets/Assets.less","webpack://./../../WebCore/css/Assets/Mixins.less"],names:[],mappings:"AAAA,+CAA+C;AAC/C,UAAU;ACcV;EACI,sDAAA;EACA,kGAAA;EACA,iGAAA;ADZJ;AACA,UAAU;AACV,kBAAkB;AAClB,6EAA6E;AAC7E,gBAAgB;AAChB,gCAAgC;AAChC,oBAAoB;AACpB,wBAAwB;AACxB,WAAW;AACX,yBAAyB;AACzB,oBAAoB;AACpB,mCAAmC;AACnC,cAAc;AACd,YAAY;AACZ,mDAAmD;AACnD,wBAAwB;AACxB,WAAW;AACX,gBAAgB;AAChB,WAAW;AACX,UAAU;AACV,mBAAmB;AACnB,WAAW;ACqPX;EACI,WAAA;ADnPJ;ACsPA;EACI,aAAA;ADpPJ;AEwIA;EACI,cAAA;EACA,YAAA;AFtIJ;AEyIA;EACI,WAAA;EACA,WAAA;AFvIJ;AE2QA;EACI,yBAAA;AFzQJ;AE4QA;EACI,mBAAA;EACA,gBAAA;EACA,uBAAA;AF1QJ;AE2RA;EACI,iBAAA;AFzRJ;AEwUA;EFtUE,yBAAyB;EEwUvB,qBAAA;EFtUF,YAAY;AACd;AEoUI;EAAuB,aAAA;AFjU3B;AAtDA;;;EEyVI,qBAAA;EFtVI,cAAA;AAyDR;AE+RI;;;;;;EACI,eAAA;EACA,0BAAA;AFxRR",sourcesContent:['@import "../../../../../WebCore/css/Assets/Assets.less";\n@import "../../../../../WebCore/css/Assets/Mixins.less";\n\n// General.less defines the color for a:link, a:visited, a:active as non-blue.\n// It\'s strange, but Adrian does not know why. We need to override here.\n\n.div-text-with-link {\n    a:link, a:visited, a:active {\n        .link();\n        color: @font-color-link;\n    }\n}','/* Constants / styles used across the product */\n\n/* Fonts */\n@font: Segoe UI, Helvetica, sans-serif;\n@font-semibold: Segoe UI Semibold, Helvetica Neue, Segoe UI, Helvetica, sans-serif;\n@font-light: Segoe UI Light, HelveticaNeue-Light, Segoe UI, Helvetica, sans-serif;\n.font-light() {\n    font-family: var(--panopto-font-family-light);\n    font-weight: 100; // FF doesn\'t include Segoe UI Light, font-weight lighter approximates it.\n}\n.font-semibold() {\n    font-family: var(--panopto-font-family-semibold);\n    font-weight: 600;\n}\n\n:root {\n    --panopto-font-family: @font;\n    --panopto-font-family-semibold: @font-semibold;\n    --panopto-font-family-light: @font-light;\n}\n\n@font-size-base: 16px;\n@font-size-medium: 1.45em;\n@font-size-large: 1.5em;\n@font-size-big-title: 1.7em;\n@font-size-small: .8em;\n@font-size-xsmall: .7em;\n@font-size-extra-large: 2.1em;\n@font-size-huge: 3.0em;\n// Our website uses this as its base\n@font-size-website-base: 13px;\n// These are basic font sizes used by the recorder. We should start making all of these consistent\n@font-size-title: 1.3em;\n@font-size-header: 1.2em;\n@font-size-command-button: 1.1em;\n@font-size-subtitle: .9em;\n@font-size-option: .8em;\n@font-size-button: .7em;\n\n@icon-size-without-text: 24px;\n@icon-size-with-text: 18px;\n\n/* Sizes */\n@site-min-width: 1004px;\n\n@small-logo-max-width: 265px;\n@small-logo-max-height: 23px;\n@large-logo-max-width: 340px;\n@large-logo-max-height: 50px;\n\n// Preferred hit target size for touch interfaces.\n@touch-target-size: 48px;\n// Smaller touch target size for tightly constrained contexts.\n@touch-target-size-small: 40px;\n\n@button-spacing: 10px;\n\n/* Page gradient */\n@page-gradient: linear-gradient(to bottom, #ffffff 0%, #f5f5f5 60%);\n\n/* Opacities of black (for consistent effect over gradient vs. fixed grays) */\n@darken-hovered: rgba(0, 0, 0, 0.03);\n@darken-selected: rgba(0, 0, 0, 0.06);\n@darken-selected-session: rgba(0, 0, 0, 0.05);\n\n/* Font Colors */\n@font-color-primary: #009900;\n@font-color-secondary: #466c2c;\n@font-color-link: #0F7395;\n\n@font-color-error: #990000;\n@font-color-dark: #000000;\n@font-color: #464646;\n@font-color-light: #777777;\n@font-color-lightest: #999999;\n@font-color-light-background: #b8b8b8;\n@font-light-gray: #aaaaaa;\n\n@font-color-black-80pct: rgba(0, 0, 0, 0.8);\n\n/* Font Colors (Accessibility) */\n@font-color-light-white-background: #767676;\n\n/* New font colors */\n@text-color-primary: rgba(0, 0, 0, .9);\n@text-color-secondary: rgba(0, 0, 0, .7);\n@text-color-on-accent: rgba(255, 255, 255);\n@text-color-additional: rgba(0, 0, 0, .6);\n\n@icon-color-primary: rgba(0, 0, 0, .8);\n@icon-color-secondary: rgba(0, 0, 0, .6);\n@icon-color-additional: rgba(0, 0, 0, .5);\n\n@border-color-primary: rgba(0, 0, 0, .1);\n\n@background-hover: rgba(0, 0, 0, .05);\n@background-active: rgba(0, 0, 0, .1);\n\n/* "Dark Theme" Colors */\n@overlay-background-color: rgba(0, 0, 0, 0.8);\n@icon-color-dark-theme: rgba(255, 255, 255, 0.8);\n@icon-color-active-dark-theme: white;\n@tab-highlight-color-dark-theme: rgba(255, 255, 255, 0.8);\n@border-color-dark-theme: rgba(255, 255, 255, 0.2);\n@font-color-dark-theme: rgba(255, 255, 255, 1);\n@font-color-secondary-dark-theme: rgba(255, 255, 255, 0.8);\n@hover-background-color-dark-theme: rgba(255, 255, 255, 0.1);\n@contrast-background-color-dark-theme: rgba(255, 255, 255, 0.2);\n\n/* Colors */\n@blue-selected: #aedcf1;\n\n@white-bright: #e6e6e6;\n@pure-white: #ffffff;\n\n@red: #bd4f4f;\n@red-medium: #a04242;\n@red-dark: #8c3939;\n@red-light: #ebcaca;\n@red-bright: #dd3217;\n\n@green: #54bf6d;\n@green-medium: #1d8f37;\n@green-dark: #185e0d;\n@green-light: #92c88a;\n@green-background: #eef5f0;\n@green-sunny: #719f46;\n@green-shady: #48761d;\n\n// Branded Panopto Green. Do _NOT_ use this for areas that should be affected by branding\n@panopto-green: #30733F;\n\n@icon-color: #626262;\n@header-color: #f5f5f5;\n@header-dropdown-background-color: White;\n@focused-background-color: #e8e8e8;\n@gray-border: #e0e0e0;\n@gray-light: #d6d6d6;\n@gray-hover: #f0f0f0;\n@gray-very-light: #f2f2f2;\n@gray-hint: #f5f5f5;\n@gray-press: #cccccc;\n@gray-dark: #999999;\n@gray-header: #666;\n@gray-shadow: #888;\n@gray-future: #f2f2f2;\n@dark-selected: #8b8b8b;\n@gray-divider: #989898;\n@light-selected: #dbdbdb;\n@gray-silver: #e7e7e7;\n@gray-disabled: #ebebe4;\n@gray-button-hover: #e5e5e5;\n@gray-transparent: rgba(0,0,0,0.2);\n@gray-transparent-subtle: rgba(0,0,0,0.1);\n@gray-transparent-light: rgba(0,0,0,0.3);\n@gray-transparent-medium: rgba(0,0,0,0.5);\n@gray-transparent-dark: rgba(0,0,0,0.6);\n@gray-dark-shadow: rgba(0,0,0,0.7);\n@gray-darker-shadow: rgba(0,0,0,0.8);\n@gray-watermark: gray;\n@letterbox-color: black;\n@rr-letterbox-color: #3f3f3f;\n@material-box-shadow: 0 6px 10px 0 rgba(0,0,0,.14),\n                      0 1px 18px 0 rgba(0,0,0,.12),\n                      0 3px 5px -1px rgba(0,0,0,.20);\n\n@background-warning: orange;\n\n@yellow: #feffc9;\n\n@stored-quota-foreground: #B56F90;\n@stored-quota-background: #B56F90;\n@delivered-quota-foreground: #4798D0;\n@delivered-quota-background: #4798D0;\n\n@drop-target-background: rgba(231, 239, 254, 0.5);\n@drop-target-background-invalid: fadeout(white, 20%);\n@drop-target-border: fadeout(#4384f4, 57%);\n\n/* For gradient buttons */\n\n/* Small Thumbnail */\n@small-thumbnail-cell-width: 120px;\n@small-thumbnail-height: 60px;\n@small-thumbnail-width: (16 / 9) * @small-thumbnail-height;\n\n/* Volume preview specific colors */\n@neutral-color: #0098cc;\n@loud-color: #9d0b0b;\n@quiet-color: #ffa900;\n@neutral-text-color: #019acd;\n@loud-text-color: #8a1d1d;\n@quiet-text-color: #d08e0b;\n@loud-warning-color: #cf8787;\n@quiet-warning-color: #ffd57f;\n@loud-border: #7fcce6;\n\n/* Opacities */\n@button-opacity: .6;\n@button-hover-opacity: .8;\n@button-active-opacity: 1.0;\n@button-disabled: .3;\n\n/* Borders */\n@input-border-edit: 1px solid #959595;\n@input-border-hover: 1px solid #cdcdcd;\n@input-border-white: 1px solid White;\n@header-dropdown-border: 1px solid #cccccc;\n@input-border-light: 1px solid #cccccc;\n@input-border-extra-light: 1px solid @gray-border;\n/* Input Border Color (WCAG 1.4.11 Accessibility) */\n@input-border-color: #8C8C8C;\n\n/* Common measurements */\n\n// The height of most of our modal inputs\n@input-height: 28px;\n\n/* Images */\n@spinner-path: "Spinner/";\n@spinner-large: "large-comet-animation-grey.gif";\n@spinner-small-white: "spinner_small_white.gif";\n@spinner-small-beige: "spinner_small_eee.gif";\n\n@spinner-large-themable: "spinner_large_themable.png";\n@spinner-small-white-themable: "spinner_small_themable_white.png";\n@spinner-small-beige-themable: "spinner_small_themable_eee.png";\n@spinner-small-gray-themable: "spinner_small_themable_e0e0e0.png";\n\n/* Transitions */\n@viewer-transition: all .125s ease-in-out;\n\n/* Mobile */\n\n// Google recommends a base of 16px\n// https://developers.google.com/speed/docs/insights/UseLegibleFontSizes?hl=en\n@mobile-base-size: 16px;\n\n// Maybe we want to change this to a hex code later\n// so for now use yellow and we can change it easier\n@mobile-font-warning: yellow;\n@mobile-background-disabled: rgb(187, 187, 187);\n\n// Mobile query constants\n\n// "almost" is one less then actual width,\n// "almost" queries should be used for max-width \n// actual queries should be used for min-width\n// By keeping those consistent we can be sure that the layout\n// doesn\'t do funky things on the pixel between the two\n// and we won\'t need to consider which media query comes first\n// NOTE: The parens around the following bits are necessary, LESS generates invalid CSS without them.\n@ipad4-portrait-width: 320px;\n@iphone5-landscape-width: 568px;\n@iphone6-portrait-width: 375px;\n\n@almost-iphone6-portrait-width: (@iphone6-portrait-width - 1);\n\n@ipad-mini-portrait-width: 768px;\n@almost-ipad-mini-portrait-width: (@ipad-mini-portrait-width - 1);\n\n@nexus7-landscape-width: 960px;\n@almost-nexus7-landscape-width: (@nexus7-landscape-width - 1);\n\n/* Embed */\n@defaultEmbedWidth: 720px;\n@defaultEmbedHeight: 405px;\n\n/* Material icons */\n@checkbox-glyph-inset: 3px;\n\n/* Resets */\nbody {\n    margin: 0px;\n}\n\n.clicked {\n    outline: none;\n}\n','@small-loading-indicator-length: 16px;\n\n.border-radius (@radius) {\n    -webkit-border-radius: @radius;\n    -moz-border-radius: @radius;\n    border-radius: @radius;\n}\n\n.box-sizing (@sizing) {\n    box-sizing: @sizing;\n    -moz-box-sizing: @sizing;\n}\n\n// Prevents anti aliasing\n// http://stackoverflow.com/questions/14068103/disable-antialising-when-scaling-images\n.prevent-anti-aliasing () {\n    // The browser will ignore the lines it can\'t understand\n    // and so it works to have the same property listed multiple times\n    image-rendering: optimizeSpeed;\n    image-rendering: -moz-crisp-edges;\n    image-rendering: -o-crisp-edges;\n    image-rendering: -webkit-optimize-contrast;\n    image-rendering: pixelated;\n    image-rendering: optimize-contrast;\n}\n\n.user-select(@select) {\n    -webkit-touch-callout: @select;\n    -webkit-user-select: @select;\n    -khtml-user-select: @select;\n    -moz-user-select: @select;\n    user-select: @select;\n}\n\n.background-image-gradient (@deg, @color-bottom, @color-top) {\n    background-image: -webkit-linear-gradient(@deg, @color-bottom 0%, @color-top 100%);\n    background-image: -moz-linear-gradient(@deg, @color-bottom 0%, @color-top 100%);\n}\n\n.background-complex-gradient (@deg, @color-first, @color-second, @color-third, @color-fourth) {\n    background-image: -webkit-linear-gradient(@deg, @color-first, @color-second, @color-third, @color-fourth);\n    background-image: -moz-linear-gradient(@deg, @color-first, @color-second, @color-third, @color-fourth);\n}\n\n// Block-level elements with known dimensions can be centered within positioned parents.\n.center-block(@width, @height, @h-offset: 0, @v-offset: 0) {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    // Block origin is centered by the above, shift by half height / width to align block center with container center.\n    margin-left: -(@width / 2) + @h-offset;\n    margin-top: -(@height / 2) + @v-offset;\n    width: @width;\n    height: @height;\n}\n\n.clickable () {\n    &:hover {\n        cursor: pointer;\n    }\n}\n\n.access-icons(@length) {\n    .access-item-icon(@image) {\n        .icon("Share/", @image, @length, @length);\n    }\n\n    &.invite {\n        .access-item-icon("icon_email.png");\n    }\n\n    &.group {\n        .access-item-icon("icon_group.png");\n    }\n\n    &.user {\n        .access-item-icon("icon_user.png");\n    }\n}\n\n.pressable (@background-highlight, @background-pressed, @cursor: default) {\n    &:hover {\n        background-color: @background-highlight;\n        cursor: @cursor;\n    }\n    &:focus {\n        background-color: @background-highlight;\n    }\n    &:active {\n        background-color: @background-pressed;\n    }\n}\n\n.hoverable (@background-highlight, @background-pressed, @cursor: default) {\n    .transition(background-color .15s);\n    &:hover {\n        background-color: @background-highlight;\n        cursor: @cursor;\n        .transition(background-color .15s);\n    }\n    &:active {\n        background-color: @background-pressed;\n        .transition(background-color .15s);\n    }\n}\n\n// @child-class-string needs to the the class selector without the \'.\', LESS allows us to pass strings but not complete selectors\n// http://stackoverflow.com/questions/19602812/less-mixin-a-variable-class-name\n.hoverable-child (@child-class-string, @background-parent-highlight, @background-child-highlight, @background-pressed, @cursor: default) {\n    &:hover .@{child-class-string} {\n        background-color: @background-parent-highlight;\n        .transition(background-color .15s);\n    }\n    .@{child-class-string} {\n        .hoverable(@background-child-highlight, @background-pressed, @cursor);\n    }\n}\n\n.hoverable-opacity() {\n    opacity: @button-opacity;\n\n    &:hover, &:focus {\n        opacity: @button-hover-opacity;\n    }\n\n    &:active {\n        opacity: @button-active-opacity;\n    }\n}\n\n.background-image(@root, @image, @repeat: no-repeat, @align: center) {\n    background-image: ~"url(\'@{image-path}@{root}@{image}\')";\n    background-repeat: @repeat;\n    background-position: @align;\n}\n\n.icon (@root, @image, @width: auto, @height: auto, @repeat: no-repeat, @align: center) {\n    .background-image(@root, @image, @repeat, @align);\n    width: @width;\n    height: @height;\n}\n\n.transition(@params) {\n    -webkit-transition: @params;\n    -moz-transition: @params;\n    -o-transition: @params;\n    transition: @params;\n}\n\n.transform(@params) {\n    transform: @params;\n    -webkit-transform: @params;\n}\n\n.pressable-icon(@root, @image, @image-hover, @image-press, @width: auto, @height: auto, @repeat: no-repeat, @align: center) {\n    .icon(@root, @image, @width, @height, @repeat, @align);\n\n    &:hover {\n        .icon(@root, @image-hover, @width, @height, @repeat, @align);\n        cursor: default;\n    }\n    &:focus {\n        .icon(@root, @image-hover, @width, @height, @repeat, @align);\n    }\n    &:active {\n        .icon(@root, @image-press, @width, @height, @repeat, @align);\n    }\n}\n\n.break {\n    display: block;\n    height:  15px;\n}\n\n.clear {\n    clear: both;\n    height: 0px;\n}\n\n.box-shadow(none) {\n    -webkit-box-shadow: none;\n    -moz-box-shadow: none;\n    box-shadow: none;\n}\n\n.box-shadow(@color, @h-shadow, @v-shadow, @blur, @spread) {\n    -webkit-box-shadow: @color @h-shadow @v-shadow @blur @spread;\n    -moz-box-shadow: @color @h-shadow @v-shadow @blur @spread;\n    box-shadow: @color @h-shadow @v-shadow @blur @spread;\n}\n\n.box-shadow-inset(@color, @h-shadow, @v-shadow, @blur, @spread) {\n    -webkit-box-shadow: @color @h-shadow @v-shadow @blur @spread inset;\n    -moz-box-shadow: @color @h-shadow @v-shadow @blur @spread inset;\n    box-shadow: @color @h-shadow @v-shadow @blur @spread inset;\n}\n\n.borders(@top-color, @right-color, @bottom-color, @left-color) {\n    border-top:1px solid @top-color;\n    border-right: 1px solid @right-color;\n    border-bottom:1px solid @bottom-color;\n    border-left:1px solid @left-color;\n}\n\n.rotating-animation() {\n    // IE and FF support the w3 standard keyframes\n    @keyframes rotate {\n        0% {\n            transform: rotate(0deg);\n        }\n        100% {\n            transform: rotate(360deg);\n        }\n    }\n\n    // Chrome and Safari need special webkit\n    @-webkit-keyframes rotate {\n        0% {\n            -webkit-transform: rotate(0deg);\n        }\n        100% {\n            -webkit-transform: rotate(360deg);\n        }\n    }\n\n    animation: rotate 2s linear infinite;\n    -webkit-animation: rotate 2s linear infinite;\n}\n\n.color-holder(@diameter) {\n    position: absolute;\n    .border-radius(50%); // Circle\n    width: @diameter;\n    height: @diameter;\n}\n\n.indicator-border(@border-size, @color){\n    left: -@border-size;\n    top: -@border-size;\n    border: @border-size solid @color;\n}\n\n.small-loading-indicator(@image-grey, @image-themed, @border-color) {\n    @small-length: @small-loading-indicator-length;\n    width: @small-length;\n    height: @small-length;\n    overflow: hidden;\n\n    .branding-color-holders {\n        display: block;\n       .color-holder(15px);\n    }\n\n    .loading-indicator {\n        position: relative;\n        .icon(@spinner-path, @image-grey, @small-length, @small-length);\n        .indicator-border(10px, @border-color);\n\n        &.branded-animation {\n            // The "- 1" fixes a samll issue in Chrome where the when zoomed to 90% you could see a second spinner\n            .icon(@spinner-path, @image-themed, @small-length - 1, @small-length - 1);\n            .rotating-animation();\n        }\n    }\n}\n\n.opacity(@opacity) {\n    opacity: @opacity;\n    @percent: @opacity * 100;\n    // IE8 and below\n    filter: alpha(opacity=@percent);\n}\n\n.horizontal-rule(@color) {\n    display: block;\n    border-bottom: 1px solid @color;\n}\n\n.popup(@z-index) {\n    z-index: @z-index;\n    .box-shadow(@gray-dark, 2px, 3px, 5px, 0);\n    border: @header-dropdown-border;\n    background-color: @header-dropdown-background-color;\n    position: absolute;\n    text-align: left;\n\n    .popup-title {\n        color: @font-color;\n        font-weight: bold;\n    }\n}\n\n.header-dropdown() {\n    .popup(100003);\n\n    > a, > div {\n        &:hover {\n            background-color: @gray-hover;\n            cursor: default;\n        }\n        &:active {\n            background-color: @gray-press;\n        }\n        text-decoration: none;\n        display: block;\n    }\n}\n\n.error {\n    color: @font-color-error !important;\n}\n\n.ellipsis {\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n}\n\n// @lines is honored on WebKit.\n// @max-height provides a fallback on other browsers (simple vertical truncation).\n.multiline-ellipsis (@lines, @max-height) {\n    // On WebKit, show ellipsis after two lines if text is longer.\n    display: -webkit-box;\n    -webkit-line-clamp: @lines;\n    -webkit-box-orient: vertical;\n    // For non-WebKit browsers, just crop lines beyond the second (no ellipsis).\n    max-height: @max-height;\n    overflow: hidden;\n    // Override "nowrap" behavior of .ellipsis (typically also present for tooltips) to enable wrapping to additional lines.\n    white-space: normal;\n}\n\n.attention {\n    font-weight: bold;\n}\n\n\n// Styles a div as a table row, with direct div children as cells\n.table-row (@width: 100%, @align: top) {\n    display: table;\n    width: @width;\n\n    > div, > a, > img, > i {\n        display: table-cell;\n        vertical-align: @align;\n    }\n}\n\n// Styles any element to look and behavior like a link\n.link (@cursor: pointer, @color: @font-color-link) {\n    color: @color;\n    text-decoration: none;\n\n    &:hover, &:focus {\n        cursor: @cursor;\n        text-decoration: underline;\n    }\n}\n\n// Creates a thin, two-tone scrollbar (plain thumb on plain track), where supported by the browser.\n// Width is 8px on Webkit, "thin" on FF (works out to similar), and full width on other browsers.\n// Webkit thumb will have a 5px border-radius (others will have square edges).\n.custom-scrollbar(@thumb-color, @track-color) {\n    @supports not selector(::-webkit-scrollbar) {\n        scrollbar-width: thin;\n        scrollbar-color: @thumb-color @track-color;\n    }\n\n    &::-webkit-scrollbar {\n        background-color: @track-color;\n        width: 8px;\n        height: 8px;\n    }\n\n    &::-webkit-scrollbar-thumb {\n        background-color: @thumb-color;\n        border-radius: 5px;\n    }\n}\n\n.hidden-scrollbar {\n    &::-webkit-scrollbar { display: none; } /* Chrome/Safari/Webkit */\n    scrollbar-width: none; /* Firefox */\n}\n\n.edit-control() {\n    padding: 2px;\n    bottom: 0px;\n    right: 0px;\n    z-index: 1;\n    background-color: white;\n\n    > div {\n        .link;\n        display: inline-block;\n        padding: 3px 8px 4px 8px;\n        border: 1px solid @gray-press;\n        background-color: white;\n    }\n}\n\n.viewer-message() {\n    margin: 20px auto 0px auto;\n    text-align: center;\n    // This is the size used in Viewer.less\n    // repeated here to make this consistent between pages\n    font-size: medium;\n\n    #messageText {\n        padding: 10px;\n    }\n\n    #messageLink {\n        padding: 0px 10px 10px 10px;\n    }\n}\n\n.role-select(@width, @margin-top) {\n    font-family: @font;\n    width: @width;\n    height: 38px;\n    margin-top: @margin-top;\n    padding: 6px;\n    font-size: @font-size-base;\n    .border-radius(4px);\n    color: @font-color-light;\n    display: block;\n    vertical-align: top;\n}\n\n// Shared thumbnail styles\n.thumbnail(@thumbnail-width-param: 196px, @thumbnail-height-param: 110px) {\n    // This is necessary to surface these params in the enclosing scope of the mixin.\n    @thumbnail-width: @thumbnail-width-param;\n    @thumbnail-height: @thumbnail-height-param;\n    @thumbnail-border: 1px;\n    @overlay-margin: 2px;\n\n    .thumbnail-container {\n        // Provide a positioning context for thumbnail overlays\n        position: relative;\n        width: @thumbnail-width;\n        height: @thumbnail-height;\n        border: @thumbnail-border solid @gray-border;\n        .border-radius(3px);\n        background: black;\n        // Prevent child image from bleeding out of the rounded corners\n        overflow: hidden;\n\n        // Give linked thumbnails a darkened border on hover\n        &.viewable:hover {\n            border: @thumbnail-border solid @gray-dark;\n        }\n\n        // Show link or span depending on "viewable" class on container\n        .thumbnail-span,\n        &.viewable .thumbnail-link {\n            display: block;\n        }\n        .thumbnail-link,\n        &.viewable .thumbnail-span {\n            display: none;\n        }\n\n        // Needed to enable "height/width: 100%" to work on ".thumbnail-img/-failed-load" below\n        .thumbnail-link,\n        .thumbnail-span {\n            width: 100%;\n            height: 100%;\n        }\n\n        .thumbnail-img,\n        .thumbnail-failed-load {\n            // Necessary for horizontal centering, correct focus outlines, etc.\n            display: block;\n            // Start by fitting height and allowing width to scale with thumbnail aspect ratio.\n            // Aspect ratios wider than 16:9 are handled in JS by Panopto.Util.fitThumbnailWidth().\n            // Once we drop IE8 we can use background-size: contain for a pure CSS solution.\n            width: auto;\n            height: 100%;\n            // Center the thumbnail horizontally within the container if it\'s narrower than 16:9\n            margin: auto;\n            // Prevent image link border in older IE\n            border: none;\n            // Prevent browser default behavior for dragging images to enable session drag from thumb.\n            pointer-events: none;\n        }\n\n        // Show duration in an overlay at the bottom right of the thumbnail\n        .duration {\n            .overlay();\n            .border-radius(1px);\n            bottom: @overlay-margin;\n            right: @overlay-margin;\n            font-size: @font-size-subtitle;\n        }\n\n        .playlist {\n            .overlay();\n            .border-radius(1px);\n            top: 0;\n            right: 0;\n            height: @thumbnail-height;\n            line-height: @thumbnail-height;\n            text-align: center;\n            padding: 0 5px;\n\n            // Give the playlist overlay a bit of default width so shorter languages don\'t look goofy\n            min-width: 40%;\n\n            // This works around issues with our "line-height"-based vertical centering hack when on a page with an\n            // XHTML 1.0 doctype (resulting in "Almost Standards Mode").\n            &::before,\n            &::after {\n                content: \'\';\n                display: inline-block;\n                vertical-align: middle;\n            }\n\n            // Handle vertical centering of text;\n            .playlist-text {\n                @height-adjustment: 10px;\n                display: inline-block;\n                vertical-align: middle;\n                // Adjust the height between the icon and text\n                line-height: @height-adjustment;\n                // Fix the vertical centering of the text\n                margin-top: -@height-adjustment;\n                font-size: @font-size-website-base;\n            }\n        }\n\n        .completion-overlay {\n            position: absolute;\n            bottom: 0;\n            height: 4px;\n            width: 100%;\n            background: @gray-press;\n\n            // Width is set in script in `itemRendered` callbacks in SessionList.ts and HomeUtils.ts.\n            // Color is set to brand color via .accent-background.\n            .progress {\n                height: 100%;\n            }\n        }\n\n        .archived-overlay {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            display: flex;\n            align-items: center;\n            justify-content: space-around;\n            align-content: space-around;\n            // Control opacity through the backgroun so the text is fully opaque.\n            background: rgba(255, 255, 255, 0.8);\n            color: @icon-color;\n            pointer-events: none;\n        }\n    }\n\n    // Mixin for info overlays on .thumbnail-container (white text on translucent black background)\n    .overlay() {\n        position: absolute;\n        // IE8 fallback (doesn\'t support rgba)\n        background: black;\n        background: rgba(0, 0, 0, 0.7);\n        padding: 1px 3px;\n        color: white;\n        cursor: default;\n        // Enable mouse events to pass through to the underlying thumbnail link / span (NOTE: not supported on IE10-)\n        pointer-events: none;\n    }\n}\n\n// Shared caption option styles\n.caption-options(@asset-path, @item-size, @item-padding, @item-border, @docked-icon-size) {\n    .user-select(none);\n\n    li {\n        // override box-sizing: border-box set on fullscreen options\n        box-sizing: content-box;\n        display: block;\n        float: left;\n        margin-left: 5px;\n        width: @item-size;\n        height: @item-size;\n        // Line height needs to consider padding to align with the width\n        line-height: @item-size - (2 * @item-padding);\n        text-align: center;\n        cursor: pointer;\n        padding: @item-padding;\n\n        // Use a transparent border when not selected to avoid reflow on selection\n        border-width: @item-border;\n        border-style: solid;\n        border-color: transparent;\n    }\n\n    // Color samples have a border color to display as well\n    li .color-sample {\n        border-width: 1px;\n        border-style: solid;\n    }\n\n    .transparent-background {\n        .icon(@asset-path, "checker.png");\n        background-position: left top;\n    }\n\n    .placement-option {\n        // Override the default explicit size to the image\n        width: auto;\n        height: auto;\n    }\n\n    // Docked image icon\n    .Docked div {\n        .icon(@asset-path, "icon_position_Docked.png", @docked-icon-size, @docked-icon-size);\n    }\n\n    // Overlay image icon\n    .Overlay div {\n        .icon(@asset-path, "icon_position_Overlay.png", @docked-icon-size, @docked-icon-size);\n    }\n}\n\n.dialog-triangle() {\n    // These are styles to position and scale unicode triangle character for a dialog\n    position: absolute;\n    display: block;\n    color: white;\n    z-index: 1000;\n    margin-left: -10px;\n    margin-top: -11px;\n    font-size: 1.5em;\n    .transform(scaleX(1.5));\n    cursor: default;\n}\n\n// Used to place an opaque overlay on the screen\n.screen-overlay() {\n    display: none;\n    position: fixed;\n    top: 0; left: 0; right: 0; bottom: 0;\n    background-color: black;\n    @opacity: 70;\n    opacity: (@opacity / 100);\n    filter: alpha(opacity=@opacity); // IE8 hack. "opacity" supported in IE9+\n    z-index: 999;\n}\n\n// Used to vertically align material icons nicely beside text\n.material-icon-beside-text() {\n    // Align the material icon with the text\n    vertical-align: middle;\n    // Underlining material design icons doesn\'t render nicely\n    text-decoration: none;\n    // Give the icon a little space from the title\n    padding-right: 3px;\n}\n\n.folder-header-icon(@width, @height, @icon) {\n    .icon(@asset-path, @icon, @width, @height);\n    float: left;\n    margin-right: 10px;\n}\n\n// Used for close buttons that use the "close"/x material icon\n.close-button (@size) {\n    display: block;\n    text-decoration: none;\n    color: @font-color-light;\n    font-size: @size;\n\n    .hoverable(@gray-transparent, @gray-transparent-dark);\n\n    &:active {\n        color: white;\n    }\n}\n\n.speech-bubble() {\n    @padding: 10px;\n    @border-width: 1px;\n    @background-color: white;\n    position: relative;\n    background-color: @background-color;\n    border: @border-width solid @gray-border;\n    border-radius: 3px;\n    border-bottom-left-radius: 0px;\n    padding: @padding;\n\n    &:before {\n        content: "";\n        position: absolute;\n        top: 100%;\n        left: 0px - @border-width;\n        width: 0px;\n        display: block;\n        border-width: 20px 20px 0 0;\n        border-style: solid;\n        border-color: @gray-border transparent;\n    }\n\n    &:after {\n        content: "";\n        position: absolute;\n        top: 100%;\n        left: 0px;\n        width: 0px;\n        display: block;\n        border-width: 17px 17px 0 0;\n        border-style: solid;\n        border-color: @background-color transparent;\n    }\n}\n\n.flat-button() {\n    display: inline-block;\n    padding: 6px 9px 8px 9px;\n    .border-radius(3px);\n    background-color: @header-color;\n    cursor: pointer;\n    text-decoration: none;\n    font-weight: 600;\n    color: @font-color;\n    text-align: center;\n    border: 1px solid @gray-light;\n\n    &.safety-background {\n        color: white;\n        border: 0px;\n        padding: 7px 10px 9px 10px;\n    }\n\n    &:hover, &:active {\n        text-decoration: none;\n    }\n}\n\n.copyright-warning() {\n    font-size: @font-size-small;\n    color: @font-color-light-white-background;\n    text-align: center;\n    padding: 20px;\n}\n\n.material-checkbox(\n    @color: @icon-color,\n    @background: rgba(255, 255, 255, 0.85)\n) {\n    -webkit-appearance: unset;\n    -moz-appearance: none;\n    position: relative;\n    color: @color;\n\n    // Remove border and background color as they still show up on Mobile Safari\n    // even with appearance unset\n    border: none;\n    background-color: transparent;\n\n    &::before {\n        content: "";\n        position: absolute;\n        top: @checkbox-glyph-inset;\n        right: @checkbox-glyph-inset;\n        bottom: @checkbox-glyph-inset;\n        left: @checkbox-glyph-inset;\n        border-radius: 3px;\n        background: @background;\n    }\n\n    &::after {\n        content: "check_box_outline_blank";\n        position: absolute;\n    }\n    &:checked::after {\n        content: "check_box";\n    }\n}\n\n.material-radio(\n    @color: @icon-color,\n    @background: rgba(255, 255, 255, 0.85)\n) {\n    -webkit-appearance: unset;\n    -moz-appearance: none;\n    position: relative;\n    color: @color;\n\n    // Remove border and background color as they still show up on Mobile Safari\n    // even with appearance unset\n    border: none;\n    background-color: transparent;\n\n    &::before {\n        content: "";\n        position: absolute;\n        top: @checkbox-glyph-inset;\n        right: @checkbox-glyph-inset;\n        bottom: @checkbox-glyph-inset;\n        left: @checkbox-glyph-inset;\n        border-radius: 3px;\n        background: @background;\n    }\n\n    &::after {\n        content: "radio_button_unchecked";\n        position: absolute;\n    }\n    &:checked::after {\n        content: "radio_button_checked";\n    }\n}\n\n.placeholder(@rules) {\n    &::placeholder {\n        @rules();\n    }\n}\n\n.material-select() {\n    background: url(data:image/svg+xml;base64,) no-repeat right 2px center;\n    -moz-appearance: none; \n    -webkit-appearance: none; \n    appearance: none;\n}\n\n.clear-search-icon() {\n    @icon-size: 18px;\n    .icon("Widgets/", "icon_cancel.svg", @icon-size, @icon-size, no-repeat);\n    background-size: @icon-size;\n}\n'],sourceRoot:""}]);const s=/^(103|3422|4044|6040|8193)$/.test(t.j)?a:null},83161(e,n,t){"use strict";t.d(n,{A:()=>s});var o=t(82001),r=t.n(o),i=t(40935),a=t.n(i)()(r());a.push([e.id,"/* Constants / styles used across the product */\n/* Fonts */\n:root {\n  --panopto-font-family: Segoe UI, Helvetica, sans-serif;\n  --panopto-font-family-semibold: Segoe UI Semibold, Helvetica Neue, Segoe UI, Helvetica, sans-serif;\n  --panopto-font-family-light: Segoe UI Light, HelveticaNeue-Light, Segoe UI, Helvetica, sans-serif;\n}\n/* Sizes */\n/* Page gradient */\n/* Opacities of black (for consistent effect over gradient vs. fixed grays) */\n/* Font Colors */\n/* Font Colors (Accessibility) */\n/* New font colors */\n/* \"Dark Theme\" Colors */\n/* Colors */\n/* For gradient buttons */\n/* Small Thumbnail */\n/* Volume preview specific colors */\n/* Opacities */\n/* Borders */\n/* Input Border Color (WCAG 1.4.11 Accessibility) */\n/* Common measurements */\n/* Images */\n/* Transitions */\n/* Mobile */\n/* Embed */\n/* Material icons */\n/* Resets */\nbody {\n  margin: 0px;\n}\n.clicked {\n  outline: none;\n}\n.break {\n  display: block;\n  height: 15px;\n}\n.clear {\n  clear: both;\n  height: 0px;\n}\n.error {\n  color: #990000 !important;\n}\n.ellipsis {\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n.attention {\n  font-weight: bold;\n}\n.hidden-scrollbar {\n  /* Chrome/Safari/Webkit */\n  scrollbar-width: none;\n  /* Firefox */\n}\n.hidden-scrollbar::-webkit-scrollbar {\n  display: none;\n}\n.meeting-integration-admin .property-page-header {\n  display: flex;\n}\n.meeting-integration-admin .property-page-header select {\n  margin-left: auto;\n  margin-right: 3px;\n  max-width: 383px;\n}\n.meeting-integration-admin .property-page-header .property-page-save-status {\n  display: none;\n}\n.meeting-user-email {\n  padding-top: 15px;\n}\ndiv.property-page-property.meeting-user-email > div.property-page-property-name.meeting-user-email-heading {\n  width: auto;\n}\n.zoom-on-premise-info {\n  margin-bottom: 20px;\n}\n.zoom-on-premise-info .error {\n  font-size: 0.8em;\n}\n.meeting-admin-settings {\n  margin-bottom: 15px;\n}\n.meeting-admin-settings .error {\n  font-size: 0.8em;\n}\n.meeting-admin-settings .property-page-property-value {\n  color: #464646;\n}\n.meeting-admin-settings .property-page-property-value .folder-picker-wrapper {\n  position: relative;\n}\n.meeting-admin-settings .property-page-property-value .folder-picker-wrapper .dropdown-list {\n  margin-bottom: 35px;\n}\n.meeting-admin-settings .property-page-property-value .property-page-property-value-instructions {\n  color: #777777;\n  font-size: 0.8em;\n  margin-bottom: 10px;\n}\n.meeting-admin-settings .property-page-property-value .property-page-property-value-note {\n  margin-top: 10px;\n}\n.meeting-admin-settings .property-page-property-value .meeting-admin-allowed-group {\n  margin-top: 5px;\n  margin-left: 19px;\n}\n.meeting-admin-settings .property-page-property-value .meeting-admin-allowed-all-users {\n  margin-top: 5px;\n  margin-left: 19px;\n}\n.meeting-admin-settings .property-page-property-value .meeting-admin-instructions {\n  color: #777777;\n  font-size: 0.8em;\n  margin-top: 5px;\n}\n.meeting-admin-settings .property-page-property-value .warning {\n  color: #a04242;\n  font-size: 0.8em;\n}\n.meeting-admin-settings .property-page-property-value textarea {\n  width: 380px;\n}\n.meeting-admin-settings .property-page-property-value textarea.single-line {\n  resize: none;\n}\n.meeting-admin-settings .property-page-property-value select {\n  width: 380px;\n}\n.meeting-admin-settings .property-page-property-value .tagit-new.initial-state ::placeholder {\n  color: gray;\n}\n.meeting-admin-settings .property-page-property-name.meeting-admin-property-name-multiline {\n  /* Make sure the name column isn't vertically centered on multiline properties*/\n  vertical-align: top;\n}\n.meeting-admin-settings .admin-add-cancel {\n  padding-top: 20px;\n  padding-bottom: 20px;\n}\n.meeting-admin-settings .admin-add-cancel .standard-button {\n  margin-right: 8px;\n}\n.meeting-admin-settings.disabled {\n  opacity: 0.5;\n  cursor: default;\n}\n.meeting-admin-settings input[type='radio'],\n.meeting-admin-settings input[type='checkbox'] {\n  margin-right: 5px;\n}\n.meeting-admin-link-button {\n  color: #0F7395;\n  text-decoration: none;\n  display: inline-block;\n  margin-left: 10px;\n  margin-right: 10px;\n}\n.meeting-admin-link-button:hover,\n.meeting-admin-link-button:focus {\n  cursor: pointer;\n  text-decoration: underline;\n}\n.meeting-admin-link-button .align-button-top {\n  vertical-align: top;\n}\n.meeting-admin-action-buttons {\n  margin-top: 10px;\n}\n.meeting-admin-action-buttons .meeting-admin-link-button {\n  margin-left: 0px;\n  margin-right: 10px;\n}\n.meeting-admin-sso-action-buttons {\n  margin-left: 150px;\n}\n.meeting-admin-sso-action-buttons .meeting-admin-link-button {\n  margin-left: 0px;\n  margin-right: 10px;\n}\n.meeting-admin-log-textarea {\n  font-family: monospace;\n  width: 100%;\n  min-width: 400px;\n  min-height: 400px;\n  height: 60vh;\n  border: 0px;\n  outline: none;\n  overflow-y: auto;\n  resize: none;\n  font-size: initial;\n}\n.continued-section {\n  margin-top: -20px;\n}\n.meeting-admin-settings-radio-option {\n  margin-top: 5px;\n}\n.meeting-admin-settings-radio-option span.meeting-admin-setting-disabled {\n  color: #ebebe4;\n}\n","",{version:3,sources:["webpack://./React/Admin/MeetingIntegrationAdmin.less","webpack://./../../WebCore/css/Assets/Assets.less","webpack://./../../WebCore/css/Assets/Mixins.less"],names:[],mappings:"AAAA,+CAA+C;AAC/C,UAAU;ACcV;EACI,sDAAA;EACA,kGAAA;EACA,iGAAA;ADZJ;AACA,UAAU;AACV,kBAAkB;AAClB,6EAA6E;AAC7E,gBAAgB;AAChB,gCAAgC;AAChC,oBAAoB;AACpB,wBAAwB;AACxB,WAAW;AACX,yBAAyB;AACzB,oBAAoB;AACpB,mCAAmC;AACnC,cAAc;AACd,YAAY;AACZ,mDAAmD;AACnD,wBAAwB;AACxB,WAAW;AACX,gBAAgB;AAChB,WAAW;AACX,UAAU;AACV,mBAAmB;AACnB,WAAW;ACqPX;EACI,WAAA;ADnPJ;ACsPA;EACI,aAAA;ADpPJ;AEwIA;EACI,cAAA;EACA,YAAA;AFtIJ;AEyIA;EACI,WAAA;EACA,WAAA;AFvIJ;AE2QA;EACI,yBAAA;AFzQJ;AE4QA;EACI,mBAAA;EACA,gBAAA;EACA,uBAAA;AF1QJ;AE2RA;EACI,iBAAA;AFzRJ;AEwUA;EFtUE,yBAAyB;EEwUvB,qBAAA;EFtUF,YAAY;AACd;AEoUI;EAAuB,aAAA;AFjU3B;AAxDA;EACI,aAAA;AA0DJ;AA3DA;EAIQ,iBAAA;EACA,iBAAA;EACA,gBAAA;AA0DR;AAhEA;EAUQ,aAAA;AAyDR;AArDA;EACI,iBAAA;AAuDJ;AAnDA;EACI,WAAA;AAqDJ;AAlDA;EACI,mBAAA;AAoDJ;AArDA;EAIQ,gBAAA;AAoDR;AAhDA;EACI,mBAAA;AAkDJ;AAnDA;EAIQ,gBAAA;AAkDR;AAtDA;EAQQ,cAAA;AAiDR;AAzDA;EAWY,kBAAA;AAiDZ;AA5DA;EAcgB,mBAAA;AAiDhB;AA/DA;EAmBY,cAAA;EACA,gBAAA;EACA,mBAAA;AA+CZ;AApEA;EAyBY,gBAAA;AA8CZ;AAvEA;EA6BY,eAAA;EACA,iBAAA;AA6CZ;AA3EA;EAkCY,eAAA;EACA,iBAAA;AA4CZ;AA/EA;EAuCY,cAAA;EACA,gBAAA;EACA,eAAA;AA2CZ;AApFA;EA6CY,cAAA;EACA,gBAAA;AA0CZ;AAxFA;EAkDY,YAAA;AAyCZ;AAvCY;EACI,YAAA;AAyChB;AA9FA;EA0DY,YAAA;AAuCZ;AAjGA;EA+DgB,WAAA;AAqChB;AA/BQ;EAiCN,+EAA+E;EA/BrE,mBAAA;AAiCZ;AAxGA;EA4EQ,iBAAA;EACA,oBAAA;AA+BR;AA5GA;EAgFY,iBAAA;AA+BZ;AA3BI;EACI,YAAA;EACA,eAAA;AA6BR;AAnHA;;EA2FQ,iBAAA;AA4BR;AAxBA;EE4NI,cAAA;EACA,qBAAA;EF3NA,qBAAA;EACA,iBAAA;EACA,kBAAA;AA2BJ;AEgMI;;EACI,eAAA;EACA,0BAAA;AF7LR;AApCA;EAOQ,mBAAA;AAgCR;AA5BA;EACI,gBAAA;AA8BJ;AA/BA;EAIQ,gBAAA;EACA,kBAAA;AA8BR;AA1BA;EACI,kBAAA;AA4BJ;AA7BA;EAIQ,gBAAA;EACA,kBAAA;AA4BR;AAxBA;EACI,sBAAA;EACA,WAAA;EACA,gBAAA;EACA,iBAAA;EACA,YAAA;EACA,WAAA;EACA,aAAA;EACA,gBAAA;EACA,YAAA;EACA,kBAAA;AA0BJ;AAvBA;EACI,iBAAA;AAyBJ;AAtBA;EACI,eAAA;AAwBJ;AAzBA;EAIQ,cAAA;AAwBR",sourcesContent:['@import "../../../../WebCore/css/Assets/Assets.less";\n@import "../../../../WebCore/css/Assets/Mixins.less";\n@import "../Shared/Components/PropertyPages/PropertyPageShared.less";\n\n.meeting-integration-admin .property-page-header {\n    display: flex;\n\n    select {\n        margin-left: auto;\n        margin-right: 3px;\n        max-width: 383px;\n    }\n\n    .property-page-save-status {\n        display: none;\n    }\n}\n\n.meeting-user-email {\n    padding-top: 15px;\n}\n\n// had to fight the specificity war on this selector\ndiv.property-page-property.meeting-user-email > div.property-page-property-name.meeting-user-email-heading {\n    width: auto;\n}\n\n.zoom-on-premise-info {\n    margin-bottom: 20px;\n\n    .error {\n        font-size: 0.8em;\n    }\n}\n\n.meeting-admin-settings {\n    margin-bottom: 15px;\n\n    .error {\n        font-size: 0.8em;\n    }\n\n    .property-page-property-value {\n        color: @font-color;\n\n        .folder-picker-wrapper {\n            position: relative;\n\n            .dropdown-list {\n                margin-bottom: 35px;\n            }\n        }\n\n        .property-page-property-value-instructions {\n            color: @font-color-light;\n            font-size: @font-size-small;\n            margin-bottom: 10px;\n        }\n\n        .property-page-property-value-note {\n            margin-top: 10px;\n        }\n\n        .meeting-admin-allowed-group {\n            margin-top: 5px;\n            margin-left: 19px;\n        }\n\n        .meeting-admin-allowed-all-users {\n            margin-top: 5px;\n            margin-left: 19px;\n        }\n\n        .meeting-admin-instructions {\n            color: @font-color-light;\n            font-size: @font-size-small;\n            margin-top: 5px;\n        }\n\n        .warning {\n            color: @red-medium;\n            font-size: @font-size-small;\n        }\n\n        textarea {\n            width: 380px;\n\n            &.single-line{\n                resize: none;\n            }\n        }\n\n        select {\n            width: 380px;\n        }\n\n        .tagit-new.initial-state {\n            ::placeholder {\n                color: @gray-watermark;\n            }\n        }\n    }\n\n    .property-page-property-name {\n        &.meeting-admin-property-name-multiline {\n            /* Make sure the name column isn\'t vertically centered on multiline properties*/\n            vertical-align: top;\n        }\n    }\n\n    .admin-add-cancel {\n        padding-top: 20px;\n        padding-bottom: 20px;\n\n        .standard-button {\n            margin-right: 8px;\n        }\n    }\n\n    &.disabled {\n        opacity: 0.5;\n        cursor: default;\n    }\n\n    input[type=\'radio\'],\n    input[type=\'checkbox\'] {\n        margin-right: 5px;\n    }\n}\n\n.meeting-admin-link-button {\n    .link();\n    display: inline-block;\n    margin-left: 10px;\n    margin-right: 10px;\n\n    .align-button-top {\n        vertical-align: top;\n    }\n}\n\n.meeting-admin-action-buttons {\n    margin-top: 10px;\n\n    .meeting-admin-link-button {\n        margin-left: 0px;\n        margin-right: 10px;\n    }\n}\n\n.meeting-admin-sso-action-buttons {\n    margin-left: 150px;\n\n    .meeting-admin-link-button {\n        margin-left: 0px;\n        margin-right: 10px;\n    }\n}\n\n.meeting-admin-log-textarea {\n    font-family: monospace;\n    width: 100%;\n    min-width: 400px;\n    min-height: 400px;\n    height: 60vh;\n    border: 0px;\n    outline: none;\n    overflow-y: auto;\n    resize: none;\n    font-size: initial;\n}\n\n.continued-section {\n    margin-top: -20px;\n}\n\n.meeting-admin-settings-radio-option {\n    margin-top: 5px;\n\n    span.meeting-admin-setting-disabled {\n        color: @gray-disabled;\n    }\n}\n','/* Constants / styles used across the product */\n\n/* Fonts */\n@font: Segoe UI, Helvetica, sans-serif;\n@font-semibold: Segoe UI Semibold, Helvetica Neue, Segoe UI, Helvetica, sans-serif;\n@font-light: Segoe UI Light, HelveticaNeue-Light, Segoe UI, Helvetica, sans-serif;\n.font-light() {\n    font-family: var(--panopto-font-family-light);\n    font-weight: 100; // FF doesn\'t include Segoe UI Light, font-weight lighter approximates it.\n}\n.font-semibold() {\n    font-family: var(--panopto-font-family-semibold);\n    font-weight: 600;\n}\n\n:root {\n    --panopto-font-family: @font;\n    --panopto-font-family-semibold: @font-semibold;\n    --panopto-font-family-light: @font-light;\n}\n\n@font-size-base: 16px;\n@font-size-medium: 1.45em;\n@font-size-large: 1.5em;\n@font-size-big-title: 1.7em;\n@font-size-small: .8em;\n@font-size-xsmall: .7em;\n@font-size-extra-large: 2.1em;\n@font-size-huge: 3.0em;\n// Our website uses this as its base\n@font-size-website-base: 13px;\n// These are basic font sizes used by the recorder. We should start making all of these consistent\n@font-size-title: 1.3em;\n@font-size-header: 1.2em;\n@font-size-command-button: 1.1em;\n@font-size-subtitle: .9em;\n@font-size-option: .8em;\n@font-size-button: .7em;\n\n@icon-size-without-text: 24px;\n@icon-size-with-text: 18px;\n\n/* Sizes */\n@site-min-width: 1004px;\n\n@small-logo-max-width: 265px;\n@small-logo-max-height: 23px;\n@large-logo-max-width: 340px;\n@large-logo-max-height: 50px;\n\n// Preferred hit target size for touch interfaces.\n@touch-target-size: 48px;\n// Smaller touch target size for tightly constrained contexts.\n@touch-target-size-small: 40px;\n\n@button-spacing: 10px;\n\n/* Page gradient */\n@page-gradient: linear-gradient(to bottom, #ffffff 0%, #f5f5f5 60%);\n\n/* Opacities of black (for consistent effect over gradient vs. fixed grays) */\n@darken-hovered: rgba(0, 0, 0, 0.03);\n@darken-selected: rgba(0, 0, 0, 0.06);\n@darken-selected-session: rgba(0, 0, 0, 0.05);\n\n/* Font Colors */\n@font-color-primary: #009900;\n@font-color-secondary: #466c2c;\n@font-color-link: #0F7395;\n\n@font-color-error: #990000;\n@font-color-dark: #000000;\n@font-color: #464646;\n@font-color-light: #777777;\n@font-color-lightest: #999999;\n@font-color-light-background: #b8b8b8;\n@font-light-gray: #aaaaaa;\n\n@font-color-black-80pct: rgba(0, 0, 0, 0.8);\n\n/* Font Colors (Accessibility) */\n@font-color-light-white-background: #767676;\n\n/* New font colors */\n@text-color-primary: rgba(0, 0, 0, .9);\n@text-color-secondary: rgba(0, 0, 0, .7);\n@text-color-on-accent: rgba(255, 255, 255);\n@text-color-additional: rgba(0, 0, 0, .6);\n\n@icon-color-primary: rgba(0, 0, 0, .8);\n@icon-color-secondary: rgba(0, 0, 0, .6);\n@icon-color-additional: rgba(0, 0, 0, .5);\n\n@border-color-primary: rgba(0, 0, 0, .1);\n\n@background-hover: rgba(0, 0, 0, .05);\n@background-active: rgba(0, 0, 0, .1);\n\n/* "Dark Theme" Colors */\n@overlay-background-color: rgba(0, 0, 0, 0.8);\n@icon-color-dark-theme: rgba(255, 255, 255, 0.8);\n@icon-color-active-dark-theme: white;\n@tab-highlight-color-dark-theme: rgba(255, 255, 255, 0.8);\n@border-color-dark-theme: rgba(255, 255, 255, 0.2);\n@font-color-dark-theme: rgba(255, 255, 255, 1);\n@font-color-secondary-dark-theme: rgba(255, 255, 255, 0.8);\n@hover-background-color-dark-theme: rgba(255, 255, 255, 0.1);\n@contrast-background-color-dark-theme: rgba(255, 255, 255, 0.2);\n\n/* Colors */\n@blue-selected: #aedcf1;\n\n@white-bright: #e6e6e6;\n@pure-white: #ffffff;\n\n@red: #bd4f4f;\n@red-medium: #a04242;\n@red-dark: #8c3939;\n@red-light: #ebcaca;\n@red-bright: #dd3217;\n\n@green: #54bf6d;\n@green-medium: #1d8f37;\n@green-dark: #185e0d;\n@green-light: #92c88a;\n@green-background: #eef5f0;\n@green-sunny: #719f46;\n@green-shady: #48761d;\n\n// Branded Panopto Green. Do _NOT_ use this for areas that should be affected by branding\n@panopto-green: #30733F;\n\n@icon-color: #626262;\n@header-color: #f5f5f5;\n@header-dropdown-background-color: White;\n@focused-background-color: #e8e8e8;\n@gray-border: #e0e0e0;\n@gray-light: #d6d6d6;\n@gray-hover: #f0f0f0;\n@gray-very-light: #f2f2f2;\n@gray-hint: #f5f5f5;\n@gray-press: #cccccc;\n@gray-dark: #999999;\n@gray-header: #666;\n@gray-shadow: #888;\n@gray-future: #f2f2f2;\n@dark-selected: #8b8b8b;\n@gray-divider: #989898;\n@light-selected: #dbdbdb;\n@gray-silver: #e7e7e7;\n@gray-disabled: #ebebe4;\n@gray-button-hover: #e5e5e5;\n@gray-transparent: rgba(0,0,0,0.2);\n@gray-transparent-subtle: rgba(0,0,0,0.1);\n@gray-transparent-light: rgba(0,0,0,0.3);\n@gray-transparent-medium: rgba(0,0,0,0.5);\n@gray-transparent-dark: rgba(0,0,0,0.6);\n@gray-dark-shadow: rgba(0,0,0,0.7);\n@gray-darker-shadow: rgba(0,0,0,0.8);\n@gray-watermark: gray;\n@letterbox-color: black;\n@rr-letterbox-color: #3f3f3f;\n@material-box-shadow: 0 6px 10px 0 rgba(0,0,0,.14),\n                      0 1px 18px 0 rgba(0,0,0,.12),\n                      0 3px 5px -1px rgba(0,0,0,.20);\n\n@background-warning: orange;\n\n@yellow: #feffc9;\n\n@stored-quota-foreground: #B56F90;\n@stored-quota-background: #B56F90;\n@delivered-quota-foreground: #4798D0;\n@delivered-quota-background: #4798D0;\n\n@drop-target-background: rgba(231, 239, 254, 0.5);\n@drop-target-background-invalid: fadeout(white, 20%);\n@drop-target-border: fadeout(#4384f4, 57%);\n\n/* For gradient buttons */\n\n/* Small Thumbnail */\n@small-thumbnail-cell-width: 120px;\n@small-thumbnail-height: 60px;\n@small-thumbnail-width: (16 / 9) * @small-thumbnail-height;\n\n/* Volume preview specific colors */\n@neutral-color: #0098cc;\n@loud-color: #9d0b0b;\n@quiet-color: #ffa900;\n@neutral-text-color: #019acd;\n@loud-text-color: #8a1d1d;\n@quiet-text-color: #d08e0b;\n@loud-warning-color: #cf8787;\n@quiet-warning-color: #ffd57f;\n@loud-border: #7fcce6;\n\n/* Opacities */\n@button-opacity: .6;\n@button-hover-opacity: .8;\n@button-active-opacity: 1.0;\n@button-disabled: .3;\n\n/* Borders */\n@input-border-edit: 1px solid #959595;\n@input-border-hover: 1px solid #cdcdcd;\n@input-border-white: 1px solid White;\n@header-dropdown-border: 1px solid #cccccc;\n@input-border-light: 1px solid #cccccc;\n@input-border-extra-light: 1px solid @gray-border;\n/* Input Border Color (WCAG 1.4.11 Accessibility) */\n@input-border-color: #8C8C8C;\n\n/* Common measurements */\n\n// The height of most of our modal inputs\n@input-height: 28px;\n\n/* Images */\n@spinner-path: "Spinner/";\n@spinner-large: "large-comet-animation-grey.gif";\n@spinner-small-white: "spinner_small_white.gif";\n@spinner-small-beige: "spinner_small_eee.gif";\n\n@spinner-large-themable: "spinner_large_themable.png";\n@spinner-small-white-themable: "spinner_small_themable_white.png";\n@spinner-small-beige-themable: "spinner_small_themable_eee.png";\n@spinner-small-gray-themable: "spinner_small_themable_e0e0e0.png";\n\n/* Transitions */\n@viewer-transition: all .125s ease-in-out;\n\n/* Mobile */\n\n// Google recommends a base of 16px\n// https://developers.google.com/speed/docs/insights/UseLegibleFontSizes?hl=en\n@mobile-base-size: 16px;\n\n// Maybe we want to change this to a hex code later\n// so for now use yellow and we can change it easier\n@mobile-font-warning: yellow;\n@mobile-background-disabled: rgb(187, 187, 187);\n\n// Mobile query constants\n\n// "almost" is one less then actual width,\n// "almost" queries should be used for max-width \n// actual queries should be used for min-width\n// By keeping those consistent we can be sure that the layout\n// doesn\'t do funky things on the pixel between the two\n// and we won\'t need to consider which media query comes first\n// NOTE: The parens around the following bits are necessary, LESS generates invalid CSS without them.\n@ipad4-portrait-width: 320px;\n@iphone5-landscape-width: 568px;\n@iphone6-portrait-width: 375px;\n\n@almost-iphone6-portrait-width: (@iphone6-portrait-width - 1);\n\n@ipad-mini-portrait-width: 768px;\n@almost-ipad-mini-portrait-width: (@ipad-mini-portrait-width - 1);\n\n@nexus7-landscape-width: 960px;\n@almost-nexus7-landscape-width: (@nexus7-landscape-width - 1);\n\n/* Embed */\n@defaultEmbedWidth: 720px;\n@defaultEmbedHeight: 405px;\n\n/* Material icons */\n@checkbox-glyph-inset: 3px;\n\n/* Resets */\nbody {\n    margin: 0px;\n}\n\n.clicked {\n    outline: none;\n}\n','@small-loading-indicator-length: 16px;\n\n.border-radius (@radius) {\n    -webkit-border-radius: @radius;\n    -moz-border-radius: @radius;\n    border-radius: @radius;\n}\n\n.box-sizing (@sizing) {\n    box-sizing: @sizing;\n    -moz-box-sizing: @sizing;\n}\n\n// Prevents anti aliasing\n// http://stackoverflow.com/questions/14068103/disable-antialising-when-scaling-images\n.prevent-anti-aliasing () {\n    // The browser will ignore the lines it can\'t understand\n    // and so it works to have the same property listed multiple times\n    image-rendering: optimizeSpeed;\n    image-rendering: -moz-crisp-edges;\n    image-rendering: -o-crisp-edges;\n    image-rendering: -webkit-optimize-contrast;\n    image-rendering: pixelated;\n    image-rendering: optimize-contrast;\n}\n\n.user-select(@select) {\n    -webkit-touch-callout: @select;\n    -webkit-user-select: @select;\n    -khtml-user-select: @select;\n    -moz-user-select: @select;\n    user-select: @select;\n}\n\n.background-image-gradient (@deg, @color-bottom, @color-top) {\n    background-image: -webkit-linear-gradient(@deg, @color-bottom 0%, @color-top 100%);\n    background-image: -moz-linear-gradient(@deg, @color-bottom 0%, @color-top 100%);\n}\n\n.background-complex-gradient (@deg, @color-first, @color-second, @color-third, @color-fourth) {\n    background-image: -webkit-linear-gradient(@deg, @color-first, @color-second, @color-third, @color-fourth);\n    background-image: -moz-linear-gradient(@deg, @color-first, @color-second, @color-third, @color-fourth);\n}\n\n// Block-level elements with known dimensions can be centered within positioned parents.\n.center-block(@width, @height, @h-offset: 0, @v-offset: 0) {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    // Block origin is centered by the above, shift by half height / width to align block center with container center.\n    margin-left: -(@width / 2) + @h-offset;\n    margin-top: -(@height / 2) + @v-offset;\n    width: @width;\n    height: @height;\n}\n\n.clickable () {\n    &:hover {\n        cursor: pointer;\n    }\n}\n\n.access-icons(@length) {\n    .access-item-icon(@image) {\n        .icon("Share/", @image, @length, @length);\n    }\n\n    &.invite {\n        .access-item-icon("icon_email.png");\n    }\n\n    &.group {\n        .access-item-icon("icon_group.png");\n    }\n\n    &.user {\n        .access-item-icon("icon_user.png");\n    }\n}\n\n.pressable (@background-highlight, @background-pressed, @cursor: default) {\n    &:hover {\n        background-color: @background-highlight;\n        cursor: @cursor;\n    }\n    &:focus {\n        background-color: @background-highlight;\n    }\n    &:active {\n        background-color: @background-pressed;\n    }\n}\n\n.hoverable (@background-highlight, @background-pressed, @cursor: default) {\n    .transition(background-color .15s);\n    &:hover {\n        background-color: @background-highlight;\n        cursor: @cursor;\n        .transition(background-color .15s);\n    }\n    &:active {\n        background-color: @background-pressed;\n        .transition(background-color .15s);\n    }\n}\n\n// @child-class-string needs to the the class selector without the \'.\', LESS allows us to pass strings but not complete selectors\n// http://stackoverflow.com/questions/19602812/less-mixin-a-variable-class-name\n.hoverable-child (@child-class-string, @background-parent-highlight, @background-child-highlight, @background-pressed, @cursor: default) {\n    &:hover .@{child-class-string} {\n        background-color: @background-parent-highlight;\n        .transition(background-color .15s);\n    }\n    .@{child-class-string} {\n        .hoverable(@background-child-highlight, @background-pressed, @cursor);\n    }\n}\n\n.hoverable-opacity() {\n    opacity: @button-opacity;\n\n    &:hover, &:focus {\n        opacity: @button-hover-opacity;\n    }\n\n    &:active {\n        opacity: @button-active-opacity;\n    }\n}\n\n.background-image(@root, @image, @repeat: no-repeat, @align: center) {\n    background-image: ~"url(\'@{image-path}@{root}@{image}\')";\n    background-repeat: @repeat;\n    background-position: @align;\n}\n\n.icon (@root, @image, @width: auto, @height: auto, @repeat: no-repeat, @align: center) {\n    .background-image(@root, @image, @repeat, @align);\n    width: @width;\n    height: @height;\n}\n\n.transition(@params) {\n    -webkit-transition: @params;\n    -moz-transition: @params;\n    -o-transition: @params;\n    transition: @params;\n}\n\n.transform(@params) {\n    transform: @params;\n    -webkit-transform: @params;\n}\n\n.pressable-icon(@root, @image, @image-hover, @image-press, @width: auto, @height: auto, @repeat: no-repeat, @align: center) {\n    .icon(@root, @image, @width, @height, @repeat, @align);\n\n    &:hover {\n        .icon(@root, @image-hover, @width, @height, @repeat, @align);\n        cursor: default;\n    }\n    &:focus {\n        .icon(@root, @image-hover, @width, @height, @repeat, @align);\n    }\n    &:active {\n        .icon(@root, @image-press, @width, @height, @repeat, @align);\n    }\n}\n\n.break {\n    display: block;\n    height:  15px;\n}\n\n.clear {\n    clear: both;\n    height: 0px;\n}\n\n.box-shadow(none) {\n    -webkit-box-shadow: none;\n    -moz-box-shadow: none;\n    box-shadow: none;\n}\n\n.box-shadow(@color, @h-shadow, @v-shadow, @blur, @spread) {\n    -webkit-box-shadow: @color @h-shadow @v-shadow @blur @spread;\n    -moz-box-shadow: @color @h-shadow @v-shadow @blur @spread;\n    box-shadow: @color @h-shadow @v-shadow @blur @spread;\n}\n\n.box-shadow-inset(@color, @h-shadow, @v-shadow, @blur, @spread) {\n    -webkit-box-shadow: @color @h-shadow @v-shadow @blur @spread inset;\n    -moz-box-shadow: @color @h-shadow @v-shadow @blur @spread inset;\n    box-shadow: @color @h-shadow @v-shadow @blur @spread inset;\n}\n\n.borders(@top-color, @right-color, @bottom-color, @left-color) {\n    border-top:1px solid @top-color;\n    border-right: 1px solid @right-color;\n    border-bottom:1px solid @bottom-color;\n    border-left:1px solid @left-color;\n}\n\n.rotating-animation() {\n    // IE and FF support the w3 standard keyframes\n    @keyframes rotate {\n        0% {\n            transform: rotate(0deg);\n        }\n        100% {\n            transform: rotate(360deg);\n        }\n    }\n\n    // Chrome and Safari need special webkit\n    @-webkit-keyframes rotate {\n        0% {\n            -webkit-transform: rotate(0deg);\n        }\n        100% {\n            -webkit-transform: rotate(360deg);\n        }\n    }\n\n    animation: rotate 2s linear infinite;\n    -webkit-animation: rotate 2s linear infinite;\n}\n\n.color-holder(@diameter) {\n    position: absolute;\n    .border-radius(50%); // Circle\n    width: @diameter;\n    height: @diameter;\n}\n\n.indicator-border(@border-size, @color){\n    left: -@border-size;\n    top: -@border-size;\n    border: @border-size solid @color;\n}\n\n.small-loading-indicator(@image-grey, @image-themed, @border-color) {\n    @small-length: @small-loading-indicator-length;\n    width: @small-length;\n    height: @small-length;\n    overflow: hidden;\n\n    .branding-color-holders {\n        display: block;\n       .color-holder(15px);\n    }\n\n    .loading-indicator {\n        position: relative;\n        .icon(@spinner-path, @image-grey, @small-length, @small-length);\n        .indicator-border(10px, @border-color);\n\n        &.branded-animation {\n            // The "- 1" fixes a samll issue in Chrome where the when zoomed to 90% you could see a second spinner\n            .icon(@spinner-path, @image-themed, @small-length - 1, @small-length - 1);\n            .rotating-animation();\n        }\n    }\n}\n\n.opacity(@opacity) {\n    opacity: @opacity;\n    @percent: @opacity * 100;\n    // IE8 and below\n    filter: alpha(opacity=@percent);\n}\n\n.horizontal-rule(@color) {\n    display: block;\n    border-bottom: 1px solid @color;\n}\n\n.popup(@z-index) {\n    z-index: @z-index;\n    .box-shadow(@gray-dark, 2px, 3px, 5px, 0);\n    border: @header-dropdown-border;\n    background-color: @header-dropdown-background-color;\n    position: absolute;\n    text-align: left;\n\n    .popup-title {\n        color: @font-color;\n        font-weight: bold;\n    }\n}\n\n.header-dropdown() {\n    .popup(100003);\n\n    > a, > div {\n        &:hover {\n            background-color: @gray-hover;\n            cursor: default;\n        }\n        &:active {\n            background-color: @gray-press;\n        }\n        text-decoration: none;\n        display: block;\n    }\n}\n\n.error {\n    color: @font-color-error !important;\n}\n\n.ellipsis {\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n}\n\n// @lines is honored on WebKit.\n// @max-height provides a fallback on other browsers (simple vertical truncation).\n.multiline-ellipsis (@lines, @max-height) {\n    // On WebKit, show ellipsis after two lines if text is longer.\n    display: -webkit-box;\n    -webkit-line-clamp: @lines;\n    -webkit-box-orient: vertical;\n    // For non-WebKit browsers, just crop lines beyond the second (no ellipsis).\n    max-height: @max-height;\n    overflow: hidden;\n    // Override "nowrap" behavior of .ellipsis (typically also present for tooltips) to enable wrapping to additional lines.\n    white-space: normal;\n}\n\n.attention {\n    font-weight: bold;\n}\n\n\n// Styles a div as a table row, with direct div children as cells\n.table-row (@width: 100%, @align: top) {\n    display: table;\n    width: @width;\n\n    > div, > a, > img, > i {\n        display: table-cell;\n        vertical-align: @align;\n    }\n}\n\n// Styles any element to look and behavior like a link\n.link (@cursor: pointer, @color: @font-color-link) {\n    color: @color;\n    text-decoration: none;\n\n    &:hover, &:focus {\n        cursor: @cursor;\n        text-decoration: underline;\n    }\n}\n\n// Creates a thin, two-tone scrollbar (plain thumb on plain track), where supported by the browser.\n// Width is 8px on Webkit, "thin" on FF (works out to similar), and full width on other browsers.\n// Webkit thumb will have a 5px border-radius (others will have square edges).\n.custom-scrollbar(@thumb-color, @track-color) {\n    @supports not selector(::-webkit-scrollbar) {\n        scrollbar-width: thin;\n        scrollbar-color: @thumb-color @track-color;\n    }\n\n    &::-webkit-scrollbar {\n        background-color: @track-color;\n        width: 8px;\n        height: 8px;\n    }\n\n    &::-webkit-scrollbar-thumb {\n        background-color: @thumb-color;\n        border-radius: 5px;\n    }\n}\n\n.hidden-scrollbar {\n    &::-webkit-scrollbar { display: none; } /* Chrome/Safari/Webkit */\n    scrollbar-width: none; /* Firefox */\n}\n\n.edit-control() {\n    padding: 2px;\n    bottom: 0px;\n    right: 0px;\n    z-index: 1;\n    background-color: white;\n\n    > div {\n        .link;\n        display: inline-block;\n        padding: 3px 8px 4px 8px;\n        border: 1px solid @gray-press;\n        background-color: white;\n    }\n}\n\n.viewer-message() {\n    margin: 20px auto 0px auto;\n    text-align: center;\n    // This is the size used in Viewer.less\n    // repeated here to make this consistent between pages\n    font-size: medium;\n\n    #messageText {\n        padding: 10px;\n    }\n\n    #messageLink {\n        padding: 0px 10px 10px 10px;\n    }\n}\n\n.role-select(@width, @margin-top) {\n    font-family: @font;\n    width: @width;\n    height: 38px;\n    margin-top: @margin-top;\n    padding: 6px;\n    font-size: @font-size-base;\n    .border-radius(4px);\n    color: @font-color-light;\n    display: block;\n    vertical-align: top;\n}\n\n// Shared thumbnail styles\n.thumbnail(@thumbnail-width-param: 196px, @thumbnail-height-param: 110px) {\n    // This is necessary to surface these params in the enclosing scope of the mixin.\n    @thumbnail-width: @thumbnail-width-param;\n    @thumbnail-height: @thumbnail-height-param;\n    @thumbnail-border: 1px;\n    @overlay-margin: 2px;\n\n    .thumbnail-container {\n        // Provide a positioning context for thumbnail overlays\n        position: relative;\n        width: @thumbnail-width;\n        height: @thumbnail-height;\n        border: @thumbnail-border solid @gray-border;\n        .border-radius(3px);\n        background: black;\n        // Prevent child image from bleeding out of the rounded corners\n        overflow: hidden;\n\n        // Give linked thumbnails a darkened border on hover\n        &.viewable:hover {\n            border: @thumbnail-border solid @gray-dark;\n        }\n\n        // Show link or span depending on "viewable" class on container\n        .thumbnail-span,\n        &.viewable .thumbnail-link {\n            display: block;\n        }\n        .thumbnail-link,\n        &.viewable .thumbnail-span {\n            display: none;\n        }\n\n        // Needed to enable "height/width: 100%" to work on ".thumbnail-img/-failed-load" below\n        .thumbnail-link,\n        .thumbnail-span {\n            width: 100%;\n            height: 100%;\n        }\n\n        .thumbnail-img,\n        .thumbnail-failed-load {\n            // Necessary for horizontal centering, correct focus outlines, etc.\n            display: block;\n            // Start by fitting height and allowing width to scale with thumbnail aspect ratio.\n            // Aspect ratios wider than 16:9 are handled in JS by Panopto.Util.fitThumbnailWidth().\n            // Once we drop IE8 we can use background-size: contain for a pure CSS solution.\n            width: auto;\n            height: 100%;\n            // Center the thumbnail horizontally within the container if it\'s narrower than 16:9\n            margin: auto;\n            // Prevent image link border in older IE\n            border: none;\n            // Prevent browser default behavior for dragging images to enable session drag from thumb.\n            pointer-events: none;\n        }\n\n        // Show duration in an overlay at the bottom right of the thumbnail\n        .duration {\n            .overlay();\n            .border-radius(1px);\n            bottom: @overlay-margin;\n            right: @overlay-margin;\n            font-size: @font-size-subtitle;\n        }\n\n        .playlist {\n            .overlay();\n            .border-radius(1px);\n            top: 0;\n            right: 0;\n            height: @thumbnail-height;\n            line-height: @thumbnail-height;\n            text-align: center;\n            padding: 0 5px;\n\n            // Give the playlist overlay a bit of default width so shorter languages don\'t look goofy\n            min-width: 40%;\n\n            // This works around issues with our "line-height"-based vertical centering hack when on a page with an\n            // XHTML 1.0 doctype (resulting in "Almost Standards Mode").\n            &::before,\n            &::after {\n                content: \'\';\n                display: inline-block;\n                vertical-align: middle;\n            }\n\n            // Handle vertical centering of text;\n            .playlist-text {\n                @height-adjustment: 10px;\n                display: inline-block;\n                vertical-align: middle;\n                // Adjust the height between the icon and text\n                line-height: @height-adjustment;\n                // Fix the vertical centering of the text\n                margin-top: -@height-adjustment;\n                font-size: @font-size-website-base;\n            }\n        }\n\n        .completion-overlay {\n            position: absolute;\n            bottom: 0;\n            height: 4px;\n            width: 100%;\n            background: @gray-press;\n\n            // Width is set in script in `itemRendered` callbacks in SessionList.ts and HomeUtils.ts.\n            // Color is set to brand color via .accent-background.\n            .progress {\n                height: 100%;\n            }\n        }\n\n        .archived-overlay {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            display: flex;\n            align-items: center;\n            justify-content: space-around;\n            align-content: space-around;\n            // Control opacity through the backgroun so the text is fully opaque.\n            background: rgba(255, 255, 255, 0.8);\n            color: @icon-color;\n            pointer-events: none;\n        }\n    }\n\n    // Mixin for info overlays on .thumbnail-container (white text on translucent black background)\n    .overlay() {\n        position: absolute;\n        // IE8 fallback (doesn\'t support rgba)\n        background: black;\n        background: rgba(0, 0, 0, 0.7);\n        padding: 1px 3px;\n        color: white;\n        cursor: default;\n        // Enable mouse events to pass through to the underlying thumbnail link / span (NOTE: not supported on IE10-)\n        pointer-events: none;\n    }\n}\n\n// Shared caption option styles\n.caption-options(@asset-path, @item-size, @item-padding, @item-border, @docked-icon-size) {\n    .user-select(none);\n\n    li {\n        // override box-sizing: border-box set on fullscreen options\n        box-sizing: content-box;\n        display: block;\n        float: left;\n        margin-left: 5px;\n        width: @item-size;\n        height: @item-size;\n        // Line height needs to consider padding to align with the width\n        line-height: @item-size - (2 * @item-padding);\n        text-align: center;\n        cursor: pointer;\n        padding: @item-padding;\n\n        // Use a transparent border when not selected to avoid reflow on selection\n        border-width: @item-border;\n        border-style: solid;\n        border-color: transparent;\n    }\n\n    // Color samples have a border color to display as well\n    li .color-sample {\n        border-width: 1px;\n        border-style: solid;\n    }\n\n    .transparent-background {\n        .icon(@asset-path, "checker.png");\n        background-position: left top;\n    }\n\n    .placement-option {\n        // Override the default explicit size to the image\n        width: auto;\n        height: auto;\n    }\n\n    // Docked image icon\n    .Docked div {\n        .icon(@asset-path, "icon_position_Docked.png", @docked-icon-size, @docked-icon-size);\n    }\n\n    // Overlay image icon\n    .Overlay div {\n        .icon(@asset-path, "icon_position_Overlay.png", @docked-icon-size, @docked-icon-size);\n    }\n}\n\n.dialog-triangle() {\n    // These are styles to position and scale unicode triangle character for a dialog\n    position: absolute;\n    display: block;\n    color: white;\n    z-index: 1000;\n    margin-left: -10px;\n    margin-top: -11px;\n    font-size: 1.5em;\n    .transform(scaleX(1.5));\n    cursor: default;\n}\n\n// Used to place an opaque overlay on the screen\n.screen-overlay() {\n    display: none;\n    position: fixed;\n    top: 0; left: 0; right: 0; bottom: 0;\n    background-color: black;\n    @opacity: 70;\n    opacity: (@opacity / 100);\n    filter: alpha(opacity=@opacity); // IE8 hack. "opacity" supported in IE9+\n    z-index: 999;\n}\n\n// Used to vertically align material icons nicely beside text\n.material-icon-beside-text() {\n    // Align the material icon with the text\n    vertical-align: middle;\n    // Underlining material design icons doesn\'t render nicely\n    text-decoration: none;\n    // Give the icon a little space from the title\n    padding-right: 3px;\n}\n\n.folder-header-icon(@width, @height, @icon) {\n    .icon(@asset-path, @icon, @width, @height);\n    float: left;\n    margin-right: 10px;\n}\n\n// Used for close buttons that use the "close"/x material icon\n.close-button (@size) {\n    display: block;\n    text-decoration: none;\n    color: @font-color-light;\n    font-size: @size;\n\n    .hoverable(@gray-transparent, @gray-transparent-dark);\n\n    &:active {\n        color: white;\n    }\n}\n\n.speech-bubble() {\n    @padding: 10px;\n    @border-width: 1px;\n    @background-color: white;\n    position: relative;\n    background-color: @background-color;\n    border: @border-width solid @gray-border;\n    border-radius: 3px;\n    border-bottom-left-radius: 0px;\n    padding: @padding;\n\n    &:before {\n        content: "";\n        position: absolute;\n        top: 100%;\n        left: 0px - @border-width;\n        width: 0px;\n        display: block;\n        border-width: 20px 20px 0 0;\n        border-style: solid;\n        border-color: @gray-border transparent;\n    }\n\n    &:after {\n        content: "";\n        position: absolute;\n        top: 100%;\n        left: 0px;\n        width: 0px;\n        display: block;\n        border-width: 17px 17px 0 0;\n        border-style: solid;\n        border-color: @background-color transparent;\n    }\n}\n\n.flat-button() {\n    display: inline-block;\n    padding: 6px 9px 8px 9px;\n    .border-radius(3px);\n    background-color: @header-color;\n    cursor: pointer;\n    text-decoration: none;\n    font-weight: 600;\n    color: @font-color;\n    text-align: center;\n    border: 1px solid @gray-light;\n\n    &.safety-background {\n        color: white;\n        border: 0px;\n        padding: 7px 10px 9px 10px;\n    }\n\n    &:hover, &:active {\n        text-decoration: none;\n    }\n}\n\n.copyright-warning() {\n    font-size: @font-size-small;\n    color: @font-color-light-white-background;\n    text-align: center;\n    padding: 20px;\n}\n\n.material-checkbox(\n    @color: @icon-color,\n    @background: rgba(255, 255, 255, 0.85)\n) {\n    -webkit-appearance: unset;\n    -moz-appearance: none;\n    position: relative;\n    color: @color;\n\n    // Remove border and background color as they still show up on Mobile Safari\n    // even with appearance unset\n    border: none;\n    background-color: transparent;\n\n    &::before {\n        content: "";\n        position: absolute;\n        top: @checkbox-glyph-inset;\n        right: @checkbox-glyph-inset;\n        bottom: @checkbox-glyph-inset;\n        left: @checkbox-glyph-inset;\n        border-radius: 3px;\n        background: @background;\n    }\n\n    &::after {\n        content: "check_box_outline_blank";\n        position: absolute;\n    }\n    &:checked::after {\n        content: "check_box";\n    }\n}\n\n.material-radio(\n    @color: @icon-color,\n    @background: rgba(255, 255, 255, 0.85)\n) {\n    -webkit-appearance: unset;\n    -moz-appearance: none;\n    position: relative;\n    color: @color;\n\n    // Remove border and background color as they still show up on Mobile Safari\n    // even with appearance unset\n    border: none;\n    background-color: transparent;\n\n    &::before {\n        content: "";\n        position: absolute;\n        top: @checkbox-glyph-inset;\n        right: @checkbox-glyph-inset;\n        bottom: @checkbox-glyph-inset;\n        left: @checkbox-glyph-inset;\n        border-radius: 3px;\n        background: @background;\n    }\n\n    &::after {\n        content: "radio_button_unchecked";\n        position: absolute;\n    }\n    &:checked::after {\n        content: "radio_button_checked";\n    }\n}\n\n.placeholder(@rules) {\n    &::placeholder {\n        @rules();\n    }\n}\n\n.material-select() {\n    background: url(data:image/svg+xml;base64,) no-repeat right 2px center;\n    -moz-appearance: none; \n    -webkit-appearance: none; \n    appearance: none;\n}\n\n.clear-search-icon() {\n    @icon-size: 18px;\n    .icon("Widgets/", "icon_cancel.svg", @icon-size, @icon-size, no-repeat);\n    background-size: @icon-size;\n}\n'],sourceRoot:""}]);const s=/^(103|4044|8193)$/.test(t.j)?a:null},67794(e,n,t){"use strict";t.d(n,{A:()=>s});var o=t(82001),r=t.n(o),i=t(40935),a=t.n(i)()(r());a.push([e.id,".expandable-row {\n  cursor: pointer;\n}\n","",{version:3,sources:["webpack://./React/Pro/AccountManagement/ExpandableRow.less"],names:[],mappings:"AAAA;EACI,eAAA;AACJ",sourcesContent:[".expandable-row {\n    cursor: pointer;\n}\n"],sourceRoot:""}]);const s=/^(5113|8347)$/.test(t.j)?a:null},92862(e,n,t){"use strict";t.d(n,{A:()=>u});var o=t(82001),r=t.n(o),i=t(40935),a=t.n(i),s=t(20062),l=t.n(s),d=new URL(t(12709),t.b),c=new URL(t(28381),t.b),p=a()(r()),h=l()(d),g=l()(c);p.push([e.id,`/* Constants / styles used across the product */\n/* Fonts */\n:root {\n  --panopto-font-family: Segoe UI, Helvetica, sans-serif;\n  --panopto-font-family-semibold: Segoe UI Semibold, Helvetica Neue, Segoe UI, Helvetica, sans-serif;\n  --panopto-font-family-light: Segoe UI Light, HelveticaNeue-Light, Segoe UI, Helvetica, sans-serif;\n}\n/* Sizes */\n/* Page gradient */\n/* Opacities of black (for consistent effect over gradient vs. fixed grays) */\n/* Font Colors */\n/* Font Colors (Accessibility) */\n/* New font colors */\n/* "Dark Theme" Colors */\n/* Colors */\n/* For gradient buttons */\n/* Small Thumbnail */\n/* Volume preview specific colors */\n/* Opacities */\n/* Borders */\n/* Input Border Color (WCAG 1.4.11 Accessibility) */\n/* Common measurements */\n/* Images */\n/* Transitions */\n/* Mobile */\n/* Embed */\n/* Material icons */\n/* Resets */\nbody {\n  margin: 0px;\n}\n.clicked {\n  outline: none;\n}\n.break {\n  display: block;\n  height: 15px;\n}\n.clear {\n  clear: both;\n  height: 0px;\n}\n.error {\n  color: #990000 !important;\n}\n.ellipsis {\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n.attention {\n  font-weight: bold;\n}\n.hidden-scrollbar {\n  /* Chrome/Safari/Webkit */\n  scrollbar-width: none;\n  /* Firefox */\n}\n.hidden-scrollbar::-webkit-scrollbar {\n  display: none;\n}\n.autosave-status {\n  position: relative;\n}\n.autosave-status .loading-block {\n  position: relative;\n  display: block;\n  width: 20px;\n  height: 20px;\n  overflow: hidden;\n}\n.autosave-status .branding-color-holders {\n  display: none;\n  margin: auto;\n  position: absolute;\n  -webkit-border-radius: 50%;\n  -moz-border-radius: 50%;\n  border-radius: 50%;\n  width: 15px;\n  height: 15px;\n}\n.autosave-status .loading-indicator {\n  display: none;\n  position: relative;\n  left: -10px;\n  top: -10px;\n  border: 10px solid white;\n}\n.autosave-status.spinning {\n  width: 16px;\n  height: 16px;\n  overflow: hidden;\n}\n.autosave-status.spinning .branding-color-holders {\n  display: block;\n  position: absolute;\n  -webkit-border-radius: 50%;\n  -moz-border-radius: 50%;\n  border-radius: 50%;\n  width: 15px;\n  height: 15px;\n}\n.autosave-status.spinning .loading-indicator {\n  position: relative;\n  background-image: url(${h});\n  background-repeat: no-repeat;\n  background-position: center;\n  width: 16px;\n  height: 16px;\n  left: -10px;\n  top: -10px;\n  border: 10px solid white;\n}\n.autosave-status.spinning .loading-indicator.branded-animation {\n  background-image: url(${g});\n  background-repeat: no-repeat;\n  background-position: center;\n  width: 15px;\n  height: 15px;\n  animation: rotate 2s linear infinite;\n  -webkit-animation: rotate 2s linear infinite;\n}\n@keyframes rotate {\n  0% {\n    transform: rotate(0deg);\n  }\n  100% {\n    transform: rotate(360deg);\n  }\n}\n@-webkit-keyframes rotate {\n  0% {\n    -webkit-transform: rotate(0deg);\n  }\n  100% {\n    -webkit-transform: rotate(360deg);\n  }\n}\n.autosave-status.spinning .loading-indicator {\n  display: block;\n}\n`,"",{version:3,sources:["webpack://./React/Shared/Components/AutosaveStatus.less","webpack://./../../WebCore/css/Assets/Assets.less","webpack://./../../WebCore/css/Assets/Mixins.less"],names:[],mappings:"AAAA,+CAA+C;AAC/C,UAAU;ACcV;EACI,sDAAA;EACA,kGAAA;EACA,iGAAA;ADZJ;AACA,UAAU;AACV,kBAAkB;AAClB,6EAA6E;AAC7E,gBAAgB;AAChB,gCAAgC;AAChC,oBAAoB;AACpB,wBAAwB;AACxB,WAAW;AACX,yBAAyB;AACzB,oBAAoB;AACpB,mCAAmC;AACnC,cAAc;AACd,YAAY;AACZ,mDAAmD;AACnD,wBAAwB;AACxB,WAAW;AACX,gBAAgB;AAChB,WAAW;AACX,UAAU;AACV,mBAAmB;AACnB,WAAW;ACqPX;EACI,WAAA;ADnPJ;ACsPA;EACI,aAAA;ADpPJ;AEwIA;EACI,cAAA;EACA,YAAA;AFtIJ;AEyIA;EACI,WAAA;EACA,WAAA;AFvIJ;AE2QA;EACI,yBAAA;AFzQJ;AE4QA;EACI,mBAAA;EACA,gBAAA;EACA,uBAAA;AF1QJ;AE2RA;EACI,iBAAA;AFzRJ;AEwUA;EFtUE,yBAAyB;EEwUvB,qBAAA;EFtUF,YAAY;AACd;AEoUI;EAAuB,aAAA;AFjU3B;AAvDA;EAEI,kBAAA;AAwDJ;AA1DA;EAKQ,kBAAA;EACA,cAAA;EACA,WAAA;EACA,YAAA;EACA,gBAAA;AAwDR;AAjEA;EAcQ,aAAA;EACA,YAAA;EEkNJ,kBAAA;EAnOA,0BAAA;EACA,uBAAA;EACA,kBAAA;EAmOA,WAAA;EACA,YAAA;AFzJJ;AA3EA;EAoBQ,aAAA;EACA,kBAAA;EEmNJ,WAAA;EACA,UAAA;EACA,wBAAA;AFxJJ;AAzDI;EEsNA,WAAA;EACA,YAAA;EACA,gBAAA;AF1JJ;AA9DI;EE2NI,cAAA;EAnBJ,kBAAA;EAnOA,0BAAA;EACA,uBAAA;EACA,kBAAA;EAmOA,WAAA;EACA,YAAA;AFpIJ;AAvEI;EEgOI,kBAAA;EA3HJ,yDAAA;EACA,4BAAA;EACA,2BAAA;EAKA,WAAA;EACA,YAAA;EAkGA,WAAA;EACA,UAAA;EACA,wBAAA;AF/HJ;AEkJQ;EA/HJ,yDAAA;EACA,4BAAA;EACA,2BAAA;EAKA,WAAA;EACA,YAAA;EAsFA,oCAAA;EACA,4CAAA;AFzGJ;AEqFI;EACI;IACI,uBAAA;EFnFV;EEqFM;IACI,yBAAA;EFnFV;AACF;AEuFI;EACI;IACI,+BAAA;EFrFV;EEuFM;IACI,iCAAA;EFrFV;AACF;AA3GI;EAKQ,cAAA;AAyGZ",sourcesContent:['@import "../../../../../WebCore/css/Assets/Assets.less";\n@import "../../../../../WebCore/css/Assets/Mixins.less";\n\n@image-path: "../../../../../WebUI/Styles/Less/Application/Images/";\n\n.autosave-status\n{\n    position: relative;\n\n    .loading-block {\n        position: relative;\n        display: block;\n        width: 20px;\n        height: 20px;\n        overflow: hidden;\n    }\n\n    .branding-color-holders {\n        // Display none so that the branded background doesn\'t show through when not spinning\n        display: none;\n        margin: auto;\n        .color-holder(15px);\n    }\n\n    .loading-indicator {\n        display: none;\n        position: relative;\n        .indicator-border(10px, white);\n    }\n\n    &.spinning {\n        .small-loading-indicator(@spinner-small-white, @spinner-small-white-themable, white);\n        .loading-indicator {\n            // Display is set to none here when not spinning so the background circle doesn\'t show\n            // So we need to specify block when it is spinning\n            display: block;\n        }\n    }\n}\n','/* Constants / styles used across the product */\n\n/* Fonts */\n@font: Segoe UI, Helvetica, sans-serif;\n@font-semibold: Segoe UI Semibold, Helvetica Neue, Segoe UI, Helvetica, sans-serif;\n@font-light: Segoe UI Light, HelveticaNeue-Light, Segoe UI, Helvetica, sans-serif;\n.font-light() {\n    font-family: var(--panopto-font-family-light);\n    font-weight: 100; // FF doesn\'t include Segoe UI Light, font-weight lighter approximates it.\n}\n.font-semibold() {\n    font-family: var(--panopto-font-family-semibold);\n    font-weight: 600;\n}\n\n:root {\n    --panopto-font-family: @font;\n    --panopto-font-family-semibold: @font-semibold;\n    --panopto-font-family-light: @font-light;\n}\n\n@font-size-base: 16px;\n@font-size-medium: 1.45em;\n@font-size-large: 1.5em;\n@font-size-big-title: 1.7em;\n@font-size-small: .8em;\n@font-size-xsmall: .7em;\n@font-size-extra-large: 2.1em;\n@font-size-huge: 3.0em;\n// Our website uses this as its base\n@font-size-website-base: 13px;\n// These are basic font sizes used by the recorder. We should start making all of these consistent\n@font-size-title: 1.3em;\n@font-size-header: 1.2em;\n@font-size-command-button: 1.1em;\n@font-size-subtitle: .9em;\n@font-size-option: .8em;\n@font-size-button: .7em;\n\n@icon-size-without-text: 24px;\n@icon-size-with-text: 18px;\n\n/* Sizes */\n@site-min-width: 1004px;\n\n@small-logo-max-width: 265px;\n@small-logo-max-height: 23px;\n@large-logo-max-width: 340px;\n@large-logo-max-height: 50px;\n\n// Preferred hit target size for touch interfaces.\n@touch-target-size: 48px;\n// Smaller touch target size for tightly constrained contexts.\n@touch-target-size-small: 40px;\n\n@button-spacing: 10px;\n\n/* Page gradient */\n@page-gradient: linear-gradient(to bottom, #ffffff 0%, #f5f5f5 60%);\n\n/* Opacities of black (for consistent effect over gradient vs. fixed grays) */\n@darken-hovered: rgba(0, 0, 0, 0.03);\n@darken-selected: rgba(0, 0, 0, 0.06);\n@darken-selected-session: rgba(0, 0, 0, 0.05);\n\n/* Font Colors */\n@font-color-primary: #009900;\n@font-color-secondary: #466c2c;\n@font-color-link: #0F7395;\n\n@font-color-error: #990000;\n@font-color-dark: #000000;\n@font-color: #464646;\n@font-color-light: #777777;\n@font-color-lightest: #999999;\n@font-color-light-background: #b8b8b8;\n@font-light-gray: #aaaaaa;\n\n@font-color-black-80pct: rgba(0, 0, 0, 0.8);\n\n/* Font Colors (Accessibility) */\n@font-color-light-white-background: #767676;\n\n/* New font colors */\n@text-color-primary: rgba(0, 0, 0, .9);\n@text-color-secondary: rgba(0, 0, 0, .7);\n@text-color-on-accent: rgba(255, 255, 255);\n@text-color-additional: rgba(0, 0, 0, .6);\n\n@icon-color-primary: rgba(0, 0, 0, .8);\n@icon-color-secondary: rgba(0, 0, 0, .6);\n@icon-color-additional: rgba(0, 0, 0, .5);\n\n@border-color-primary: rgba(0, 0, 0, .1);\n\n@background-hover: rgba(0, 0, 0, .05);\n@background-active: rgba(0, 0, 0, .1);\n\n/* "Dark Theme" Colors */\n@overlay-background-color: rgba(0, 0, 0, 0.8);\n@icon-color-dark-theme: rgba(255, 255, 255, 0.8);\n@icon-color-active-dark-theme: white;\n@tab-highlight-color-dark-theme: rgba(255, 255, 255, 0.8);\n@border-color-dark-theme: rgba(255, 255, 255, 0.2);\n@font-color-dark-theme: rgba(255, 255, 255, 1);\n@font-color-secondary-dark-theme: rgba(255, 255, 255, 0.8);\n@hover-background-color-dark-theme: rgba(255, 255, 255, 0.1);\n@contrast-background-color-dark-theme: rgba(255, 255, 255, 0.2);\n\n/* Colors */\n@blue-selected: #aedcf1;\n\n@white-bright: #e6e6e6;\n@pure-white: #ffffff;\n\n@red: #bd4f4f;\n@red-medium: #a04242;\n@red-dark: #8c3939;\n@red-light: #ebcaca;\n@red-bright: #dd3217;\n\n@green: #54bf6d;\n@green-medium: #1d8f37;\n@green-dark: #185e0d;\n@green-light: #92c88a;\n@green-background: #eef5f0;\n@green-sunny: #719f46;\n@green-shady: #48761d;\n\n// Branded Panopto Green. Do _NOT_ use this for areas that should be affected by branding\n@panopto-green: #30733F;\n\n@icon-color: #626262;\n@header-color: #f5f5f5;\n@header-dropdown-background-color: White;\n@focused-background-color: #e8e8e8;\n@gray-border: #e0e0e0;\n@gray-light: #d6d6d6;\n@gray-hover: #f0f0f0;\n@gray-very-light: #f2f2f2;\n@gray-hint: #f5f5f5;\n@gray-press: #cccccc;\n@gray-dark: #999999;\n@gray-header: #666;\n@gray-shadow: #888;\n@gray-future: #f2f2f2;\n@dark-selected: #8b8b8b;\n@gray-divider: #989898;\n@light-selected: #dbdbdb;\n@gray-silver: #e7e7e7;\n@gray-disabled: #ebebe4;\n@gray-button-hover: #e5e5e5;\n@gray-transparent: rgba(0,0,0,0.2);\n@gray-transparent-subtle: rgba(0,0,0,0.1);\n@gray-transparent-light: rgba(0,0,0,0.3);\n@gray-transparent-medium: rgba(0,0,0,0.5);\n@gray-transparent-dark: rgba(0,0,0,0.6);\n@gray-dark-shadow: rgba(0,0,0,0.7);\n@gray-darker-shadow: rgba(0,0,0,0.8);\n@gray-watermark: gray;\n@letterbox-color: black;\n@rr-letterbox-color: #3f3f3f;\n@material-box-shadow: 0 6px 10px 0 rgba(0,0,0,.14),\n                      0 1px 18px 0 rgba(0,0,0,.12),\n                      0 3px 5px -1px rgba(0,0,0,.20);\n\n@background-warning: orange;\n\n@yellow: #feffc9;\n\n@stored-quota-foreground: #B56F90;\n@stored-quota-background: #B56F90;\n@delivered-quota-foreground: #4798D0;\n@delivered-quota-background: #4798D0;\n\n@drop-target-background: rgba(231, 239, 254, 0.5);\n@drop-target-background-invalid: fadeout(white, 20%);\n@drop-target-border: fadeout(#4384f4, 57%);\n\n/* For gradient buttons */\n\n/* Small Thumbnail */\n@small-thumbnail-cell-width: 120px;\n@small-thumbnail-height: 60px;\n@small-thumbnail-width: (16 / 9) * @small-thumbnail-height;\n\n/* Volume preview specific colors */\n@neutral-color: #0098cc;\n@loud-color: #9d0b0b;\n@quiet-color: #ffa900;\n@neutral-text-color: #019acd;\n@loud-text-color: #8a1d1d;\n@quiet-text-color: #d08e0b;\n@loud-warning-color: #cf8787;\n@quiet-warning-color: #ffd57f;\n@loud-border: #7fcce6;\n\n/* Opacities */\n@button-opacity: .6;\n@button-hover-opacity: .8;\n@button-active-opacity: 1.0;\n@button-disabled: .3;\n\n/* Borders */\n@input-border-edit: 1px solid #959595;\n@input-border-hover: 1px solid #cdcdcd;\n@input-border-white: 1px solid White;\n@header-dropdown-border: 1px solid #cccccc;\n@input-border-light: 1px solid #cccccc;\n@input-border-extra-light: 1px solid @gray-border;\n/* Input Border Color (WCAG 1.4.11 Accessibility) */\n@input-border-color: #8C8C8C;\n\n/* Common measurements */\n\n// The height of most of our modal inputs\n@input-height: 28px;\n\n/* Images */\n@spinner-path: "Spinner/";\n@spinner-large: "large-comet-animation-grey.gif";\n@spinner-small-white: "spinner_small_white.gif";\n@spinner-small-beige: "spinner_small_eee.gif";\n\n@spinner-large-themable: "spinner_large_themable.png";\n@spinner-small-white-themable: "spinner_small_themable_white.png";\n@spinner-small-beige-themable: "spinner_small_themable_eee.png";\n@spinner-small-gray-themable: "spinner_small_themable_e0e0e0.png";\n\n/* Transitions */\n@viewer-transition: all .125s ease-in-out;\n\n/* Mobile */\n\n// Google recommends a base of 16px\n// https://developers.google.com/speed/docs/insights/UseLegibleFontSizes?hl=en\n@mobile-base-size: 16px;\n\n// Maybe we want to change this to a hex code later\n// so for now use yellow and we can change it easier\n@mobile-font-warning: yellow;\n@mobile-background-disabled: rgb(187, 187, 187);\n\n// Mobile query constants\n\n// "almost" is one less then actual width,\n// "almost" queries should be used for max-width \n// actual queries should be used for min-width\n// By keeping those consistent we can be sure that the layout\n// doesn\'t do funky things on the pixel between the two\n// and we won\'t need to consider which media query comes first\n// NOTE: The parens around the following bits are necessary, LESS generates invalid CSS without them.\n@ipad4-portrait-width: 320px;\n@iphone5-landscape-width: 568px;\n@iphone6-portrait-width: 375px;\n\n@almost-iphone6-portrait-width: (@iphone6-portrait-width - 1);\n\n@ipad-mini-portrait-width: 768px;\n@almost-ipad-mini-portrait-width: (@ipad-mini-portrait-width - 1);\n\n@nexus7-landscape-width: 960px;\n@almost-nexus7-landscape-width: (@nexus7-landscape-width - 1);\n\n/* Embed */\n@defaultEmbedWidth: 720px;\n@defaultEmbedHeight: 405px;\n\n/* Material icons */\n@checkbox-glyph-inset: 3px;\n\n/* Resets */\nbody {\n    margin: 0px;\n}\n\n.clicked {\n    outline: none;\n}\n','@small-loading-indicator-length: 16px;\n\n.border-radius (@radius) {\n    -webkit-border-radius: @radius;\n    -moz-border-radius: @radius;\n    border-radius: @radius;\n}\n\n.box-sizing (@sizing) {\n    box-sizing: @sizing;\n    -moz-box-sizing: @sizing;\n}\n\n// Prevents anti aliasing\n// http://stackoverflow.com/questions/14068103/disable-antialising-when-scaling-images\n.prevent-anti-aliasing () {\n    // The browser will ignore the lines it can\'t understand\n    // and so it works to have the same property listed multiple times\n    image-rendering: optimizeSpeed;\n    image-rendering: -moz-crisp-edges;\n    image-rendering: -o-crisp-edges;\n    image-rendering: -webkit-optimize-contrast;\n    image-rendering: pixelated;\n    image-rendering: optimize-contrast;\n}\n\n.user-select(@select) {\n    -webkit-touch-callout: @select;\n    -webkit-user-select: @select;\n    -khtml-user-select: @select;\n    -moz-user-select: @select;\n    user-select: @select;\n}\n\n.background-image-gradient (@deg, @color-bottom, @color-top) {\n    background-image: -webkit-linear-gradient(@deg, @color-bottom 0%, @color-top 100%);\n    background-image: -moz-linear-gradient(@deg, @color-bottom 0%, @color-top 100%);\n}\n\n.background-complex-gradient (@deg, @color-first, @color-second, @color-third, @color-fourth) {\n    background-image: -webkit-linear-gradient(@deg, @color-first, @color-second, @color-third, @color-fourth);\n    background-image: -moz-linear-gradient(@deg, @color-first, @color-second, @color-third, @color-fourth);\n}\n\n// Block-level elements with known dimensions can be centered within positioned parents.\n.center-block(@width, @height, @h-offset: 0, @v-offset: 0) {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    // Block origin is centered by the above, shift by half height / width to align block center with container center.\n    margin-left: -(@width / 2) + @h-offset;\n    margin-top: -(@height / 2) + @v-offset;\n    width: @width;\n    height: @height;\n}\n\n.clickable () {\n    &:hover {\n        cursor: pointer;\n    }\n}\n\n.access-icons(@length) {\n    .access-item-icon(@image) {\n        .icon("Share/", @image, @length, @length);\n    }\n\n    &.invite {\n        .access-item-icon("icon_email.png");\n    }\n\n    &.group {\n        .access-item-icon("icon_group.png");\n    }\n\n    &.user {\n        .access-item-icon("icon_user.png");\n    }\n}\n\n.pressable (@background-highlight, @background-pressed, @cursor: default) {\n    &:hover {\n        background-color: @background-highlight;\n        cursor: @cursor;\n    }\n    &:focus {\n        background-color: @background-highlight;\n    }\n    &:active {\n        background-color: @background-pressed;\n    }\n}\n\n.hoverable (@background-highlight, @background-pressed, @cursor: default) {\n    .transition(background-color .15s);\n    &:hover {\n        background-color: @background-highlight;\n        cursor: @cursor;\n        .transition(background-color .15s);\n    }\n    &:active {\n        background-color: @background-pressed;\n        .transition(background-color .15s);\n    }\n}\n\n// @child-class-string needs to the the class selector without the \'.\', LESS allows us to pass strings but not complete selectors\n// http://stackoverflow.com/questions/19602812/less-mixin-a-variable-class-name\n.hoverable-child (@child-class-string, @background-parent-highlight, @background-child-highlight, @background-pressed, @cursor: default) {\n    &:hover .@{child-class-string} {\n        background-color: @background-parent-highlight;\n        .transition(background-color .15s);\n    }\n    .@{child-class-string} {\n        .hoverable(@background-child-highlight, @background-pressed, @cursor);\n    }\n}\n\n.hoverable-opacity() {\n    opacity: @button-opacity;\n\n    &:hover, &:focus {\n        opacity: @button-hover-opacity;\n    }\n\n    &:active {\n        opacity: @button-active-opacity;\n    }\n}\n\n.background-image(@root, @image, @repeat: no-repeat, @align: center) {\n    background-image: ~"url(\'@{image-path}@{root}@{image}\')";\n    background-repeat: @repeat;\n    background-position: @align;\n}\n\n.icon (@root, @image, @width: auto, @height: auto, @repeat: no-repeat, @align: center) {\n    .background-image(@root, @image, @repeat, @align);\n    width: @width;\n    height: @height;\n}\n\n.transition(@params) {\n    -webkit-transition: @params;\n    -moz-transition: @params;\n    -o-transition: @params;\n    transition: @params;\n}\n\n.transform(@params) {\n    transform: @params;\n    -webkit-transform: @params;\n}\n\n.pressable-icon(@root, @image, @image-hover, @image-press, @width: auto, @height: auto, @repeat: no-repeat, @align: center) {\n    .icon(@root, @image, @width, @height, @repeat, @align);\n\n    &:hover {\n        .icon(@root, @image-hover, @width, @height, @repeat, @align);\n        cursor: default;\n    }\n    &:focus {\n        .icon(@root, @image-hover, @width, @height, @repeat, @align);\n    }\n    &:active {\n        .icon(@root, @image-press, @width, @height, @repeat, @align);\n    }\n}\n\n.break {\n    display: block;\n    height:  15px;\n}\n\n.clear {\n    clear: both;\n    height: 0px;\n}\n\n.box-shadow(none) {\n    -webkit-box-shadow: none;\n    -moz-box-shadow: none;\n    box-shadow: none;\n}\n\n.box-shadow(@color, @h-shadow, @v-shadow, @blur, @spread) {\n    -webkit-box-shadow: @color @h-shadow @v-shadow @blur @spread;\n    -moz-box-shadow: @color @h-shadow @v-shadow @blur @spread;\n    box-shadow: @color @h-shadow @v-shadow @blur @spread;\n}\n\n.box-shadow-inset(@color, @h-shadow, @v-shadow, @blur, @spread) {\n    -webkit-box-shadow: @color @h-shadow @v-shadow @blur @spread inset;\n    -moz-box-shadow: @color @h-shadow @v-shadow @blur @spread inset;\n    box-shadow: @color @h-shadow @v-shadow @blur @spread inset;\n}\n\n.borders(@top-color, @right-color, @bottom-color, @left-color) {\n    border-top:1px solid @top-color;\n    border-right: 1px solid @right-color;\n    border-bottom:1px solid @bottom-color;\n    border-left:1px solid @left-color;\n}\n\n.rotating-animation() {\n    // IE and FF support the w3 standard keyframes\n    @keyframes rotate {\n        0% {\n            transform: rotate(0deg);\n        }\n        100% {\n            transform: rotate(360deg);\n        }\n    }\n\n    // Chrome and Safari need special webkit\n    @-webkit-keyframes rotate {\n        0% {\n            -webkit-transform: rotate(0deg);\n        }\n        100% {\n            -webkit-transform: rotate(360deg);\n        }\n    }\n\n    animation: rotate 2s linear infinite;\n    -webkit-animation: rotate 2s linear infinite;\n}\n\n.color-holder(@diameter) {\n    position: absolute;\n    .border-radius(50%); // Circle\n    width: @diameter;\n    height: @diameter;\n}\n\n.indicator-border(@border-size, @color){\n    left: -@border-size;\n    top: -@border-size;\n    border: @border-size solid @color;\n}\n\n.small-loading-indicator(@image-grey, @image-themed, @border-color) {\n    @small-length: @small-loading-indicator-length;\n    width: @small-length;\n    height: @small-length;\n    overflow: hidden;\n\n    .branding-color-holders {\n        display: block;\n       .color-holder(15px);\n    }\n\n    .loading-indicator {\n        position: relative;\n        .icon(@spinner-path, @image-grey, @small-length, @small-length);\n        .indicator-border(10px, @border-color);\n\n        &.branded-animation {\n            // The "- 1" fixes a samll issue in Chrome where the when zoomed to 90% you could see a second spinner\n            .icon(@spinner-path, @image-themed, @small-length - 1, @small-length - 1);\n            .rotating-animation();\n        }\n    }\n}\n\n.opacity(@opacity) {\n    opacity: @opacity;\n    @percent: @opacity * 100;\n    // IE8 and below\n    filter: alpha(opacity=@percent);\n}\n\n.horizontal-rule(@color) {\n    display: block;\n    border-bottom: 1px solid @color;\n}\n\n.popup(@z-index) {\n    z-index: @z-index;\n    .box-shadow(@gray-dark, 2px, 3px, 5px, 0);\n    border: @header-dropdown-border;\n    background-color: @header-dropdown-background-color;\n    position: absolute;\n    text-align: left;\n\n    .popup-title {\n        color: @font-color;\n        font-weight: bold;\n    }\n}\n\n.header-dropdown() {\n    .popup(100003);\n\n    > a, > div {\n        &:hover {\n            background-color: @gray-hover;\n            cursor: default;\n        }\n        &:active {\n            background-color: @gray-press;\n        }\n        text-decoration: none;\n        display: block;\n    }\n}\n\n.error {\n    color: @font-color-error !important;\n}\n\n.ellipsis {\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n}\n\n// @lines is honored on WebKit.\n// @max-height provides a fallback on other browsers (simple vertical truncation).\n.multiline-ellipsis (@lines, @max-height) {\n    // On WebKit, show ellipsis after two lines if text is longer.\n    display: -webkit-box;\n    -webkit-line-clamp: @lines;\n    -webkit-box-orient: vertical;\n    // For non-WebKit browsers, just crop lines beyond the second (no ellipsis).\n    max-height: @max-height;\n    overflow: hidden;\n    // Override "nowrap" behavior of .ellipsis (typically also present for tooltips) to enable wrapping to additional lines.\n    white-space: normal;\n}\n\n.attention {\n    font-weight: bold;\n}\n\n\n// Styles a div as a table row, with direct div children as cells\n.table-row (@width: 100%, @align: top) {\n    display: table;\n    width: @width;\n\n    > div, > a, > img, > i {\n        display: table-cell;\n        vertical-align: @align;\n    }\n}\n\n// Styles any element to look and behavior like a link\n.link (@cursor: pointer, @color: @font-color-link) {\n    color: @color;\n    text-decoration: none;\n\n    &:hover, &:focus {\n        cursor: @cursor;\n        text-decoration: underline;\n    }\n}\n\n// Creates a thin, two-tone scrollbar (plain thumb on plain track), where supported by the browser.\n// Width is 8px on Webkit, "thin" on FF (works out to similar), and full width on other browsers.\n// Webkit thumb will have a 5px border-radius (others will have square edges).\n.custom-scrollbar(@thumb-color, @track-color) {\n    @supports not selector(::-webkit-scrollbar) {\n        scrollbar-width: thin;\n        scrollbar-color: @thumb-color @track-color;\n    }\n\n    &::-webkit-scrollbar {\n        background-color: @track-color;\n        width: 8px;\n        height: 8px;\n    }\n\n    &::-webkit-scrollbar-thumb {\n        background-color: @thumb-color;\n        border-radius: 5px;\n    }\n}\n\n.hidden-scrollbar {\n    &::-webkit-scrollbar { display: none; } /* Chrome/Safari/Webkit */\n    scrollbar-width: none; /* Firefox */\n}\n\n.edit-control() {\n    padding: 2px;\n    bottom: 0px;\n    right: 0px;\n    z-index: 1;\n    background-color: white;\n\n    > div {\n        .link;\n        display: inline-block;\n        padding: 3px 8px 4px 8px;\n        border: 1px solid @gray-press;\n        background-color: white;\n    }\n}\n\n.viewer-message() {\n    margin: 20px auto 0px auto;\n    text-align: center;\n    // This is the size used in Viewer.less\n    // repeated here to make this consistent between pages\n    font-size: medium;\n\n    #messageText {\n        padding: 10px;\n    }\n\n    #messageLink {\n        padding: 0px 10px 10px 10px;\n    }\n}\n\n.role-select(@width, @margin-top) {\n    font-family: @font;\n    width: @width;\n    height: 38px;\n    margin-top: @margin-top;\n    padding: 6px;\n    font-size: @font-size-base;\n    .border-radius(4px);\n    color: @font-color-light;\n    display: block;\n    vertical-align: top;\n}\n\n// Shared thumbnail styles\n.thumbnail(@thumbnail-width-param: 196px, @thumbnail-height-param: 110px) {\n    // This is necessary to surface these params in the enclosing scope of the mixin.\n    @thumbnail-width: @thumbnail-width-param;\n    @thumbnail-height: @thumbnail-height-param;\n    @thumbnail-border: 1px;\n    @overlay-margin: 2px;\n\n    .thumbnail-container {\n        // Provide a positioning context for thumbnail overlays\n        position: relative;\n        width: @thumbnail-width;\n        height: @thumbnail-height;\n        border: @thumbnail-border solid @gray-border;\n        .border-radius(3px);\n        background: black;\n        // Prevent child image from bleeding out of the rounded corners\n        overflow: hidden;\n\n        // Give linked thumbnails a darkened border on hover\n        &.viewable:hover {\n            border: @thumbnail-border solid @gray-dark;\n        }\n\n        // Show link or span depending on "viewable" class on container\n        .thumbnail-span,\n        &.viewable .thumbnail-link {\n            display: block;\n        }\n        .thumbnail-link,\n        &.viewable .thumbnail-span {\n            display: none;\n        }\n\n        // Needed to enable "height/width: 100%" to work on ".thumbnail-img/-failed-load" below\n        .thumbnail-link,\n        .thumbnail-span {\n            width: 100%;\n            height: 100%;\n        }\n\n        .thumbnail-img,\n        .thumbnail-failed-load {\n            // Necessary for horizontal centering, correct focus outlines, etc.\n            display: block;\n            // Start by fitting height and allowing width to scale with thumbnail aspect ratio.\n            // Aspect ratios wider than 16:9 are handled in JS by Panopto.Util.fitThumbnailWidth().\n            // Once we drop IE8 we can use background-size: contain for a pure CSS solution.\n            width: auto;\n            height: 100%;\n            // Center the thumbnail horizontally within the container if it\'s narrower than 16:9\n            margin: auto;\n            // Prevent image link border in older IE\n            border: none;\n            // Prevent browser default behavior for dragging images to enable session drag from thumb.\n            pointer-events: none;\n        }\n\n        // Show duration in an overlay at the bottom right of the thumbnail\n        .duration {\n            .overlay();\n            .border-radius(1px);\n            bottom: @overlay-margin;\n            right: @overlay-margin;\n            font-size: @font-size-subtitle;\n        }\n\n        .playlist {\n            .overlay();\n            .border-radius(1px);\n            top: 0;\n            right: 0;\n            height: @thumbnail-height;\n            line-height: @thumbnail-height;\n            text-align: center;\n            padding: 0 5px;\n\n            // Give the playlist overlay a bit of default width so shorter languages don\'t look goofy\n            min-width: 40%;\n\n            // This works around issues with our "line-height"-based vertical centering hack when on a page with an\n            // XHTML 1.0 doctype (resulting in "Almost Standards Mode").\n            &::before,\n            &::after {\n                content: \'\';\n                display: inline-block;\n                vertical-align: middle;\n            }\n\n            // Handle vertical centering of text;\n            .playlist-text {\n                @height-adjustment: 10px;\n                display: inline-block;\n                vertical-align: middle;\n                // Adjust the height between the icon and text\n                line-height: @height-adjustment;\n                // Fix the vertical centering of the text\n                margin-top: -@height-adjustment;\n                font-size: @font-size-website-base;\n            }\n        }\n\n        .completion-overlay {\n            position: absolute;\n            bottom: 0;\n            height: 4px;\n            width: 100%;\n            background: @gray-press;\n\n            // Width is set in script in `itemRendered` callbacks in SessionList.ts and HomeUtils.ts.\n            // Color is set to brand color via .accent-background.\n            .progress {\n                height: 100%;\n            }\n        }\n\n        .archived-overlay {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            display: flex;\n            align-items: center;\n            justify-content: space-around;\n            align-content: space-around;\n            // Control opacity through the backgroun so the text is fully opaque.\n            background: rgba(255, 255, 255, 0.8);\n            color: @icon-color;\n            pointer-events: none;\n        }\n    }\n\n    // Mixin for info overlays on .thumbnail-container (white text on translucent black background)\n    .overlay() {\n        position: absolute;\n        // IE8 fallback (doesn\'t support rgba)\n        background: black;\n        background: rgba(0, 0, 0, 0.7);\n        padding: 1px 3px;\n        color: white;\n        cursor: default;\n        // Enable mouse events to pass through to the underlying thumbnail link / span (NOTE: not supported on IE10-)\n        pointer-events: none;\n    }\n}\n\n// Shared caption option styles\n.caption-options(@asset-path, @item-size, @item-padding, @item-border, @docked-icon-size) {\n    .user-select(none);\n\n    li {\n        // override box-sizing: border-box set on fullscreen options\n        box-sizing: content-box;\n        display: block;\n        float: left;\n        margin-left: 5px;\n        width: @item-size;\n        height: @item-size;\n        // Line height needs to consider padding to align with the width\n        line-height: @item-size - (2 * @item-padding);\n        text-align: center;\n        cursor: pointer;\n        padding: @item-padding;\n\n        // Use a transparent border when not selected to avoid reflow on selection\n        border-width: @item-border;\n        border-style: solid;\n        border-color: transparent;\n    }\n\n    // Color samples have a border color to display as well\n    li .color-sample {\n        border-width: 1px;\n        border-style: solid;\n    }\n\n    .transparent-background {\n        .icon(@asset-path, "checker.png");\n        background-position: left top;\n    }\n\n    .placement-option {\n        // Override the default explicit size to the image\n        width: auto;\n        height: auto;\n    }\n\n    // Docked image icon\n    .Docked div {\n        .icon(@asset-path, "icon_position_Docked.png", @docked-icon-size, @docked-icon-size);\n    }\n\n    // Overlay image icon\n    .Overlay div {\n        .icon(@asset-path, "icon_position_Overlay.png", @docked-icon-size, @docked-icon-size);\n    }\n}\n\n.dialog-triangle() {\n    // These are styles to position and scale unicode triangle character for a dialog\n    position: absolute;\n    display: block;\n    color: white;\n    z-index: 1000;\n    margin-left: -10px;\n    margin-top: -11px;\n    font-size: 1.5em;\n    .transform(scaleX(1.5));\n    cursor: default;\n}\n\n// Used to place an opaque overlay on the screen\n.screen-overlay() {\n    display: none;\n    position: fixed;\n    top: 0; left: 0; right: 0; bottom: 0;\n    background-color: black;\n    @opacity: 70;\n    opacity: (@opacity / 100);\n    filter: alpha(opacity=@opacity); // IE8 hack. "opacity" supported in IE9+\n    z-index: 999;\n}\n\n// Used to vertically align material icons nicely beside text\n.material-icon-beside-text() {\n    // Align the material icon with the text\n    vertical-align: middle;\n    // Underlining material design icons doesn\'t render nicely\n    text-decoration: none;\n    // Give the icon a little space from the title\n    padding-right: 3px;\n}\n\n.folder-header-icon(@width, @height, @icon) {\n    .icon(@asset-path, @icon, @width, @height);\n    float: left;\n    margin-right: 10px;\n}\n\n// Used for close buttons that use the "close"/x material icon\n.close-button (@size) {\n    display: block;\n    text-decoration: none;\n    color: @font-color-light;\n    font-size: @size;\n\n    .hoverable(@gray-transparent, @gray-transparent-dark);\n\n    &:active {\n        color: white;\n    }\n}\n\n.speech-bubble() {\n    @padding: 10px;\n    @border-width: 1px;\n    @background-color: white;\n    position: relative;\n    background-color: @background-color;\n    border: @border-width solid @gray-border;\n    border-radius: 3px;\n    border-bottom-left-radius: 0px;\n    padding: @padding;\n\n    &:before {\n        content: "";\n        position: absolute;\n        top: 100%;\n        left: 0px - @border-width;\n        width: 0px;\n        display: block;\n        border-width: 20px 20px 0 0;\n        border-style: solid;\n        border-color: @gray-border transparent;\n    }\n\n    &:after {\n        content: "";\n        position: absolute;\n        top: 100%;\n        left: 0px;\n        width: 0px;\n        display: block;\n        border-width: 17px 17px 0 0;\n        border-style: solid;\n        border-color: @background-color transparent;\n    }\n}\n\n.flat-button() {\n    display: inline-block;\n    padding: 6px 9px 8px 9px;\n    .border-radius(3px);\n    background-color: @header-color;\n    cursor: pointer;\n    text-decoration: none;\n    font-weight: 600;\n    color: @font-color;\n    text-align: center;\n    border: 1px solid @gray-light;\n\n    &.safety-background {\n        color: white;\n        border: 0px;\n        padding: 7px 10px 9px 10px;\n    }\n\n    &:hover, &:active {\n        text-decoration: none;\n    }\n}\n\n.copyright-warning() {\n    font-size: @font-size-small;\n    color: @font-color-light-white-background;\n    text-align: center;\n    padding: 20px;\n}\n\n.material-checkbox(\n    @color: @icon-color,\n    @background: rgba(255, 255, 255, 0.85)\n) {\n    -webkit-appearance: unset;\n    -moz-appearance: none;\n    position: relative;\n    color: @color;\n\n    // Remove border and background color as they still show up on Mobile Safari\n    // even with appearance unset\n    border: none;\n    background-color: transparent;\n\n    &::before {\n        content: "";\n        position: absolute;\n        top: @checkbox-glyph-inset;\n        right: @checkbox-glyph-inset;\n        bottom: @checkbox-glyph-inset;\n        left: @checkbox-glyph-inset;\n        border-radius: 3px;\n        background: @background;\n    }\n\n    &::after {\n        content: "check_box_outline_blank";\n        position: absolute;\n    }\n    &:checked::after {\n        content: "check_box";\n    }\n}\n\n.material-radio(\n    @color: @icon-color,\n    @background: rgba(255, 255, 255, 0.85)\n) {\n    -webkit-appearance: unset;\n    -moz-appearance: none;\n    position: relative;\n    color: @color;\n\n    // Remove border and background color as they still show up on Mobile Safari\n    // even with appearance unset\n    border: none;\n    background-color: transparent;\n\n    &::before {\n        content: "";\n        position: absolute;\n        top: @checkbox-glyph-inset;\n        right: @checkbox-glyph-inset;\n        bottom: @checkbox-glyph-inset;\n        left: @checkbox-glyph-inset;\n        border-radius: 3px;\n        background: @background;\n    }\n\n    &::after {\n        content: "radio_button_unchecked";\n        position: absolute;\n    }\n    &:checked::after {\n        content: "radio_button_checked";\n    }\n}\n\n.placeholder(@rules) {\n    &::placeholder {\n        @rules();\n    }\n}\n\n.material-select() {\n    background: url(data:image/svg+xml;base64,) no-repeat right 2px center;\n    -moz-appearance: none; \n    -webkit-appearance: none; \n    appearance: none;\n}\n\n.clear-search-icon() {\n    @icon-size: 18px;\n    .icon("Widgets/", "icon_cancel.svg", @icon-size, @icon-size, no-repeat);\n    background-size: @icon-size;\n}\n'],sourceRoot:""}]);const u=/^((10|367|819)3|3180|4044|6116)$/.test(t.j)?p:null},20326(e,n,t){"use strict";t.d(n,{A:()=>s});var o=t(82001),r=t.n(o),i=t(40935),a=t.n(i)()(r());a.push([e.id,'/* Constants / styles used across the product */\n/* Fonts */\n:root {\n  --panopto-font-family: Segoe UI, Helvetica, sans-serif;\n  --panopto-font-family-semibold: Segoe UI Semibold, Helvetica Neue, Segoe UI, Helvetica, sans-serif;\n  --panopto-font-family-light: Segoe UI Light, HelveticaNeue-Light, Segoe UI, Helvetica, sans-serif;\n}\n/* Sizes */\n/* Page gradient */\n/* Opacities of black (for consistent effect over gradient vs. fixed grays) */\n/* Font Colors */\n/* Font Colors (Accessibility) */\n/* New font colors */\n/* "Dark Theme" Colors */\n/* Colors */\n/* For gradient buttons */\n/* Small Thumbnail */\n/* Volume preview specific colors */\n/* Opacities */\n/* Borders */\n/* Input Border Color (WCAG 1.4.11 Accessibility) */\n/* Common measurements */\n/* Images */\n/* Transitions */\n/* Mobile */\n/* Embed */\n/* Material icons */\n/* Resets */\nbody {\n  margin: 0px;\n}\n.clicked {\n  outline: none;\n}\n.break {\n  display: block;\n  height: 15px;\n}\n.clear {\n  clear: both;\n  height: 0px;\n}\n.error {\n  color: #990000 !important;\n}\n.ellipsis {\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n.attention {\n  font-weight: bold;\n}\n.hidden-scrollbar {\n  /* Chrome/Safari/Webkit */\n  scrollbar-width: none;\n  /* Firefox */\n}\n.hidden-scrollbar::-webkit-scrollbar {\n  display: none;\n}\n.breadcrumbs .breadcrumb-link {\n  color: #464646;\n  text-decoration: none;\n}\n.breadcrumbs .breadcrumb-link:hover,\n.breadcrumbs .breadcrumb-link:focus {\n  cursor: pointer;\n  text-decoration: underline;\n}\n.breadcrumbs .material-icons {\n  padding-right: 6px;\n  color: #626262;\n}\n.breadcrumbs .breadcrumb-separator {\n  padding-left: 6px;\n}\n.breadcrumbs .breadcrumb-icon {\n  padding-right: 6px;\n  width: 24px;\n  height: 24px;\n}\n.breadcrumbs.branded-header-breadcrumbs .breadcrumb-link {\n  color: white;\n  text-decoration: none;\n}\n.breadcrumbs.branded-header-breadcrumbs .breadcrumb-link:hover,\n.breadcrumbs.branded-header-breadcrumbs .breadcrumb-link:focus {\n  cursor: pointer;\n  text-decoration: underline;\n}\n.breadcrumbs.branded-header-breadcrumbs .material-icons {\n  color: white;\n}\n.breadcrumbs.branded-header-breadcrumbs .breadcrumb-separator {\n  position: relative;\n  top: 5px;\n}\n.breadcrumbs.branded-header-breadcrumbs [aria-current="page"] {\n  font-family: var(--panopto-font-family-semibold);\n  font-weight: 600;\n}\n',"",{version:3,sources:["webpack://./React/Shared/Components/Breadcrumbs.less","webpack://./../../WebCore/css/Assets/Assets.less","webpack://./../../WebCore/css/Assets/Mixins.less"],names:[],mappings:"AAAA,+CAA+C;AAC/C,UAAU;ACcV;EACI,sDAAA;EACA,kGAAA;EACA,iGAAA;ADZJ;AACA,UAAU;AACV,kBAAkB;AAClB,6EAA6E;AAC7E,gBAAgB;AAChB,gCAAgC;AAChC,oBAAoB;AACpB,wBAAwB;AACxB,WAAW;AACX,yBAAyB;AACzB,oBAAoB;AACpB,mCAAmC;AACnC,cAAc;AACd,YAAY;AACZ,mDAAmD;AACnD,wBAAwB;AACxB,WAAW;AACX,gBAAgB;AAChB,WAAW;AACX,UAAU;AACV,mBAAmB;AACnB,WAAW;ACqPX;EACI,WAAA;ADnPJ;ACsPA;EACI,aAAA;ADpPJ;AEwIA;EACI,cAAA;EACA,YAAA;AFtIJ;AEyIA;EACI,WAAA;EACA,WAAA;AFvIJ;AE2QA;EACI,yBAAA;AFzQJ;AE4QA;EACI,mBAAA;EACA,gBAAA;EACA,uBAAA;AF1QJ;AE2RA;EACI,iBAAA;AFzRJ;AEwUA;EFtUE,yBAAyB;EEwUvB,qBAAA;EFtUF,YAAY;AACd;AEoUI;EAAuB,aAAA;AFjU3B;AAvDA;EEyVI,cAAA;EACA,qBAAA;AF/RJ;AEiSI;;EACI,eAAA;EACA,0BAAA;AF9RR;AAhEA;EAMQ,kBAAA;EACA,cAAA;AA6DR;AApEA;EAWQ,iBAAA;AA4DR;AAvEA;EAeQ,kBAAA;EACA,WAAA;EACA,YAAA;AA2DR;AAxDI;EEqUA,YAAA;EACA,qBAAA;AF1QJ;AE4QI;;EACI,eAAA;EACA,0BAAA;AFzQR;AAjEI;EAMQ,YAAA;AA8DZ;AApEI;EAUQ,kBAAA;EACA,QAAA;AA6DZ;AAxEI;ECdA,gDAAA;EACA,gBAAA;ADyFJ",sourcesContent:['@import "../../../../../WebCore/css/Assets/Assets.less";\n@import "../../../../../WebCore/css/Assets/Mixins.less";\n\n@breadcrumb-padding: 6px;\n\n.breadcrumbs {\n    .breadcrumb-link {\n        .link(@color: @font-color);\n    }\n\n    .material-icons {\n        padding-right: @breadcrumb-padding;\n        color: @icon-color;\n    }\n\n    .breadcrumb-separator {\n        padding-left: @breadcrumb-padding;\n    }\n\n    .breadcrumb-icon {\n        padding-right: @breadcrumb-padding;\n        width: 24px;\n        height: 24px;\n    }\n\n    &.branded-header-breadcrumbs {\n        .breadcrumb-link {\n            .link(@color: white);\n        }\n\n        .material-icons {\n            color: white;\n        }\n\n        .breadcrumb-separator {\n            position: relative;\n            top: 5px;\n        }\n\n        [aria-current="page"] {\n            .font-semibold();\n        }\n    }\n}\n','/* Constants / styles used across the product */\n\n/* Fonts */\n@font: Segoe UI, Helvetica, sans-serif;\n@font-semibold: Segoe UI Semibold, Helvetica Neue, Segoe UI, Helvetica, sans-serif;\n@font-light: Segoe UI Light, HelveticaNeue-Light, Segoe UI, Helvetica, sans-serif;\n.font-light() {\n    font-family: var(--panopto-font-family-light);\n    font-weight: 100; // FF doesn\'t include Segoe UI Light, font-weight lighter approximates it.\n}\n.font-semibold() {\n    font-family: var(--panopto-font-family-semibold);\n    font-weight: 600;\n}\n\n:root {\n    --panopto-font-family: @font;\n    --panopto-font-family-semibold: @font-semibold;\n    --panopto-font-family-light: @font-light;\n}\n\n@font-size-base: 16px;\n@font-size-medium: 1.45em;\n@font-size-large: 1.5em;\n@font-size-big-title: 1.7em;\n@font-size-small: .8em;\n@font-size-xsmall: .7em;\n@font-size-extra-large: 2.1em;\n@font-size-huge: 3.0em;\n// Our website uses this as its base\n@font-size-website-base: 13px;\n// These are basic font sizes used by the recorder. We should start making all of these consistent\n@font-size-title: 1.3em;\n@font-size-header: 1.2em;\n@font-size-command-button: 1.1em;\n@font-size-subtitle: .9em;\n@font-size-option: .8em;\n@font-size-button: .7em;\n\n@icon-size-without-text: 24px;\n@icon-size-with-text: 18px;\n\n/* Sizes */\n@site-min-width: 1004px;\n\n@small-logo-max-width: 265px;\n@small-logo-max-height: 23px;\n@large-logo-max-width: 340px;\n@large-logo-max-height: 50px;\n\n// Preferred hit target size for touch interfaces.\n@touch-target-size: 48px;\n// Smaller touch target size for tightly constrained contexts.\n@touch-target-size-small: 40px;\n\n@button-spacing: 10px;\n\n/* Page gradient */\n@page-gradient: linear-gradient(to bottom, #ffffff 0%, #f5f5f5 60%);\n\n/* Opacities of black (for consistent effect over gradient vs. fixed grays) */\n@darken-hovered: rgba(0, 0, 0, 0.03);\n@darken-selected: rgba(0, 0, 0, 0.06);\n@darken-selected-session: rgba(0, 0, 0, 0.05);\n\n/* Font Colors */\n@font-color-primary: #009900;\n@font-color-secondary: #466c2c;\n@font-color-link: #0F7395;\n\n@font-color-error: #990000;\n@font-color-dark: #000000;\n@font-color: #464646;\n@font-color-light: #777777;\n@font-color-lightest: #999999;\n@font-color-light-background: #b8b8b8;\n@font-light-gray: #aaaaaa;\n\n@font-color-black-80pct: rgba(0, 0, 0, 0.8);\n\n/* Font Colors (Accessibility) */\n@font-color-light-white-background: #767676;\n\n/* New font colors */\n@text-color-primary: rgba(0, 0, 0, .9);\n@text-color-secondary: rgba(0, 0, 0, .7);\n@text-color-on-accent: rgba(255, 255, 255);\n@text-color-additional: rgba(0, 0, 0, .6);\n\n@icon-color-primary: rgba(0, 0, 0, .8);\n@icon-color-secondary: rgba(0, 0, 0, .6);\n@icon-color-additional: rgba(0, 0, 0, .5);\n\n@border-color-primary: rgba(0, 0, 0, .1);\n\n@background-hover: rgba(0, 0, 0, .05);\n@background-active: rgba(0, 0, 0, .1);\n\n/* "Dark Theme" Colors */\n@overlay-background-color: rgba(0, 0, 0, 0.8);\n@icon-color-dark-theme: rgba(255, 255, 255, 0.8);\n@icon-color-active-dark-theme: white;\n@tab-highlight-color-dark-theme: rgba(255, 255, 255, 0.8);\n@border-color-dark-theme: rgba(255, 255, 255, 0.2);\n@font-color-dark-theme: rgba(255, 255, 255, 1);\n@font-color-secondary-dark-theme: rgba(255, 255, 255, 0.8);\n@hover-background-color-dark-theme: rgba(255, 255, 255, 0.1);\n@contrast-background-color-dark-theme: rgba(255, 255, 255, 0.2);\n\n/* Colors */\n@blue-selected: #aedcf1;\n\n@white-bright: #e6e6e6;\n@pure-white: #ffffff;\n\n@red: #bd4f4f;\n@red-medium: #a04242;\n@red-dark: #8c3939;\n@red-light: #ebcaca;\n@red-bright: #dd3217;\n\n@green: #54bf6d;\n@green-medium: #1d8f37;\n@green-dark: #185e0d;\n@green-light: #92c88a;\n@green-background: #eef5f0;\n@green-sunny: #719f46;\n@green-shady: #48761d;\n\n// Branded Panopto Green. Do _NOT_ use this for areas that should be affected by branding\n@panopto-green: #30733F;\n\n@icon-color: #626262;\n@header-color: #f5f5f5;\n@header-dropdown-background-color: White;\n@focused-background-color: #e8e8e8;\n@gray-border: #e0e0e0;\n@gray-light: #d6d6d6;\n@gray-hover: #f0f0f0;\n@gray-very-light: #f2f2f2;\n@gray-hint: #f5f5f5;\n@gray-press: #cccccc;\n@gray-dark: #999999;\n@gray-header: #666;\n@gray-shadow: #888;\n@gray-future: #f2f2f2;\n@dark-selected: #8b8b8b;\n@gray-divider: #989898;\n@light-selected: #dbdbdb;\n@gray-silver: #e7e7e7;\n@gray-disabled: #ebebe4;\n@gray-button-hover: #e5e5e5;\n@gray-transparent: rgba(0,0,0,0.2);\n@gray-transparent-subtle: rgba(0,0,0,0.1);\n@gray-transparent-light: rgba(0,0,0,0.3);\n@gray-transparent-medium: rgba(0,0,0,0.5);\n@gray-transparent-dark: rgba(0,0,0,0.6);\n@gray-dark-shadow: rgba(0,0,0,0.7);\n@gray-darker-shadow: rgba(0,0,0,0.8);\n@gray-watermark: gray;\n@letterbox-color: black;\n@rr-letterbox-color: #3f3f3f;\n@material-box-shadow: 0 6px 10px 0 rgba(0,0,0,.14),\n                      0 1px 18px 0 rgba(0,0,0,.12),\n                      0 3px 5px -1px rgba(0,0,0,.20);\n\n@background-warning: orange;\n\n@yellow: #feffc9;\n\n@stored-quota-foreground: #B56F90;\n@stored-quota-background: #B56F90;\n@delivered-quota-foreground: #4798D0;\n@delivered-quota-background: #4798D0;\n\n@drop-target-background: rgba(231, 239, 254, 0.5);\n@drop-target-background-invalid: fadeout(white, 20%);\n@drop-target-border: fadeout(#4384f4, 57%);\n\n/* For gradient buttons */\n\n/* Small Thumbnail */\n@small-thumbnail-cell-width: 120px;\n@small-thumbnail-height: 60px;\n@small-thumbnail-width: (16 / 9) * @small-thumbnail-height;\n\n/* Volume preview specific colors */\n@neutral-color: #0098cc;\n@loud-color: #9d0b0b;\n@quiet-color: #ffa900;\n@neutral-text-color: #019acd;\n@loud-text-color: #8a1d1d;\n@quiet-text-color: #d08e0b;\n@loud-warning-color: #cf8787;\n@quiet-warning-color: #ffd57f;\n@loud-border: #7fcce6;\n\n/* Opacities */\n@button-opacity: .6;\n@button-hover-opacity: .8;\n@button-active-opacity: 1.0;\n@button-disabled: .3;\n\n/* Borders */\n@input-border-edit: 1px solid #959595;\n@input-border-hover: 1px solid #cdcdcd;\n@input-border-white: 1px solid White;\n@header-dropdown-border: 1px solid #cccccc;\n@input-border-light: 1px solid #cccccc;\n@input-border-extra-light: 1px solid @gray-border;\n/* Input Border Color (WCAG 1.4.11 Accessibility) */\n@input-border-color: #8C8C8C;\n\n/* Common measurements */\n\n// The height of most of our modal inputs\n@input-height: 28px;\n\n/* Images */\n@spinner-path: "Spinner/";\n@spinner-large: "large-comet-animation-grey.gif";\n@spinner-small-white: "spinner_small_white.gif";\n@spinner-small-beige: "spinner_small_eee.gif";\n\n@spinner-large-themable: "spinner_large_themable.png";\n@spinner-small-white-themable: "spinner_small_themable_white.png";\n@spinner-small-beige-themable: "spinner_small_themable_eee.png";\n@spinner-small-gray-themable: "spinner_small_themable_e0e0e0.png";\n\n/* Transitions */\n@viewer-transition: all .125s ease-in-out;\n\n/* Mobile */\n\n// Google recommends a base of 16px\n// https://developers.google.com/speed/docs/insights/UseLegibleFontSizes?hl=en\n@mobile-base-size: 16px;\n\n// Maybe we want to change this to a hex code later\n// so for now use yellow and we can change it easier\n@mobile-font-warning: yellow;\n@mobile-background-disabled: rgb(187, 187, 187);\n\n// Mobile query constants\n\n// "almost" is one less then actual width,\n// "almost" queries should be used for max-width \n// actual queries should be used for min-width\n// By keeping those consistent we can be sure that the layout\n// doesn\'t do funky things on the pixel between the two\n// and we won\'t need to consider which media query comes first\n// NOTE: The parens around the following bits are necessary, LESS generates invalid CSS without them.\n@ipad4-portrait-width: 320px;\n@iphone5-landscape-width: 568px;\n@iphone6-portrait-width: 375px;\n\n@almost-iphone6-portrait-width: (@iphone6-portrait-width - 1);\n\n@ipad-mini-portrait-width: 768px;\n@almost-ipad-mini-portrait-width: (@ipad-mini-portrait-width - 1);\n\n@nexus7-landscape-width: 960px;\n@almost-nexus7-landscape-width: (@nexus7-landscape-width - 1);\n\n/* Embed */\n@defaultEmbedWidth: 720px;\n@defaultEmbedHeight: 405px;\n\n/* Material icons */\n@checkbox-glyph-inset: 3px;\n\n/* Resets */\nbody {\n    margin: 0px;\n}\n\n.clicked {\n    outline: none;\n}\n','@small-loading-indicator-length: 16px;\n\n.border-radius (@radius) {\n    -webkit-border-radius: @radius;\n    -moz-border-radius: @radius;\n    border-radius: @radius;\n}\n\n.box-sizing (@sizing) {\n    box-sizing: @sizing;\n    -moz-box-sizing: @sizing;\n}\n\n// Prevents anti aliasing\n// http://stackoverflow.com/questions/14068103/disable-antialising-when-scaling-images\n.prevent-anti-aliasing () {\n    // The browser will ignore the lines it can\'t understand\n    // and so it works to have the same property listed multiple times\n    image-rendering: optimizeSpeed;\n    image-rendering: -moz-crisp-edges;\n    image-rendering: -o-crisp-edges;\n    image-rendering: -webkit-optimize-contrast;\n    image-rendering: pixelated;\n    image-rendering: optimize-contrast;\n}\n\n.user-select(@select) {\n    -webkit-touch-callout: @select;\n    -webkit-user-select: @select;\n    -khtml-user-select: @select;\n    -moz-user-select: @select;\n    user-select: @select;\n}\n\n.background-image-gradient (@deg, @color-bottom, @color-top) {\n    background-image: -webkit-linear-gradient(@deg, @color-bottom 0%, @color-top 100%);\n    background-image: -moz-linear-gradient(@deg, @color-bottom 0%, @color-top 100%);\n}\n\n.background-complex-gradient (@deg, @color-first, @color-second, @color-third, @color-fourth) {\n    background-image: -webkit-linear-gradient(@deg, @color-first, @color-second, @color-third, @color-fourth);\n    background-image: -moz-linear-gradient(@deg, @color-first, @color-second, @color-third, @color-fourth);\n}\n\n// Block-level elements with known dimensions can be centered within positioned parents.\n.center-block(@width, @height, @h-offset: 0, @v-offset: 0) {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    // Block origin is centered by the above, shift by half height / width to align block center with container center.\n    margin-left: -(@width / 2) + @h-offset;\n    margin-top: -(@height / 2) + @v-offset;\n    width: @width;\n    height: @height;\n}\n\n.clickable () {\n    &:hover {\n        cursor: pointer;\n    }\n}\n\n.access-icons(@length) {\n    .access-item-icon(@image) {\n        .icon("Share/", @image, @length, @length);\n    }\n\n    &.invite {\n        .access-item-icon("icon_email.png");\n    }\n\n    &.group {\n        .access-item-icon("icon_group.png");\n    }\n\n    &.user {\n        .access-item-icon("icon_user.png");\n    }\n}\n\n.pressable (@background-highlight, @background-pressed, @cursor: default) {\n    &:hover {\n        background-color: @background-highlight;\n        cursor: @cursor;\n    }\n    &:focus {\n        background-color: @background-highlight;\n    }\n    &:active {\n        background-color: @background-pressed;\n    }\n}\n\n.hoverable (@background-highlight, @background-pressed, @cursor: default) {\n    .transition(background-color .15s);\n    &:hover {\n        background-color: @background-highlight;\n        cursor: @cursor;\n        .transition(background-color .15s);\n    }\n    &:active {\n        background-color: @background-pressed;\n        .transition(background-color .15s);\n    }\n}\n\n// @child-class-string needs to the the class selector without the \'.\', LESS allows us to pass strings but not complete selectors\n// http://stackoverflow.com/questions/19602812/less-mixin-a-variable-class-name\n.hoverable-child (@child-class-string, @background-parent-highlight, @background-child-highlight, @background-pressed, @cursor: default) {\n    &:hover .@{child-class-string} {\n        background-color: @background-parent-highlight;\n        .transition(background-color .15s);\n    }\n    .@{child-class-string} {\n        .hoverable(@background-child-highlight, @background-pressed, @cursor);\n    }\n}\n\n.hoverable-opacity() {\n    opacity: @button-opacity;\n\n    &:hover, &:focus {\n        opacity: @button-hover-opacity;\n    }\n\n    &:active {\n        opacity: @button-active-opacity;\n    }\n}\n\n.background-image(@root, @image, @repeat: no-repeat, @align: center) {\n    background-image: ~"url(\'@{image-path}@{root}@{image}\')";\n    background-repeat: @repeat;\n    background-position: @align;\n}\n\n.icon (@root, @image, @width: auto, @height: auto, @repeat: no-repeat, @align: center) {\n    .background-image(@root, @image, @repeat, @align);\n    width: @width;\n    height: @height;\n}\n\n.transition(@params) {\n    -webkit-transition: @params;\n    -moz-transition: @params;\n    -o-transition: @params;\n    transition: @params;\n}\n\n.transform(@params) {\n    transform: @params;\n    -webkit-transform: @params;\n}\n\n.pressable-icon(@root, @image, @image-hover, @image-press, @width: auto, @height: auto, @repeat: no-repeat, @align: center) {\n    .icon(@root, @image, @width, @height, @repeat, @align);\n\n    &:hover {\n        .icon(@root, @image-hover, @width, @height, @repeat, @align);\n        cursor: default;\n    }\n    &:focus {\n        .icon(@root, @image-hover, @width, @height, @repeat, @align);\n    }\n    &:active {\n        .icon(@root, @image-press, @width, @height, @repeat, @align);\n    }\n}\n\n.break {\n    display: block;\n    height:  15px;\n}\n\n.clear {\n    clear: both;\n    height: 0px;\n}\n\n.box-shadow(none) {\n    -webkit-box-shadow: none;\n    -moz-box-shadow: none;\n    box-shadow: none;\n}\n\n.box-shadow(@color, @h-shadow, @v-shadow, @blur, @spread) {\n    -webkit-box-shadow: @color @h-shadow @v-shadow @blur @spread;\n    -moz-box-shadow: @color @h-shadow @v-shadow @blur @spread;\n    box-shadow: @color @h-shadow @v-shadow @blur @spread;\n}\n\n.box-shadow-inset(@color, @h-shadow, @v-shadow, @blur, @spread) {\n    -webkit-box-shadow: @color @h-shadow @v-shadow @blur @spread inset;\n    -moz-box-shadow: @color @h-shadow @v-shadow @blur @spread inset;\n    box-shadow: @color @h-shadow @v-shadow @blur @spread inset;\n}\n\n.borders(@top-color, @right-color, @bottom-color, @left-color) {\n    border-top:1px solid @top-color;\n    border-right: 1px solid @right-color;\n    border-bottom:1px solid @bottom-color;\n    border-left:1px solid @left-color;\n}\n\n.rotating-animation() {\n    // IE and FF support the w3 standard keyframes\n    @keyframes rotate {\n        0% {\n            transform: rotate(0deg);\n        }\n        100% {\n            transform: rotate(360deg);\n        }\n    }\n\n    // Chrome and Safari need special webkit\n    @-webkit-keyframes rotate {\n        0% {\n            -webkit-transform: rotate(0deg);\n        }\n        100% {\n            -webkit-transform: rotate(360deg);\n        }\n    }\n\n    animation: rotate 2s linear infinite;\n    -webkit-animation: rotate 2s linear infinite;\n}\n\n.color-holder(@diameter) {\n    position: absolute;\n    .border-radius(50%); // Circle\n    width: @diameter;\n    height: @diameter;\n}\n\n.indicator-border(@border-size, @color){\n    left: -@border-size;\n    top: -@border-size;\n    border: @border-size solid @color;\n}\n\n.small-loading-indicator(@image-grey, @image-themed, @border-color) {\n    @small-length: @small-loading-indicator-length;\n    width: @small-length;\n    height: @small-length;\n    overflow: hidden;\n\n    .branding-color-holders {\n        display: block;\n       .color-holder(15px);\n    }\n\n    .loading-indicator {\n        position: relative;\n        .icon(@spinner-path, @image-grey, @small-length, @small-length);\n        .indicator-border(10px, @border-color);\n\n        &.branded-animation {\n            // The "- 1" fixes a samll issue in Chrome where the when zoomed to 90% you could see a second spinner\n            .icon(@spinner-path, @image-themed, @small-length - 1, @small-length - 1);\n            .rotating-animation();\n        }\n    }\n}\n\n.opacity(@opacity) {\n    opacity: @opacity;\n    @percent: @opacity * 100;\n    // IE8 and below\n    filter: alpha(opacity=@percent);\n}\n\n.horizontal-rule(@color) {\n    display: block;\n    border-bottom: 1px solid @color;\n}\n\n.popup(@z-index) {\n    z-index: @z-index;\n    .box-shadow(@gray-dark, 2px, 3px, 5px, 0);\n    border: @header-dropdown-border;\n    background-color: @header-dropdown-background-color;\n    position: absolute;\n    text-align: left;\n\n    .popup-title {\n        color: @font-color;\n        font-weight: bold;\n    }\n}\n\n.header-dropdown() {\n    .popup(100003);\n\n    > a, > div {\n        &:hover {\n            background-color: @gray-hover;\n            cursor: default;\n        }\n        &:active {\n            background-color: @gray-press;\n        }\n        text-decoration: none;\n        display: block;\n    }\n}\n\n.error {\n    color: @font-color-error !important;\n}\n\n.ellipsis {\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n}\n\n// @lines is honored on WebKit.\n// @max-height provides a fallback on other browsers (simple vertical truncation).\n.multiline-ellipsis (@lines, @max-height) {\n    // On WebKit, show ellipsis after two lines if text is longer.\n    display: -webkit-box;\n    -webkit-line-clamp: @lines;\n    -webkit-box-orient: vertical;\n    // For non-WebKit browsers, just crop lines beyond the second (no ellipsis).\n    max-height: @max-height;\n    overflow: hidden;\n    // Override "nowrap" behavior of .ellipsis (typically also present for tooltips) to enable wrapping to additional lines.\n    white-space: normal;\n}\n\n.attention {\n    font-weight: bold;\n}\n\n\n// Styles a div as a table row, with direct div children as cells\n.table-row (@width: 100%, @align: top) {\n    display: table;\n    width: @width;\n\n    > div, > a, > img, > i {\n        display: table-cell;\n        vertical-align: @align;\n    }\n}\n\n// Styles any element to look and behavior like a link\n.link (@cursor: pointer, @color: @font-color-link) {\n    color: @color;\n    text-decoration: none;\n\n    &:hover, &:focus {\n        cursor: @cursor;\n        text-decoration: underline;\n    }\n}\n\n// Creates a thin, two-tone scrollbar (plain thumb on plain track), where supported by the browser.\n// Width is 8px on Webkit, "thin" on FF (works out to similar), and full width on other browsers.\n// Webkit thumb will have a 5px border-radius (others will have square edges).\n.custom-scrollbar(@thumb-color, @track-color) {\n    @supports not selector(::-webkit-scrollbar) {\n        scrollbar-width: thin;\n        scrollbar-color: @thumb-color @track-color;\n    }\n\n    &::-webkit-scrollbar {\n        background-color: @track-color;\n        width: 8px;\n        height: 8px;\n    }\n\n    &::-webkit-scrollbar-thumb {\n        background-color: @thumb-color;\n        border-radius: 5px;\n    }\n}\n\n.hidden-scrollbar {\n    &::-webkit-scrollbar { display: none; } /* Chrome/Safari/Webkit */\n    scrollbar-width: none; /* Firefox */\n}\n\n.edit-control() {\n    padding: 2px;\n    bottom: 0px;\n    right: 0px;\n    z-index: 1;\n    background-color: white;\n\n    > div {\n        .link;\n        display: inline-block;\n        padding: 3px 8px 4px 8px;\n        border: 1px solid @gray-press;\n        background-color: white;\n    }\n}\n\n.viewer-message() {\n    margin: 20px auto 0px auto;\n    text-align: center;\n    // This is the size used in Viewer.less\n    // repeated here to make this consistent between pages\n    font-size: medium;\n\n    #messageText {\n        padding: 10px;\n    }\n\n    #messageLink {\n        padding: 0px 10px 10px 10px;\n    }\n}\n\n.role-select(@width, @margin-top) {\n    font-family: @font;\n    width: @width;\n    height: 38px;\n    margin-top: @margin-top;\n    padding: 6px;\n    font-size: @font-size-base;\n    .border-radius(4px);\n    color: @font-color-light;\n    display: block;\n    vertical-align: top;\n}\n\n// Shared thumbnail styles\n.thumbnail(@thumbnail-width-param: 196px, @thumbnail-height-param: 110px) {\n    // This is necessary to surface these params in the enclosing scope of the mixin.\n    @thumbnail-width: @thumbnail-width-param;\n    @thumbnail-height: @thumbnail-height-param;\n    @thumbnail-border: 1px;\n    @overlay-margin: 2px;\n\n    .thumbnail-container {\n        // Provide a positioning context for thumbnail overlays\n        position: relative;\n        width: @thumbnail-width;\n        height: @thumbnail-height;\n        border: @thumbnail-border solid @gray-border;\n        .border-radius(3px);\n        background: black;\n        // Prevent child image from bleeding out of the rounded corners\n        overflow: hidden;\n\n        // Give linked thumbnails a darkened border on hover\n        &.viewable:hover {\n            border: @thumbnail-border solid @gray-dark;\n        }\n\n        // Show link or span depending on "viewable" class on container\n        .thumbnail-span,\n        &.viewable .thumbnail-link {\n            display: block;\n        }\n        .thumbnail-link,\n        &.viewable .thumbnail-span {\n            display: none;\n        }\n\n        // Needed to enable "height/width: 100%" to work on ".thumbnail-img/-failed-load" below\n        .thumbnail-link,\n        .thumbnail-span {\n            width: 100%;\n            height: 100%;\n        }\n\n        .thumbnail-img,\n        .thumbnail-failed-load {\n            // Necessary for horizontal centering, correct focus outlines, etc.\n            display: block;\n            // Start by fitting height and allowing width to scale with thumbnail aspect ratio.\n            // Aspect ratios wider than 16:9 are handled in JS by Panopto.Util.fitThumbnailWidth().\n            // Once we drop IE8 we can use background-size: contain for a pure CSS solution.\n            width: auto;\n            height: 100%;\n            // Center the thumbnail horizontally within the container if it\'s narrower than 16:9\n            margin: auto;\n            // Prevent image link border in older IE\n            border: none;\n            // Prevent browser default behavior for dragging images to enable session drag from thumb.\n            pointer-events: none;\n        }\n\n        // Show duration in an overlay at the bottom right of the thumbnail\n        .duration {\n            .overlay();\n            .border-radius(1px);\n            bottom: @overlay-margin;\n            right: @overlay-margin;\n            font-size: @font-size-subtitle;\n        }\n\n        .playlist {\n            .overlay();\n            .border-radius(1px);\n            top: 0;\n            right: 0;\n            height: @thumbnail-height;\n            line-height: @thumbnail-height;\n            text-align: center;\n            padding: 0 5px;\n\n            // Give the playlist overlay a bit of default width so shorter languages don\'t look goofy\n            min-width: 40%;\n\n            // This works around issues with our "line-height"-based vertical centering hack when on a page with an\n            // XHTML 1.0 doctype (resulting in "Almost Standards Mode").\n            &::before,\n            &::after {\n                content: \'\';\n                display: inline-block;\n                vertical-align: middle;\n            }\n\n            // Handle vertical centering of text;\n            .playlist-text {\n                @height-adjustment: 10px;\n                display: inline-block;\n                vertical-align: middle;\n                // Adjust the height between the icon and text\n                line-height: @height-adjustment;\n                // Fix the vertical centering of the text\n                margin-top: -@height-adjustment;\n                font-size: @font-size-website-base;\n            }\n        }\n\n        .completion-overlay {\n            position: absolute;\n            bottom: 0;\n            height: 4px;\n            width: 100%;\n            background: @gray-press;\n\n            // Width is set in script in `itemRendered` callbacks in SessionList.ts and HomeUtils.ts.\n            // Color is set to brand color via .accent-background.\n            .progress {\n                height: 100%;\n            }\n        }\n\n        .archived-overlay {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            display: flex;\n            align-items: center;\n            justify-content: space-around;\n            align-content: space-around;\n            // Control opacity through the backgroun so the text is fully opaque.\n            background: rgba(255, 255, 255, 0.8);\n            color: @icon-color;\n            pointer-events: none;\n        }\n    }\n\n    // Mixin for info overlays on .thumbnail-container (white text on translucent black background)\n    .overlay() {\n        position: absolute;\n        // IE8 fallback (doesn\'t support rgba)\n        background: black;\n        background: rgba(0, 0, 0, 0.7);\n        padding: 1px 3px;\n        color: white;\n        cursor: default;\n        // Enable mouse events to pass through to the underlying thumbnail link / span (NOTE: not supported on IE10-)\n        pointer-events: none;\n    }\n}\n\n// Shared caption option styles\n.caption-options(@asset-path, @item-size, @item-padding, @item-border, @docked-icon-size) {\n    .user-select(none);\n\n    li {\n        // override box-sizing: border-box set on fullscreen options\n        box-sizing: content-box;\n        display: block;\n        float: left;\n        margin-left: 5px;\n        width: @item-size;\n        height: @item-size;\n        // Line height needs to consider padding to align with the width\n        line-height: @item-size - (2 * @item-padding);\n        text-align: center;\n        cursor: pointer;\n        padding: @item-padding;\n\n        // Use a transparent border when not selected to avoid reflow on selection\n        border-width: @item-border;\n        border-style: solid;\n        border-color: transparent;\n    }\n\n    // Color samples have a border color to display as well\n    li .color-sample {\n        border-width: 1px;\n        border-style: solid;\n    }\n\n    .transparent-background {\n        .icon(@asset-path, "checker.png");\n        background-position: left top;\n    }\n\n    .placement-option {\n        // Override the default explicit size to the image\n        width: auto;\n        height: auto;\n    }\n\n    // Docked image icon\n    .Docked div {\n        .icon(@asset-path, "icon_position_Docked.png", @docked-icon-size, @docked-icon-size);\n    }\n\n    // Overlay image icon\n    .Overlay div {\n        .icon(@asset-path, "icon_position_Overlay.png", @docked-icon-size, @docked-icon-size);\n    }\n}\n\n.dialog-triangle() {\n    // These are styles to position and scale unicode triangle character for a dialog\n    position: absolute;\n    display: block;\n    color: white;\n    z-index: 1000;\n    margin-left: -10px;\n    margin-top: -11px;\n    font-size: 1.5em;\n    .transform(scaleX(1.5));\n    cursor: default;\n}\n\n// Used to place an opaque overlay on the screen\n.screen-overlay() {\n    display: none;\n    position: fixed;\n    top: 0; left: 0; right: 0; bottom: 0;\n    background-color: black;\n    @opacity: 70;\n    opacity: (@opacity / 100);\n    filter: alpha(opacity=@opacity); // IE8 hack. "opacity" supported in IE9+\n    z-index: 999;\n}\n\n// Used to vertically align material icons nicely beside text\n.material-icon-beside-text() {\n    // Align the material icon with the text\n    vertical-align: middle;\n    // Underlining material design icons doesn\'t render nicely\n    text-decoration: none;\n    // Give the icon a little space from the title\n    padding-right: 3px;\n}\n\n.folder-header-icon(@width, @height, @icon) {\n    .icon(@asset-path, @icon, @width, @height);\n    float: left;\n    margin-right: 10px;\n}\n\n// Used for close buttons that use the "close"/x material icon\n.close-button (@size) {\n    display: block;\n    text-decoration: none;\n    color: @font-color-light;\n    font-size: @size;\n\n    .hoverable(@gray-transparent, @gray-transparent-dark);\n\n    &:active {\n        color: white;\n    }\n}\n\n.speech-bubble() {\n    @padding: 10px;\n    @border-width: 1px;\n    @background-color: white;\n    position: relative;\n    background-color: @background-color;\n    border: @border-width solid @gray-border;\n    border-radius: 3px;\n    border-bottom-left-radius: 0px;\n    padding: @padding;\n\n    &:before {\n        content: "";\n        position: absolute;\n        top: 100%;\n        left: 0px - @border-width;\n        width: 0px;\n        display: block;\n        border-width: 20px 20px 0 0;\n        border-style: solid;\n        border-color: @gray-border transparent;\n    }\n\n    &:after {\n        content: "";\n        position: absolute;\n        top: 100%;\n        left: 0px;\n        width: 0px;\n        display: block;\n        border-width: 17px 17px 0 0;\n        border-style: solid;\n        border-color: @background-color transparent;\n    }\n}\n\n.flat-button() {\n    display: inline-block;\n    padding: 6px 9px 8px 9px;\n    .border-radius(3px);\n    background-color: @header-color;\n    cursor: pointer;\n    text-decoration: none;\n    font-weight: 600;\n    color: @font-color;\n    text-align: center;\n    border: 1px solid @gray-light;\n\n    &.safety-background {\n        color: white;\n        border: 0px;\n        padding: 7px 10px 9px 10px;\n    }\n\n    &:hover, &:active {\n        text-decoration: none;\n    }\n}\n\n.copyright-warning() {\n    font-size: @font-size-small;\n    color: @font-color-light-white-background;\n    text-align: center;\n    padding: 20px;\n}\n\n.material-checkbox(\n    @color: @icon-color,\n    @background: rgba(255, 255, 255, 0.85)\n) {\n    -webkit-appearance: unset;\n    -moz-appearance: none;\n    position: relative;\n    color: @color;\n\n    // Remove border and background color as they still show up on Mobile Safari\n    // even with appearance unset\n    border: none;\n    background-color: transparent;\n\n    &::before {\n        content: "";\n        position: absolute;\n        top: @checkbox-glyph-inset;\n        right: @checkbox-glyph-inset;\n        bottom: @checkbox-glyph-inset;\n        left: @checkbox-glyph-inset;\n        border-radius: 3px;\n        background: @background;\n    }\n\n    &::after {\n        content: "check_box_outline_blank";\n        position: absolute;\n    }\n    &:checked::after {\n        content: "check_box";\n    }\n}\n\n.material-radio(\n    @color: @icon-color,\n    @background: rgba(255, 255, 255, 0.85)\n) {\n    -webkit-appearance: unset;\n    -moz-appearance: none;\n    position: relative;\n    color: @color;\n\n    // Remove border and background color as they still show up on Mobile Safari\n    // even with appearance unset\n    border: none;\n    background-color: transparent;\n\n    &::before {\n        content: "";\n        position: absolute;\n        top: @checkbox-glyph-inset;\n        right: @checkbox-glyph-inset;\n        bottom: @checkbox-glyph-inset;\n        left: @checkbox-glyph-inset;\n        border-radius: 3px;\n        background: @background;\n    }\n\n    &::after {\n        content: "radio_button_unchecked";\n        position: absolute;\n    }\n    &:checked::after {\n        content: "radio_button_checked";\n    }\n}\n\n.placeholder(@rules) {\n    &::placeholder {\n        @rules();\n    }\n}\n\n.material-select() {\n    background: url(data:image/svg+xml;base64,) no-repeat right 2px center;\n    -moz-appearance: none; \n    -webkit-appearance: none; \n    appearance: none;\n}\n\n.clear-search-icon() {\n    @icon-size: 18px;\n    .icon("Widgets/", "icon_cancel.svg", @icon-size, @icon-size, no-repeat);\n    background-size: @icon-size;\n}\n'],sourceRoot:""}]);const s=/^((10|367|819)3|3180|4044|4788|6116|9176|9541)$/.test(t.j)?a:null},10510(e,n,t){"use strict";t.d(n,{A:()=>s});var o=t(82001),r=t.n(o),i=t(40935),a=t.n(i)()(r());a.push([e.id,'/* Constants / styles used across the product */\n/* Fonts */\n:root {\n  --panopto-font-family: Segoe UI, Helvetica, sans-serif;\n  --panopto-font-family-semibold: Segoe UI Semibold, Helvetica Neue, Segoe UI, Helvetica, sans-serif;\n  --panopto-font-family-light: Segoe UI Light, HelveticaNeue-Light, Segoe UI, Helvetica, sans-serif;\n}\n/* Sizes */\n/* Page gradient */\n/* Opacities of black (for consistent effect over gradient vs. fixed grays) */\n/* Font Colors */\n/* Font Colors (Accessibility) */\n/* New font colors */\n/* "Dark Theme" Colors */\n/* Colors */\n/* For gradient buttons */\n/* Small Thumbnail */\n/* Volume preview specific colors */\n/* Opacities */\n/* Borders */\n/* Input Border Color (WCAG 1.4.11 Accessibility) */\n/* Common measurements */\n/* Images */\n/* Transitions */\n/* Mobile */\n/* Embed */\n/* Material icons */\n/* Resets */\nbody {\n  margin: 0px;\n}\n.clicked {\n  outline: none;\n}\n.custom-date-range-tag {\n  border: 1px solid #cccccc;\n  border-radius: 20px;\n  background-color: #f5f5f5;\n  padding: 0px 5px;\n  margin-left: 5px;\n  font-size: 12px;\n  line-height: 24px;\n  cursor: pointer;\n}\n',"",{version:3,sources:["webpack://./React/Shared/Components/CustomDateRangeTag.less","webpack://./../../WebCore/css/Assets/Assets.less"],names:[],mappings:"AAAA,+CAA+C;AAC/C,UAAU;ACcV;EACI,sDAAA;EACA,kGAAA;EACA,iGAAA;ADZJ;AACA,UAAU;AACV,kBAAkB;AAClB,6EAA6E;AAC7E,gBAAgB;AAChB,gCAAgC;AAChC,oBAAoB;AACpB,wBAAwB;AACxB,WAAW;AACX,yBAAyB;AACzB,oBAAoB;AACpB,mCAAmC;AACnC,cAAc;AACd,YAAY;AACZ,mDAAmD;AACnD,wBAAwB;AACxB,WAAW;AACX,gBAAgB;AAChB,WAAW;AACX,UAAU;AACV,mBAAmB;AACnB,WAAW;ACqPX;EACI,WAAA;ADnPJ;ACsPA;EACI,aAAA;ADpPJ;AA/BA;EACI,yBAAA;EACA,mBAAA;EACA,yBAAA;EACA,gBAAA;EACA,gBAAA;EACA,eAAA;EACA,iBAAA;EACA,eAAA;AAiCJ",sourcesContent:['@import "../../../../../WebCore/css/Assets/Assets.less";\n\n.custom-date-range-tag {\n    border: 1px solid @gray-press;\n    border-radius: 20px;\n    background-color: @header-color;\n    padding: 0px 5px;\n    margin-left: 5px;\n    font-size: 12px;\n    line-height: 24px;\n    cursor: pointer;\n}\n','/* Constants / styles used across the product */\n\n/* Fonts */\n@font: Segoe UI, Helvetica, sans-serif;\n@font-semibold: Segoe UI Semibold, Helvetica Neue, Segoe UI, Helvetica, sans-serif;\n@font-light: Segoe UI Light, HelveticaNeue-Light, Segoe UI, Helvetica, sans-serif;\n.font-light() {\n    font-family: var(--panopto-font-family-light);\n    font-weight: 100; // FF doesn\'t include Segoe UI Light, font-weight lighter approximates it.\n}\n.font-semibold() {\n    font-family: var(--panopto-font-family-semibold);\n    font-weight: 600;\n}\n\n:root {\n    --panopto-font-family: @font;\n    --panopto-font-family-semibold: @font-semibold;\n    --panopto-font-family-light: @font-light;\n}\n\n@font-size-base: 16px;\n@font-size-medium: 1.45em;\n@font-size-large: 1.5em;\n@font-size-big-title: 1.7em;\n@font-size-small: .8em;\n@font-size-xsmall: .7em;\n@font-size-extra-large: 2.1em;\n@font-size-huge: 3.0em;\n// Our website uses this as its base\n@font-size-website-base: 13px;\n// These are basic font sizes used by the recorder. We should start making all of these consistent\n@font-size-title: 1.3em;\n@font-size-header: 1.2em;\n@font-size-command-button: 1.1em;\n@font-size-subtitle: .9em;\n@font-size-option: .8em;\n@font-size-button: .7em;\n\n@icon-size-without-text: 24px;\n@icon-size-with-text: 18px;\n\n/* Sizes */\n@site-min-width: 1004px;\n\n@small-logo-max-width: 265px;\n@small-logo-max-height: 23px;\n@large-logo-max-width: 340px;\n@large-logo-max-height: 50px;\n\n// Preferred hit target size for touch interfaces.\n@touch-target-size: 48px;\n// Smaller touch target size for tightly constrained contexts.\n@touch-target-size-small: 40px;\n\n@button-spacing: 10px;\n\n/* Page gradient */\n@page-gradient: linear-gradient(to bottom, #ffffff 0%, #f5f5f5 60%);\n\n/* Opacities of black (for consistent effect over gradient vs. fixed grays) */\n@darken-hovered: rgba(0, 0, 0, 0.03);\n@darken-selected: rgba(0, 0, 0, 0.06);\n@darken-selected-session: rgba(0, 0, 0, 0.05);\n\n/* Font Colors */\n@font-color-primary: #009900;\n@font-color-secondary: #466c2c;\n@font-color-link: #0F7395;\n\n@font-color-error: #990000;\n@font-color-dark: #000000;\n@font-color: #464646;\n@font-color-light: #777777;\n@font-color-lightest: #999999;\n@font-color-light-background: #b8b8b8;\n@font-light-gray: #aaaaaa;\n\n@font-color-black-80pct: rgba(0, 0, 0, 0.8);\n\n/* Font Colors (Accessibility) */\n@font-color-light-white-background: #767676;\n\n/* New font colors */\n@text-color-primary: rgba(0, 0, 0, .9);\n@text-color-secondary: rgba(0, 0, 0, .7);\n@text-color-on-accent: rgba(255, 255, 255);\n@text-color-additional: rgba(0, 0, 0, .6);\n\n@icon-color-primary: rgba(0, 0, 0, .8);\n@icon-color-secondary: rgba(0, 0, 0, .6);\n@icon-color-additional: rgba(0, 0, 0, .5);\n\n@border-color-primary: rgba(0, 0, 0, .1);\n\n@background-hover: rgba(0, 0, 0, .05);\n@background-active: rgba(0, 0, 0, .1);\n\n/* "Dark Theme" Colors */\n@overlay-background-color: rgba(0, 0, 0, 0.8);\n@icon-color-dark-theme: rgba(255, 255, 255, 0.8);\n@icon-color-active-dark-theme: white;\n@tab-highlight-color-dark-theme: rgba(255, 255, 255, 0.8);\n@border-color-dark-theme: rgba(255, 255, 255, 0.2);\n@font-color-dark-theme: rgba(255, 255, 255, 1);\n@font-color-secondary-dark-theme: rgba(255, 255, 255, 0.8);\n@hover-background-color-dark-theme: rgba(255, 255, 255, 0.1);\n@contrast-background-color-dark-theme: rgba(255, 255, 255, 0.2);\n\n/* Colors */\n@blue-selected: #aedcf1;\n\n@white-bright: #e6e6e6;\n@pure-white: #ffffff;\n\n@red: #bd4f4f;\n@red-medium: #a04242;\n@red-dark: #8c3939;\n@red-light: #ebcaca;\n@red-bright: #dd3217;\n\n@green: #54bf6d;\n@green-medium: #1d8f37;\n@green-dark: #185e0d;\n@green-light: #92c88a;\n@green-background: #eef5f0;\n@green-sunny: #719f46;\n@green-shady: #48761d;\n\n// Branded Panopto Green. Do _NOT_ use this for areas that should be affected by branding\n@panopto-green: #30733F;\n\n@icon-color: #626262;\n@header-color: #f5f5f5;\n@header-dropdown-background-color: White;\n@focused-background-color: #e8e8e8;\n@gray-border: #e0e0e0;\n@gray-light: #d6d6d6;\n@gray-hover: #f0f0f0;\n@gray-very-light: #f2f2f2;\n@gray-hint: #f5f5f5;\n@gray-press: #cccccc;\n@gray-dark: #999999;\n@gray-header: #666;\n@gray-shadow: #888;\n@gray-future: #f2f2f2;\n@dark-selected: #8b8b8b;\n@gray-divider: #989898;\n@light-selected: #dbdbdb;\n@gray-silver: #e7e7e7;\n@gray-disabled: #ebebe4;\n@gray-button-hover: #e5e5e5;\n@gray-transparent: rgba(0,0,0,0.2);\n@gray-transparent-subtle: rgba(0,0,0,0.1);\n@gray-transparent-light: rgba(0,0,0,0.3);\n@gray-transparent-medium: rgba(0,0,0,0.5);\n@gray-transparent-dark: rgba(0,0,0,0.6);\n@gray-dark-shadow: rgba(0,0,0,0.7);\n@gray-darker-shadow: rgba(0,0,0,0.8);\n@gray-watermark: gray;\n@letterbox-color: black;\n@rr-letterbox-color: #3f3f3f;\n@material-box-shadow: 0 6px 10px 0 rgba(0,0,0,.14),\n                      0 1px 18px 0 rgba(0,0,0,.12),\n                      0 3px 5px -1px rgba(0,0,0,.20);\n\n@background-warning: orange;\n\n@yellow: #feffc9;\n\n@stored-quota-foreground: #B56F90;\n@stored-quota-background: #B56F90;\n@delivered-quota-foreground: #4798D0;\n@delivered-quota-background: #4798D0;\n\n@drop-target-background: rgba(231, 239, 254, 0.5);\n@drop-target-background-invalid: fadeout(white, 20%);\n@drop-target-border: fadeout(#4384f4, 57%);\n\n/* For gradient buttons */\n\n/* Small Thumbnail */\n@small-thumbnail-cell-width: 120px;\n@small-thumbnail-height: 60px;\n@small-thumbnail-width: (16 / 9) * @small-thumbnail-height;\n\n/* Volume preview specific colors */\n@neutral-color: #0098cc;\n@loud-color: #9d0b0b;\n@quiet-color: #ffa900;\n@neutral-text-color: #019acd;\n@loud-text-color: #8a1d1d;\n@quiet-text-color: #d08e0b;\n@loud-warning-color: #cf8787;\n@quiet-warning-color: #ffd57f;\n@loud-border: #7fcce6;\n\n/* Opacities */\n@button-opacity: .6;\n@button-hover-opacity: .8;\n@button-active-opacity: 1.0;\n@button-disabled: .3;\n\n/* Borders */\n@input-border-edit: 1px solid #959595;\n@input-border-hover: 1px solid #cdcdcd;\n@input-border-white: 1px solid White;\n@header-dropdown-border: 1px solid #cccccc;\n@input-border-light: 1px solid #cccccc;\n@input-border-extra-light: 1px solid @gray-border;\n/* Input Border Color (WCAG 1.4.11 Accessibility) */\n@input-border-color: #8C8C8C;\n\n/* Common measurements */\n\n// The height of most of our modal inputs\n@input-height: 28px;\n\n/* Images */\n@spinner-path: "Spinner/";\n@spinner-large: "large-comet-animation-grey.gif";\n@spinner-small-white: "spinner_small_white.gif";\n@spinner-small-beige: "spinner_small_eee.gif";\n\n@spinner-large-themable: "spinner_large_themable.png";\n@spinner-small-white-themable: "spinner_small_themable_white.png";\n@spinner-small-beige-themable: "spinner_small_themable_eee.png";\n@spinner-small-gray-themable: "spinner_small_themable_e0e0e0.png";\n\n/* Transitions */\n@viewer-transition: all .125s ease-in-out;\n\n/* Mobile */\n\n// Google recommends a base of 16px\n// https://developers.google.com/speed/docs/insights/UseLegibleFontSizes?hl=en\n@mobile-base-size: 16px;\n\n// Maybe we want to change this to a hex code later\n// so for now use yellow and we can change it easier\n@mobile-font-warning: yellow;\n@mobile-background-disabled: rgb(187, 187, 187);\n\n// Mobile query constants\n\n// "almost" is one less then actual width,\n// "almost" queries should be used for max-width \n// actual queries should be used for min-width\n// By keeping those consistent we can be sure that the layout\n// doesn\'t do funky things on the pixel between the two\n// and we won\'t need to consider which media query comes first\n// NOTE: The parens around the following bits are necessary, LESS generates invalid CSS without them.\n@ipad4-portrait-width: 320px;\n@iphone5-landscape-width: 568px;\n@iphone6-portrait-width: 375px;\n\n@almost-iphone6-portrait-width: (@iphone6-portrait-width - 1);\n\n@ipad-mini-portrait-width: 768px;\n@almost-ipad-mini-portrait-width: (@ipad-mini-portrait-width - 1);\n\n@nexus7-landscape-width: 960px;\n@almost-nexus7-landscape-width: (@nexus7-landscape-width - 1);\n\n/* Embed */\n@defaultEmbedWidth: 720px;\n@defaultEmbedHeight: 405px;\n\n/* Material icons */\n@checkbox-glyph-inset: 3px;\n\n/* Resets */\nbody {\n    margin: 0px;\n}\n\n.clicked {\n    outline: none;\n}\n'],sourceRoot:""}]);const s=/^(4788|6929|9541)$/.test(t.j)?a:null},83316(e,n,t){"use strict";t.d(n,{A:()=>s});var o=t(82001),r=t.n(o),i=t(40935),a=t.n(i)()(r());a.push([e.id,'/* Constants / styles used across the product */\n/* Fonts */\n:root {\n  --panopto-font-family: Segoe UI, Helvetica, sans-serif;\n  --panopto-font-family-semibold: Segoe UI Semibold, Helvetica Neue, Segoe UI, Helvetica, sans-serif;\n  --panopto-font-family-light: Segoe UI Light, HelveticaNeue-Light, Segoe UI, Helvetica, sans-serif;\n}\n/* Sizes */\n/* Page gradient */\n/* Opacities of black (for consistent effect over gradient vs. fixed grays) */\n/* Font Colors */\n/* Font Colors (Accessibility) */\n/* New font colors */\n/* "Dark Theme" Colors */\n/* Colors */\n/* For gradient buttons */\n/* Small Thumbnail */\n/* Volume preview specific colors */\n/* Opacities */\n/* Borders */\n/* Input Border Color (WCAG 1.4.11 Accessibility) */\n/* Common measurements */\n/* Images */\n/* Transitions */\n/* Mobile */\n/* Embed */\n/* Material icons */\n/* Resets */\nbody {\n  margin: 0px;\n}\n.clicked {\n  outline: none;\n}\n.date-filter {\n  color: #464646;\n}\n.date-filter select {\n  height: 26px;\n  vertical-align: bottom;\n  color: #464646;\n}\n.date-filter .custom-date-range-tag-wrapper {\n  display: inline-block;\n  vertical-align: bottom;\n}\n.date-filter.right-aligned {\n  position: relative;\n}\n.date-filter.right-aligned .custom-date-range-tag-wrapper {\n  margin-right: 5px;\n}\n.date-filter.right-aligned .date-range-popup {\n  right: 0px;\n}\n',"",{version:3,sources:["webpack://./React/Shared/Components/DateFilter.less","webpack://./../../WebCore/css/Assets/Assets.less"],names:[],mappings:"AAAA,+CAA+C;AAC/C,UAAU;ACcV;EACI,sDAAA;EACA,kGAAA;EACA,iGAAA;ADZJ;AACA,UAAU;AACV,kBAAkB;AAClB,6EAA6E;AAC7E,gBAAgB;AAChB,gCAAgC;AAChC,oBAAoB;AACpB,wBAAwB;AACxB,WAAW;AACX,yBAAyB;AACzB,oBAAoB;AACpB,mCAAmC;AACnC,cAAc;AACd,YAAY;AACZ,mDAAmD;AACnD,wBAAwB;AACxB,WAAW;AACX,gBAAgB;AAChB,WAAW;AACX,UAAU;AACV,mBAAmB;AACnB,WAAW;ACqPX;EACI,WAAA;ADnPJ;ACsPA;EACI,aAAA;ADpPJ;AA/BA;EACI,cAAA;AAiCJ;AAlCA;EAIQ,YAAA;EACA,sBAAA;EACA,cAAA;AAiCR;AAvCA;EAUQ,qBAAA;EACA,sBAAA;AAgCR;AA7BI;EACI,kBAAA;AA+BR;AAhCI;EAIQ,iBAAA;AA+BZ;AAnCI;EAQQ,UAAA;AA8BZ",sourcesContent:['@import "../../../../../WebCore/css/Assets/Assets.less";\n\n.date-filter {\n    color: @font-color;\n\n    select {\n        height: 26px;\n        vertical-align: bottom;\n        color: @font-color;\n    }\n\n    .custom-date-range-tag-wrapper {\n        display: inline-block;\n        vertical-align: bottom;\n    }\n\n    &.right-aligned {\n        position: relative;\n\n        .custom-date-range-tag-wrapper {\n            margin-right: 5px;\n        }\n\n        .date-range-popup {\n            right: 0px;\n        }\n    }\n}\n','/* Constants / styles used across the product */\n\n/* Fonts */\n@font: Segoe UI, Helvetica, sans-serif;\n@font-semibold: Segoe UI Semibold, Helvetica Neue, Segoe UI, Helvetica, sans-serif;\n@font-light: Segoe UI Light, HelveticaNeue-Light, Segoe UI, Helvetica, sans-serif;\n.font-light() {\n    font-family: var(--panopto-font-family-light);\n    font-weight: 100; // FF doesn\'t include Segoe UI Light, font-weight lighter approximates it.\n}\n.font-semibold() {\n    font-family: var(--panopto-font-family-semibold);\n    font-weight: 600;\n}\n\n:root {\n    --panopto-font-family: @font;\n    --panopto-font-family-semibold: @font-semibold;\n    --panopto-font-family-light: @font-light;\n}\n\n@font-size-base: 16px;\n@font-size-medium: 1.45em;\n@font-size-large: 1.5em;\n@font-size-big-title: 1.7em;\n@font-size-small: .8em;\n@font-size-xsmall: .7em;\n@font-size-extra-large: 2.1em;\n@font-size-huge: 3.0em;\n// Our website uses this as its base\n@font-size-website-base: 13px;\n// These are basic font sizes used by the recorder. We should start making all of these consistent\n@font-size-title: 1.3em;\n@font-size-header: 1.2em;\n@font-size-command-button: 1.1em;\n@font-size-subtitle: .9em;\n@font-size-option: .8em;\n@font-size-button: .7em;\n\n@icon-size-without-text: 24px;\n@icon-size-with-text: 18px;\n\n/* Sizes */\n@site-min-width: 1004px;\n\n@small-logo-max-width: 265px;\n@small-logo-max-height: 23px;\n@large-logo-max-width: 340px;\n@large-logo-max-height: 50px;\n\n// Preferred hit target size for touch interfaces.\n@touch-target-size: 48px;\n// Smaller touch target size for tightly constrained contexts.\n@touch-target-size-small: 40px;\n\n@button-spacing: 10px;\n\n/* Page gradient */\n@page-gradient: linear-gradient(to bottom, #ffffff 0%, #f5f5f5 60%);\n\n/* Opacities of black (for consistent effect over gradient vs. fixed grays) */\n@darken-hovered: rgba(0, 0, 0, 0.03);\n@darken-selected: rgba(0, 0, 0, 0.06);\n@darken-selected-session: rgba(0, 0, 0, 0.05);\n\n/* Font Colors */\n@font-color-primary: #009900;\n@font-color-secondary: #466c2c;\n@font-color-link: #0F7395;\n\n@font-color-error: #990000;\n@font-color-dark: #000000;\n@font-color: #464646;\n@font-color-light: #777777;\n@font-color-lightest: #999999;\n@font-color-light-background: #b8b8b8;\n@font-light-gray: #aaaaaa;\n\n@font-color-black-80pct: rgba(0, 0, 0, 0.8);\n\n/* Font Colors (Accessibility) */\n@font-color-light-white-background: #767676;\n\n/* New font colors */\n@text-color-primary: rgba(0, 0, 0, .9);\n@text-color-secondary: rgba(0, 0, 0, .7);\n@text-color-on-accent: rgba(255, 255, 255);\n@text-color-additional: rgba(0, 0, 0, .6);\n\n@icon-color-primary: rgba(0, 0, 0, .8);\n@icon-color-secondary: rgba(0, 0, 0, .6);\n@icon-color-additional: rgba(0, 0, 0, .5);\n\n@border-color-primary: rgba(0, 0, 0, .1);\n\n@background-hover: rgba(0, 0, 0, .05);\n@background-active: rgba(0, 0, 0, .1);\n\n/* "Dark Theme" Colors */\n@overlay-background-color: rgba(0, 0, 0, 0.8);\n@icon-color-dark-theme: rgba(255, 255, 255, 0.8);\n@icon-color-active-dark-theme: white;\n@tab-highlight-color-dark-theme: rgba(255, 255, 255, 0.8);\n@border-color-dark-theme: rgba(255, 255, 255, 0.2);\n@font-color-dark-theme: rgba(255, 255, 255, 1);\n@font-color-secondary-dark-theme: rgba(255, 255, 255, 0.8);\n@hover-background-color-dark-theme: rgba(255, 255, 255, 0.1);\n@contrast-background-color-dark-theme: rgba(255, 255, 255, 0.2);\n\n/* Colors */\n@blue-selected: #aedcf1;\n\n@white-bright: #e6e6e6;\n@pure-white: #ffffff;\n\n@red: #bd4f4f;\n@red-medium: #a04242;\n@red-dark: #8c3939;\n@red-light: #ebcaca;\n@red-bright: #dd3217;\n\n@green: #54bf6d;\n@green-medium: #1d8f37;\n@green-dark: #185e0d;\n@green-light: #92c88a;\n@green-background: #eef5f0;\n@green-sunny: #719f46;\n@green-shady: #48761d;\n\n// Branded Panopto Green. Do _NOT_ use this for areas that should be affected by branding\n@panopto-green: #30733F;\n\n@icon-color: #626262;\n@header-color: #f5f5f5;\n@header-dropdown-background-color: White;\n@focused-background-color: #e8e8e8;\n@gray-border: #e0e0e0;\n@gray-light: #d6d6d6;\n@gray-hover: #f0f0f0;\n@gray-very-light: #f2f2f2;\n@gray-hint: #f5f5f5;\n@gray-press: #cccccc;\n@gray-dark: #999999;\n@gray-header: #666;\n@gray-shadow: #888;\n@gray-future: #f2f2f2;\n@dark-selected: #8b8b8b;\n@gray-divider: #989898;\n@light-selected: #dbdbdb;\n@gray-silver: #e7e7e7;\n@gray-disabled: #ebebe4;\n@gray-button-hover: #e5e5e5;\n@gray-transparent: rgba(0,0,0,0.2);\n@gray-transparent-subtle: rgba(0,0,0,0.1);\n@gray-transparent-light: rgba(0,0,0,0.3);\n@gray-transparent-medium: rgba(0,0,0,0.5);\n@gray-transparent-dark: rgba(0,0,0,0.6);\n@gray-dark-shadow: rgba(0,0,0,0.7);\n@gray-darker-shadow: rgba(0,0,0,0.8);\n@gray-watermark: gray;\n@letterbox-color: black;\n@rr-letterbox-color: #3f3f3f;\n@material-box-shadow: 0 6px 10px 0 rgba(0,0,0,.14),\n                      0 1px 18px 0 rgba(0,0,0,.12),\n                      0 3px 5px -1px rgba(0,0,0,.20);\n\n@background-warning: orange;\n\n@yellow: #feffc9;\n\n@stored-quota-foreground: #B56F90;\n@stored-quota-background: #B56F90;\n@delivered-quota-foreground: #4798D0;\n@delivered-quota-background: #4798D0;\n\n@drop-target-background: rgba(231, 239, 254, 0.5);\n@drop-target-background-invalid: fadeout(white, 20%);\n@drop-target-border: fadeout(#4384f4, 57%);\n\n/* For gradient buttons */\n\n/* Small Thumbnail */\n@small-thumbnail-cell-width: 120px;\n@small-thumbnail-height: 60px;\n@small-thumbnail-width: (16 / 9) * @small-thumbnail-height;\n\n/* Volume preview specific colors */\n@neutral-color: #0098cc;\n@loud-color: #9d0b0b;\n@quiet-color: #ffa900;\n@neutral-text-color: #019acd;\n@loud-text-color: #8a1d1d;\n@quiet-text-color: #d08e0b;\n@loud-warning-color: #cf8787;\n@quiet-warning-color: #ffd57f;\n@loud-border: #7fcce6;\n\n/* Opacities */\n@button-opacity: .6;\n@button-hover-opacity: .8;\n@button-active-opacity: 1.0;\n@button-disabled: .3;\n\n/* Borders */\n@input-border-edit: 1px solid #959595;\n@input-border-hover: 1px solid #cdcdcd;\n@input-border-white: 1px solid White;\n@header-dropdown-border: 1px solid #cccccc;\n@input-border-light: 1px solid #cccccc;\n@input-border-extra-light: 1px solid @gray-border;\n/* Input Border Color (WCAG 1.4.11 Accessibility) */\n@input-border-color: #8C8C8C;\n\n/* Common measurements */\n\n// The height of most of our modal inputs\n@input-height: 28px;\n\n/* Images */\n@spinner-path: "Spinner/";\n@spinner-large: "large-comet-animation-grey.gif";\n@spinner-small-white: "spinner_small_white.gif";\n@spinner-small-beige: "spinner_small_eee.gif";\n\n@spinner-large-themable: "spinner_large_themable.png";\n@spinner-small-white-themable: "spinner_small_themable_white.png";\n@spinner-small-beige-themable: "spinner_small_themable_eee.png";\n@spinner-small-gray-themable: "spinner_small_themable_e0e0e0.png";\n\n/* Transitions */\n@viewer-transition: all .125s ease-in-out;\n\n/* Mobile */\n\n// Google recommends a base of 16px\n// https://developers.google.com/speed/docs/insights/UseLegibleFontSizes?hl=en\n@mobile-base-size: 16px;\n\n// Maybe we want to change this to a hex code later\n// so for now use yellow and we can change it easier\n@mobile-font-warning: yellow;\n@mobile-background-disabled: rgb(187, 187, 187);\n\n// Mobile query constants\n\n// "almost" is one less then actual width,\n// "almost" queries should be used for max-width \n// actual queries should be used for min-width\n// By keeping those consistent we can be sure that the layout\n// doesn\'t do funky things on the pixel between the two\n// and we won\'t need to consider which media query comes first\n// NOTE: The parens around the following bits are necessary, LESS generates invalid CSS without them.\n@ipad4-portrait-width: 320px;\n@iphone5-landscape-width: 568px;\n@iphone6-portrait-width: 375px;\n\n@almost-iphone6-portrait-width: (@iphone6-portrait-width - 1);\n\n@ipad-mini-portrait-width: 768px;\n@almost-ipad-mini-portrait-width: (@ipad-mini-portrait-width - 1);\n\n@nexus7-landscape-width: 960px;\n@almost-nexus7-landscape-width: (@nexus7-landscape-width - 1);\n\n/* Embed */\n@defaultEmbedWidth: 720px;\n@defaultEmbedHeight: 405px;\n\n/* Material icons */\n@checkbox-glyph-inset: 3px;\n\n/* Resets */\nbody {\n    margin: 0px;\n}\n\n.clicked {\n    outline: none;\n}\n'],sourceRoot:""}]);const s=/^(4788|6929|9541)$/.test(t.j)?a:null},14559(e,n,t){"use strict";t.d(n,{A:()=>s});var o=t(82001),r=t.n(o),i=t(40935),a=t.n(i)()(r());a.push([e.id,'/* Constants / styles used across the product */\n/* Fonts */\n:root {\n  --panopto-font-family: Segoe UI, Helvetica, sans-serif;\n  --panopto-font-family-semibold: Segoe UI Semibold, Helvetica Neue, Segoe UI, Helvetica, sans-serif;\n  --panopto-font-family-light: Segoe UI Light, HelveticaNeue-Light, Segoe UI, Helvetica, sans-serif;\n}\n/* Sizes */\n/* Page gradient */\n/* Opacities of black (for consistent effect over gradient vs. fixed grays) */\n/* Font Colors */\n/* Font Colors (Accessibility) */\n/* New font colors */\n/* "Dark Theme" Colors */\n/* Colors */\n/* For gradient buttons */\n/* Small Thumbnail */\n/* Volume preview specific colors */\n/* Opacities */\n/* Borders */\n/* Input Border Color (WCAG 1.4.11 Accessibility) */\n/* Common measurements */\n/* Images */\n/* Transitions */\n/* Mobile */\n/* Embed */\n/* Material icons */\n/* Resets */\nbody {\n  margin: 0px;\n}\n.clicked {\n  outline: none;\n}\n.date-range-popup {\n  position: absolute;\n  background-color: white;\n  border: 1px solid #cccccc;\n  border-radius: 3px;\n  box-shadow: #999999 0px 1px 1px 0;\n  padding: 16px;\n  margin-top: 10px;\n  font-size: 16px;\n  z-index: 1;\n}\n.date-range-popup .popup-content {\n  position: relative;\n}\n.date-range-popup .popup-content .popup-title {\n  font-size: 20px;\n  padding-bottom: 16px;\n  font-weight: normal;\n}\n.date-range-popup .popup-content .picker-wrapper {\n  white-space: nowrap;\n}\n.date-range-popup .popup-content .picker-wrapper span {\n  vertical-align: bottom;\n}\n.date-range-popup .popup-content .picker-wrapper input {\n  border: 1px solid #cccccc;\n  margin-left: 10px;\n  width: 130px;\n}\n.date-range-popup .popup-content .button-container {\n  padding-top: 16px;\n  text-align: right;\n}\n.date-range-popup .popup-content .button-container button {\n  margin-left: 10px;\n}\n.date-range-popup .popup-content .button-container button.safety-background {\n  color: white;\n}\n.date-range-popup .popup-content .close-button {\n  position: absolute;\n  top: 0px;\n  right: 0px;\n  cursor: pointer;\n}\n',"",{version:3,sources:["webp